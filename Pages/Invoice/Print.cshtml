@page "{id:int}"
@model E_Invoice_system.Pages.Invoice.PrintModel
@{
    Layout = null;
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Invoice - @(Model.Invoice.invoice_no ?? Model.Invoice.id.ToString())</title>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800;900&display=swap" rel="stylesheet">
    <style>
        :root {
            --primary-red: #BC1823;
            --dark-grey: #1f2937;
            --light-grey: #f3f4f6;
            --text-main: #111827;
            --text-muted: #4b5563;
        }

        * { margin: 0; padding: 0; box-sizing: border-box; }
        
        body { 
            font-family: 'Inter', sans-serif; 
            background: #e5e7eb; 
            display: flex; 
            flex-direction: column; 
            align-items: center;
        }

        .no-print {
            width: 100%;
            max-width: 210mm;
            padding: 20px;
            display: flex;
            justify-content: flex-end;
            gap: 10px;
        }

        .btn-print {
            background: var(--primary-red);
            color: white;
            border: none;
            padding: 10px 25px;
            border-radius: 6px;
            font-weight: 700;
            cursor: pointer;
            text-transform: uppercase;
            font-size: 14px;
        }

        .btn-close {
            background: var(--dark-grey);
            color: white;
            border: none;
            padding: 10px 25px;
            border-radius: 6px;
            font-weight: 700;
            cursor: pointer;
            text-transform: uppercase;
            font-size: 14px;
        }

        #invoice-container {
            width: 210mm;
            min-height: 297mm;
            background: white;
            position: relative;
            overflow: hidden;
            display: flex;
            flex-direction: column;
            box-shadow: 0 0 50px rgba(0,0,0,0.1);
        }

        /* Top Shapes */
        .top-shape-grey {
            position: absolute;
            top: 0;
            right: 0;
            width: 45%;
            height: 150px;
            background: var(--dark-grey);
            clip-path: polygon(25% 0, 100% 0, 100% 100%);
            z-index: 0;
        }

        .top-shape-grey-left {
            position: absolute;
            top: 0;
            left: 0;
            width: 35%;
            height: 120px;
            background: #374151;
            clip-path: polygon(0 0, 100% 0, 0 100%);
            z-index: 0;
        }

        .header {
            position: relative;
            z-index: 10;
            padding: 40px 50px;
            display: flex;
            justify-content: space-between;
            align-items: flex-start;
        }

        .logo-box {
            width: 180px;
            background: white;
            padding: 10px;
            border-radius: 4px;
            box-shadow: 0 5px 15px rgba(0,0,0,0.05);
        }

        .logo-box img { width: 100%; height: auto; }

        .invoice-title-block {
            text-align: right;
        }

        .invoice-label {
            font-size: 48px;
            font-weight: 900;
            color: var(--primary-red);
            text-transform: uppercase;
            line-height: 1;
        }

        .invoice-number {
            font-size: 18px;
            font-weight: 800;
            color: var(--text-main);
            margin-top: 5px;
        }

        /* Address Section */
        .address-section {
            padding: 0 50px 30px 50px;
            display: flex;
            justify-content: space-between;
            position: relative;
            z-index: 10;
        }

        .address-box { width: 45%; }
        .address-box.seller { text-align: right; }

        .banner-label {
            background: var(--primary-red);
            color: white;
            padding: 5px 15px;
            font-size: 14px;
            font-weight: 900;
            display: inline-block;
            margin-bottom: 15px;
            text-transform: uppercase;
        }

        .name-bold {
            font-size: 24px;
            font-weight: 800;
            color: var(--text-main);
            margin-bottom: 5px;
        }

        .details-text {
            font-size: 14px;
            color: var(--text-muted);
            line-height: 1.5;
        }

        .status-container {
            padding: 0 50px 20px 50px;
            display: flex;
            gap: 40px;
        }

        .status-item { display: flex; flex-direction: column; }
        .status-item label { 
            font-size: 11px; 
            font-weight: 700; 
            color: #9ca3af; 
            text-transform: uppercase;
            margin-bottom: 4px;
        }
        .status-value { font-size: 16px; font-weight: 800; color: var(--text-main); }
        .status-badge {
            background: #10b981;
            color: white;
            padding: 2px 10px;
            border-radius: 4px;
            font-size: 12px;
            font-weight: 700;
        }

        /* Items Table */
        .items-container {
            padding: 0 30px;
            flex: 1;
        }

        table {
            width: 100%;
            border-collapse: collapse;
        }

        thead tr {
            background: var(--primary-red);
        }

        th {
            color: white;
            text-transform: uppercase;
            font-weight: 800;
            font-size: 13px;
            padding: 12px 15px;
            text-align: left;
        }

        td {
            padding: 15px;
            border-bottom: 1px solid #f1f5f9;
            font-size: 14px;
            color: var(--text-main);
        }

        .col-price { text-align: right; width: 120px; }
        .col-qty { text-align: center; width: 150px; }
        .col-total { text-align: right; width: 150px; font-weight: 800; }

        /* Summary & Footer */
        .bottom-area {
            padding: 40px 50px 100px 50px;
            display: flex;
            justify-content: space-between;
            align-items: flex-end;
        }

        .left-bottom { width: 50%; }
        .right-bottom { width: 40%; }

        .terms-title {
            font-size: 18px;
            font-weight: 800;
            color: var(--primary-red);
            margin-bottom: 10px;
        }

        .terms-text {
            font-size: 12px;
            color: var(--text-muted);
            line-height: 1.5;
            margin-bottom: 40px;
        }

        .signature-block {
            margin-top: 20px;
        }

        .sig-line {
            border-top: 2px solid var(--text-main);
            width: 250px;
            margin-bottom: 10px;
        }

        .sig-label {
            font-size: 14px;
            font-weight: 800;
            text-transform: uppercase;
        }

        .summary-row {
            display: flex;
            justify-content: flex-end;
            align-items: center;
            margin-bottom: 8px;
        }

        .summary-label {
            font-size: 16px;
            font-weight: 700;
            color: var(--text-muted);
            margin-right: 40px;
        }

        .summary-val {
            font-size: 18px;
            font-weight: 800;
            color: var(--text-main);
            width: 120px;
            text-align: right;
        }

        .grand-total-bar {
            background: var(--primary-red);
            color: white;
            padding: 15px 25px;
            margin-top: 20px;
            display: flex;
            justify-content: space-between;
            align-items: center;
            border-radius: 4px;
        }

        .gt-label { font-size: 22px; font-weight: 900; text-transform: uppercase; }
        .gt-val { font-size: 24px; font-weight: 900; }

        /* Footer Pattern */
        .footer-pattern {
            position: absolute;
            bottom: 0;
            left: 0;
            width: 100%;
            height: 60px;
            z-index: 5;
        }

        .shape-black-bottom {
            position: absolute;
            bottom: 0;
            right: 0;
            width: 100%;
            height: 40px;
            background: var(--dark-grey);
            clip-path: polygon(5% 0, 100% 0, 100% 100%, 0% 100%);
        }

        .shape-red-bottom-1 {
            position: absolute;
            bottom: 0;
            left: 0;
            width: 200px;
            height: 60px;
            background: var(--primary-red);
            clip-path: polygon(0 20%, 80% 100%, 0 100%);
        }

        .shape-red-bottom-2 {
            position: absolute;
            bottom: 0;
            left: 100px;
            width: 250px;
            height: 30px;
            background: var(--primary-red);
            clip-path: polygon(10% 0, 100% 100%, 0 100%);
        }

        .footer-text {
            position: absolute;
            bottom: 12px;
            right: 30px;
            color: white;
            font-size: 10px;
            font-weight: 800;
            text-transform: uppercase;
            letter-spacing: 2px;
            z-index: 10;
        }

        @@media print {
            body { background: white; }
            .no-print { display: none; }
            #invoice-container { 
                box-shadow: none; 
                transform: none; 
                margin: 0;
                width: 210mm;
                height: 297mm;
            }
            @@page { 
                size: A4; 
                margin: 0 !important; 
            }
            * { -webkit-print-color-adjust: exact !important; print-color-adjust: exact !important; }
        }
    </style>
</head>
<body>
    <div class="no-print">
        <button onclick="window.print()" class="btn-print">Print Invoice</button>
        <button onclick="window.close()" class="btn-close">Close</button>
    </div>

    <div id="invoice-container">
        <!-- Decoration Shapes -->
        <div class="top-shape-grey-left"></div>
        <div class="top-shape-grey"></div>

        <div class="header">
            <div class="logo-box">
                <img src="/images/sata-logo.png" alt="SATA Logo" onerror="this.src='https://via.placeholder.com/200x60?text=SATA+TECHNOLOGIES'"/>
            </div>
            <div class="invoice-title-block">
                <h1 class="invoice-label">Invoice</h1>
                <p class="invoice-number">#@(Model.Invoice.invoice_no ?? Model.Invoice.id.ToString())</p>
            </div>
        </div>

        <div class="address-section">
            <div class="address-box">
                <div class="banner-label">Invoice To:</div>
                <h2 class="name-bold">@Model.Invoice.customer_name</h2>
                <div class="details-text">
                    <p>@Model.Invoice.customer_address</p>
                    <p>Phone: @Model.Invoice.customer_contact</p>
                </div>
            </div>
            <div class="address-box seller">
                <div class="banner-label">Invoice From:</div>
                <h2 class="name-bold">@Model.Invoice.seller_name</h2>
                <div class="details-text">
                    <p>@Model.Invoice.seller_address</p>
                    <p>Phone: @Model.Invoice.seller_contact</p>
                    <p style="font-weight:800; color:var(--text-main); margin-top:10px;">Date: @Model.Invoice.date.ToString("dd MMM yyyy")</p>
                </div>
            </div>
        </div>

        <div class="status-container">
            <div class="status-item">
                <label>Status</label>
                <div class="status-value">
                    <span class="status-badge" style="background:@(Model.Invoice.status == "Paid" ? "#10b981" : "#BC1823")">@Model.Invoice.status</span>
                </div>
            </div>
            <div class="status-item">
                <label>Payment Method</label>
                <div class="status-value" style="text-transform:capitalize;">@Model.Invoice.payment</div>
            </div>
        </div>

        <div class="items-container">
            <table>
                <thead>
                    <tr>
                        <th style="padding-left:15px;">Products/Services</th>
                        <th class="col-price">Price</th>
                        <th class="col-qty">Qty/Unit Type</th>
                        <th class="col-total" style="padding-right:15px;">Total Price</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model.IsMultiItem)
                    {
                        foreach (var item in Model.Items)
                        {
                            <tr>
                                <td style="padding-left:15px;">
                                    <div style="font-weight:700;">@item["name"]</div>
                                    <div style="font-size:12px; color:var(--text-muted);">Expiry: @(item.ContainsKey("expiryDate") ? item["expiryDate"] : "N/A")</div>
                                </td>
                                <td class="col-price">$@(((decimal)item["price"]).ToString("N2"))</td>
                                <td class="col-qty">@item["qty"]</td>
                                <td class="col-total" style="padding-right:15px;">$@(((decimal)item["total"]).ToString("N2"))</td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td style="padding-left:15px;">
                                <div style="font-weight:700;">@Model.Invoice.prod_name_service</div>
                                <div style="font-size:12px; color:var(--text-muted);">Expiry: @Model.SingleItemExpiry</div>
                            </td>
                            <td class="col-price">$@Model.Invoice.price.ToString("N2")</td>
                            <td class="col-qty">@Model.Invoice.qty_unit_type</td>
                            <td class="col-total" style="padding-right:15px;">$@((Model.Invoice.price - Model.Invoice.discount).ToString("N2"))</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>

        <div class="bottom-area">
            <div class="left-bottom">
                <h3 class="terms-title">Terms & Conditions</h3>
                <div class="terms-text">
                    <p>Please make payment within 15 days of receiving this invoice.</p>
                    <p>Thank you for choosing SATA TECHNOLOGIES for your business.</p>
                </div>
                
                <div class="signature-block">
                    <div class="sig-line"></div>
                    <p class="sig-label">Authorized Signature</p>
                </div>
            </div>
            
            <div class="right-bottom">
                <div class="summary-row">
                    <span class="summary-label">Sub Total</span>
                    <span class="summary-val">$@Model.Subtotal.ToString("N2")</span>
                </div>
                <div class="summary-row" style="color:var(--primary-red);">
                    <span class="summary-label" style="color:var(--primary-red);">Discount</span>
                    <span class="summary-val">- $@Model.Invoice.discount.ToString("N2")</span>
                </div>
                
                <div class="grand-total-bar">
                    <span class="gt-label">Grand Total</span>
                    <span class="gt-val">$@Model.Invoice.total_price.ToString("N2")</span>
                </div>
            </div>
        </div>

        <!-- Footer Pattern -->
        <div class="footer-pattern">
            <div class="shape-red-bottom-2"></div>
            <div class="shape-red-bottom-1"></div>
            <div class="shape-black-bottom"></div>
            <p class="footer-text">SATA E-Invoice System Innovating the Future</p>
        </div>
    </div>
</body>
</html>
