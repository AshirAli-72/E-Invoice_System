@page "{id:int}"
@model E_Invoice_system.Pages.Invoice.PrintModel
@inject E_Invoice_system.Services.CurrencyService CurrencyService
@{
    Layout = null;
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Invoice - @(Model.Invoice.invoice_no ?? Model.Invoice.id.ToString())</title>
    <link rel="stylesheet" href="/lib/inter-font/inter.css" />
    <link rel="stylesheet" href="/css/Invoice/invoice.css">
    
</head>
<body>
    <div class="print-controls no-print">
        <button onclick="window.print()" class="btn btn-print">Print Invoice</button>
        <button onclick="window.close()" class="btn btn-close">Close Tab</button>
    </div>

    <div id="invoice-to-print" class="invoice-paper">
        <!-- Decoration Shapes -->
        <div class="top-left-pattern"></div>
        <div class="top-right-pattern"></div>

        <div class="invoice-header">
            <div class="logo-container">
                <img src="/images/sata-logo.png" alt="SATA Logo" />
            </div>
            <div class="invoice-meta">
                <h1 class="invoice-title">Invoice</h1>
                <p class="invoice-id">#@(Model.Invoice.invoice_no ?? Model.Invoice.id.ToString())</p>
            </div>
        </div>

        <div class="invoice-addresses">
            <div class="address-box">
                <div class="address-label">Invoice To:</div>
                <h2 class="address-name">@Model.Invoice.customer_name</h2>
                <div class="address-details">
                    <p>@Model.Invoice.customer_address</p>
                    <p>Phone: @Model.Invoice.customer_contact</p>
                </div>
            </div>
            <div class="address-box right">
                <div class="address-label">Invoice From:</div>
                <h2 class="address-name">@Model.Invoice.seller_name</h2>
                <div class="address-details">
                    <p>@Model.Invoice.seller_address</p>
                    <p>Phone: @Model.Invoice.seller_contact</p>
                    <p style="font-weight:900; color:#111; margin-top:8px; font-size:13px;">Date: @Model.Invoice.date</p>
                </div>
            </div>
        </div>

        <div class="status-bar">
            <div class="status-item">
                <label>Status</label>
                <span class="status-badge" style="background:@(Model.Invoice.status == "Paid" ? "#065f46" : "#9B111E")">@Model.Invoice.status</span>
            </div>
            <div class="status-item">
                <label>Payment Method</label>
                <div class="payment-text">@Model.Invoice.payment</div>
            </div>
        </div>

        <div class="invoice-table-container">
            <table class="invoice-table">
                <thead>
                    <tr>
                        <th style="width: 45%;">Products/Services</th>
                        <th class="col-center" style="width: 15%;">Price</th>
                        <th class="col-center" style="width: 20%;">Qty/Unit Type</th>
                        <th class="col-right" style="width: 20%;">Total Price</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model.IsMultiItem)
                    {
                        foreach (var item in Model.Items)
                        {
                            <tr>
                                <td>
                                    <div class="col-bold">@item["name"]</div>
                                    @if (item.ContainsKey("expiryDate") && (string)item["expiryDate"] != "N/A")
                                    {
                                        <div style="font-size:11px; color:#ef4444; margin-top:3px;">Expiry: @item["expiryDate"]</div>
                                    }
                                </td>
                                <td class="col-center">@CurrencyService.GetSymbol()@(((decimal)item["price"]).ToString("N2"))</td>
                                <td class="col-center">@item["qty"]</td>
                                <td class="col-right col-bold">@CurrencyService.GetSymbol()@(((decimal)item["total"]).ToString("N2"))</td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td>
                                <div class="col-bold">@Model.Invoice.prod_name_service</div>
                                @if (Model.SingleItemExpiry != "N/A")
                                {
                                    <div style="font-size:11px; color:#ef4444; margin-top:3px;">Expiry: @Model.SingleItemExpiry</div>
                                }
                            </td>
                            <td class="col-center">@CurrencyService.GetSymbol()@Model.Invoice.price.ToString("N2")</td>
                            <td class="col-center">@Model.Invoice.qty_unit_type</td>
                            <td class="col-right col-bold">@CurrencyService.GetSymbol()@((Model.Invoice.price - Model.Invoice.discount).ToString("N2"))</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>

        <div class="invoice-footer">
            <div class="terms-section">
                <h3>Terms & Conditions</h3>
                <p>Please make payment within 15 days of receiving this invoice. Thank you for choosing SATA TECHNOLOGIES for your business needs.</p>
                
                <div class="signature-section">
                    <div class="sig-line"></div>
                    <p class="sig-label">Authorized Signature</p>
                </div>
            </div>
            
            <div class="totals-section">
                <div class="total-row">
                    <span class="total-label">Sub Total</span>
                    <span class="total-val">@CurrencyService.GetSymbol()@Model.Subtotal.ToString("N2")</span>
                </div>
                <div class="total-row" style="color:var(--invoice-red);">
                    <span class="total-label" style="color:var(--invoice-red);">Discount</span>
                    <span class="total-val">- @CurrencyService.GetSymbol()@Model.Invoice.discount.ToString("N2")</span>
                </div>
                
                <div class="grand-total-bar">
                    <span class="grand-label">Grand Total</span>
                    <span class="grand-val">@CurrencyService.GetSymbol()@Model.Invoice.total_price.ToString("N2")</span>
                </div>
            </div>
        </div>

        <!-- Footer Decoration -->
        <div class="bottom-left-pattern"></div>
        <div class="bottom-right-pattern"></div>
        <p class="footer-branding">SATA E-Invoice System Innovating the Future</p>
    </div>
</body>
</html>
