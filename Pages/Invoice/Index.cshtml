@page
@model E_Invoice_system.Pages.Invoice.IndexModel
@using System.Text.Json
@{
    ViewData["Title"] = "Invoices";
}

<div class="card card-no-padding">
    <div class="card-header card-header-flex" style="padding: 1.5rem 1.5rem 0 1.5rem;">
        <div class="card-title">All Invoices</div>
        <a asp-page="./Create" class="btn-primary">
            <i class="ph-file-plus"></i> Create New Invoice
        </a>
    </div>
    
    <div class="table-responsive">
        <table class="styled-table" style="min-width: 1100px;">
            <thead>
                <tr>
                    <th style="padding-left: 1.5rem; white-space: nowrap;">Invoice #</th>
                    <th style="white-space: nowrap;">Customer Name</th>
                    <th style="white-space: nowrap;">Date</th>
                    <th>Product/Service</th>
                    <th style="white-space: nowrap;">QTY/Unit Type</th>
                    <th style="white-space: nowrap;">Expiry</th>
                    <th>Discount</th>
                    <th>Total</th>
                    <th style="white-space: nowrap;">Method</th>
                    <th>Status</th>
                    <th class="text-right" style="padding-right: 1.5rem;">Actions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model.Invoices)
                {
                    <tr>
                        <td class="font-bold" style="padding-left: 1.5rem; white-space: nowrap;">#@(item.invoice_no ?? item.id.ToString())</td>
                        <td class="font-medium" style="white-space: nowrap;">@item.customer_name</td>
                        <td style="white-space: nowrap;">@item.date.ToString("MMM dd, yyyy")</td>
                        <td class="font-sm">
                            @{
                                var displayName = item.prod_name_service;
                                var displayQty = item.qty_unit_type;
                                var displayExpiry = "N/A";
                                
                                try {
                                    if (!string.IsNullOrEmpty(displayName) && displayName.Trim().StartsWith("["))
                                    {
                                        var items = JsonSerializer.Deserialize<List<Dictionary<string, object>>>(displayName);
                                        if (items != null && items.Any())
                                        {
                                            var names = items.Select(i => i.ContainsKey("name") ? i["name"].ToString() : "").Where(n => !string.IsNullOrEmpty(n));
                                            displayName = string.Join(", ", names);
                                            
                                            var qtys = items.Select(i => i.ContainsKey("qty") ? i["qty"].ToString() : "").Where(q => !string.IsNullOrEmpty(q));
                                            displayQty = string.Join(", ", qtys);

                                            var dates = items.Select(i => i.ContainsKey("expiryDate") ? i["expiryDate"].ToString() : null)
                                                             .Where(d => !string.IsNullOrEmpty(d))
                                                             .Select(d => DateTime.TryParse(d, out var dt) ? dt.ToString("MMM dd, yyyy") : d);
                                            displayExpiry = string.Join(", ", dates);

                                            // Truncate if too long
                                            if (displayName.Length > 40) displayName = displayName.Substring(0, 37) + "...";
                                            if (displayQty.Length > 20) displayQty = displayQty.Substring(0, 17) + "...";
                                            if (displayExpiry.Length > 25) displayExpiry = displayExpiry.Substring(0, 22) + "...";
                                        }
                                    }
                                } catch {}
                            }
                            @displayName
                        </td>
                        <td class="font-sm">@displayQty</td>
                        <td class="font-sm text-muted">@displayExpiry</td>
                        <td class="text-danger font-medium">$@(item.discount.ToString("N2"))</td>
                        <td class="font-bold text-primary">$@(item.total_price.ToString("N2"))</td>
                        <td class="font-sm" style="white-space: nowrap;">@item.payment</td>
                        <td>
                            <span class="status-badge @(item.status == "Paid" ? "status-paid" : (item.status == "Pending" ? "status-pending" : "status-inactive"))">
                                @(item.status ?? "Draft")
                            </span>
                        </td>
                        <td class="text-right" style="padding-right: 1.5rem;">
                            <div class="actions-container actions-right">
                                <button type="button" onclick="viewInvoice(@item.id)" class="btn-icon-sm btn-view" title="View Invoice">
                                    <i class="ph-eye"></i>
                                </button>
                                <form method="post" asp-page-handler="Delete" asp-route-id="@item.id" style="display:inline;" onsubmit="return confirm('Are you sure you want to delete this invoice?')">
                                    <button type="submit" class="btn-icon-sm btn-delete">
                                        <i class="ph-trash"></i>
                                    </button>
                                </form>
                            </div>
                        </td>
                    </tr>
                }
                @if (!Model.Invoices.Any())
                {
                    <tr>
                        <td colspan="11" class="empty-state">
                            <i class="ph-file-text empty-state-icon"></i>
                            <p>No invoices found. Click "Create New Invoice" to start.</p>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>

<!-- Invoice View Modal -->
<div id="invoiceModal" class="modal-overlay-v2">
    <div class="modal-container-v2 shadow-luxury">
        <div class="modal-header-v2">
            <h3 class="modal-title-v2">Invoice Details</h3>
            <button type="button" class="btn-close-v2" onclick="closeInvoiceModal()"><i class="ph-x"></i></button>
        </div>
        <div id="invoiceModalContent" class="modal-body-v2">
            <div class="loading-state">
                <i class="ph-spinner ph-spin"></i>
                <span>Loading invoice...</span>
            </div>
        </div>
        <div class="modal-footer-v2">
            <button type="button" class="btn-secondary" onclick="closeInvoiceModal()">Close</button>
            <button id="modalPrintBtn" type="button" class="btn-primary" style="background:#BC1823; border:none;">
                <i class="ph-printer"></i> Print
            </button>
        </div>
    </div>
</div>

<style>
    .modal-overlay-v2 {
        position: fixed;
        top: 0;
        left: 0;
        width: 100%;
        height: 100%;
        background: rgba(0,0,0,0.5);
        display: none;
        align-items: center;
        justify-content: center;
        z-index: 1000;
        backdrop-filter: blur(4px);
    }
    .modal-overlay-v2.show { display: flex; }
    
    .modal-container-v2 {
        background: white;
        width: 95%;
        max-width: 900px;
        max-height: 90vh;
        border-radius: 12px;
        display: flex;
        flex-direction: column;
        overflow: hidden;
    }
    
    .modal-header-v2 {
        padding: 15px 25px;
        border-bottom: 1px solid #f1f5f9;
        display: flex;
        justify-content: space-between;
        align-items: center;
    }
    
    .modal-title-v2 { font-weight: 800; color: #1e293b; margin: 0; }
    .btn-close-v2 { background: none; border: none; font-size: 1.5rem; cursor: pointer; color: #94a3b8; }
    
    .modal-body-v2 {
        padding: 25px;
        overflow-y: auto;
        flex: 1;
        background: #f8fafc;
    }
    
    .modal-footer-v2 {
        padding: 15px 25px;
        border-top: 1px solid #f1f5f9;
        display: flex;
        justify-content: flex-end;
        gap: 12px;
    }
    
    .loading-state {
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 15px;
        padding: 50px;
        color: #64748b;
    }
    .loading-state i { font-size: 2.5rem; }
</style>

@section Scripts {
    <script>
        function viewInvoice(id) {
            const modal = document.getElementById('invoiceModal');
            const content = document.getElementById('invoiceModalContent');
            const printBtn = document.getElementById('modalPrintBtn');
            
            // Show modal and loading
            modal.classList.add('show');
            content.innerHTML = `
                <div class="loading-state">
                    <i class="ph-spinner ph-spin"></i>
                    <span>Loading invoice details...</span>
                </div>
            `;

            // Set print button action
            printBtn.onclick = () => {
                window.open(`/Invoice/Print?id=${id}`, '_blank');
            };

            // Fetch invoice details
            fetch(`/Invoice/Details/${id}`, {
                headers: {
                    'X-Requested-With': 'XMLHttpRequest'
                }
            })
            .then(response => response.text())
            .then(html => {
                content.innerHTML = html;
            })
            .catch(error => {
                content.innerHTML = `
                    <div class="error-state" style="text-align:center; padding:40px; color:#ef4444;">
                        <i class="ph-warning" style="font-size:2rem;"></i>
                        <p>Error loading invoice details. Please try again.</p>
                    </div>
                `;
                console.error('Error:', error);
            });
        }

        function closeInvoiceModal() {
            document.getElementById('invoiceModal').classList.remove('show');
        }

        // Close on escape key
        document.addEventListener('keydown', (e) => {
            if (e.key === 'Escape') closeInvoiceModal();
        });

        // Close on click outside
        document.getElementById('invoiceModal').addEventListener('click', (e) => {
            if (e.target.id === 'invoiceModal') closeInvoiceModal();
        });
    </script>
}
