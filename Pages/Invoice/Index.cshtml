@page
@model E_Invoice_system.Pages.Invoice.IndexModel
@using System.Text.Json
@{
    ViewData["Title"] = "Invoices";
}

<div class="card card-no-padding">
    <div class="card-header card-header-flex" style="padding: 1.5rem 1.5rem 0 1.5rem;">
        <div class="card-title">All Invoices</div>
        <a asp-page="./Create" class="btn-primary">
            <i class="ph-file-plus"></i> Create New Invoice
        </a>
    </div>
    
    <div class="table-responsive">
        <table class="styled-table" style="min-width: 1100px;">
            <thead>
                <tr>
                    <th style="padding-left: 1.5rem; white-space: nowrap;">Invoice #</th>
                    <th style="white-space: nowrap;">Customer Name</th>
                    <th style="white-space: nowrap;">Date</th>
                    <th>Product/Service</th>
                    <th style="white-space: nowrap;">QTY/Unit Type</th>
                    <th style="white-space: nowrap;">Expiry</th>
                    <th>Discount</th>
                    <th>Total</th>
                    <th style="white-space: nowrap;">Method</th>
                    <th>Status</th>
                    <th class="text-right" style="padding-right: 1.5rem;">Actions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model.Invoices)
                {
                    <tr>
                        <td class="font-bold" style="padding-left: 1.5rem; white-space: nowrap;">#@(item.InvoiceNo ?? item.id.ToString())</td>
                        <td class="font-medium" style="white-space: nowrap;">@item.CustomerName</td>
                        <td style="white-space: nowrap;">@item.Date.ToString("MMM dd, yyyy")</td>
                        <td class="font-sm">@item.DisplayName</td>
                        <td class="font-sm">@item.DisplayQty</td>
                        <td class="font-sm text-muted">@item.DisplayExpiry</td>
                        <td class="text-danger font-medium">$@(item.Discount.ToString("N2"))</td>
                        <td class="font-bold text-primary">$@(item.TotalPrice.ToString("N2"))</td>
                        <td class="font-sm" style="white-space: nowrap;">@item.Payment</td>
                        <td>
                            <span class="status-badge @(item.Status == "Paid" ? "status-paid" : (item.Status == "Pending" ? "status-pending" : "status-inactive"))">
                                @(item.Status ?? "Draft")
                            </span>
                        </td>
                        <td class="text-right" style="padding-right: 1.5rem;">
                            <div class="actions-container actions-right">
                                <a href="/Invoice/Details/@item.id" class="btn-icon-sm btn-view" title="View Invoice">
                                    <i class="ph-eye"></i>
                                </a>
                                <form method="post" asp-page-handler="Delete" asp-route-id="@item.id" style="display:inline;" onsubmit="return confirm('Are you sure you want to delete this invoice?')">
                                    <button type="submit" class="btn-icon-sm btn-delete">
                                        <i class="ph-trash"></i>
                                    </button>
                                </form>
                            </div>
                        </td>
                    </tr>
                }
                @if (!Model.Invoices.Any())
                {
                    <tr>
                        <td colspan="11" class="empty-state">
                            <i class="ph-file-text empty-state-icon"></i>
                            <p>No invoices found. Click "Create New Invoice" to start.</p>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>

    <!-- Pagination -->
    @if (Model.TotalPages > 1)
    {
        <div class="pagination-footer">
            <div class="pagination-info">
                Showing <span>@((Model.PageNumber - 1) * Model.PageSize + 1)</span> to <span>@(Math.Min(Model.PageNumber * Model.PageSize, Model.TotalCount))</span> of <span>@Model.TotalCount</span>
            </div>
            <div class="pagination-controls">
                @if (Model.PageNumber > 1)
                {
                    <a asp-page="./Index" asp-route-PageNumber="@(Model.PageNumber - 1)" class="page-link-btn">
                        <i class="ph-caret-left"></i> Previous
                    </a>
                }
                else
                {
                    <button class="page-link-btn disabled" disabled><i class="ph-caret-left"></i> Previous</button>
                }

                <div class="page-number-indicator">
                    Page @Model.PageNumber of @Model.TotalPages
                </div>

                @if (Model.PageNumber < Model.TotalPages)
                {
                    <a asp-page="./Index" asp-route-PageNumber="@(Model.PageNumber + 1)" class="page-link-btn">
                        Next <i class="ph-caret-right"></i>
                    </a>
                }
                else
                {
                    <button class="page-link-btn disabled" disabled>Next <i class="ph-caret-right"></i></button>
                }
            </div>
        </div>
    }
</div>

<style>
    /* Pagination Styles */
    .pagination-footer {
        padding: 1.25rem 1.5rem;
        background: #f8fafc;
        border-top: 1px solid rgba(0,0,0,0.05);
        display: flex;
        justify-content: space-between;
        align-items: center;
        flex-wrap: wrap;
        gap: 1.5rem;
    }

    .pagination-info {
        font-size: 0.85rem;
        color: #64748b;
    }

    .pagination-info span {
        font-weight: 700;
        color: #1e293b;
    }

    .pagination-controls {
        display: flex;
        align-items: center;
        gap: 1rem;
    }

    .page-link-btn {
        display: flex;
        align-items: center;
        gap: 8px;
        padding: 8px 16px;
        background: white;
        border: 1px solid #e2e8f0;
        border-radius: 10px;
        color: #1e293b;
        text-decoration: none;
        font-size: 0.85rem;
        font-weight: 600;
        transition: all 0.2s;
    }

    .page-link-btn:hover:not(.disabled) {
        border-color: var(--primary);
        color: var(--primary);
        background: #f0f9ff;
    }

    .page-link-btn.disabled {
        opacity: 0.5;
        cursor: not-allowed;
    }

    .page-number-indicator {
        font-size: 0.85rem;
        font-weight: 600;
        color: #64748b;
    }

    @@media (max-width: 768px) {
        .pagination-footer {
            flex-direction: column;
            align-items: center;
            text-align: center;
        }
    }
</style>
