@page
@model E_Invoice_system.Pages.Invoice.IndexModel
@{
    ViewData["Title"] = "Invoices";
}

@section Styles {
    <link rel="stylesheet" href="~/css/invoice/index.css" asp-append-version="true" />
}

<div class="management-container">
    <div class="card card-no-padding">
        <div class="page-header">
            <div class="page-header-left">
                <i class="ph-file-text page-header-icon"></i>
                <div style="display:flex;flex-direction:column;gap:0.25rem;">
                    <h2 class="page-header-title">Invoice Management</h2>
                    <p class="text-muted font-sm" style="margin:0;">View and manage your generated customer invoices.</p>
                </div>
            </div>
            <button onclick="document.getElementById('createInvModal').style.display='flex'" class="btn-primary">
                <i class="ph-file-plus"></i> Create New Invoice
            </button>
        </div>

        <div class="table-container">
            <div class="table-responsive">
                <table class="styled-table" style="min-width:1000px;margin-bottom:0;">
                    <thead>
                        <tr>
                            <th style="padding-left:1.5rem;">Invoice #</th>
                            <th>Customer</th>
                            <th>Date</th>
                            <th>Items</th>
                            <th>Discount</th>
                            <th>Total</th>
                            <th>Method</th>
                            <th>Status</th>
                            <th class="text-right" style="padding-right:1.5rem;">Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model.Invoices)
                        {
                            <tr>
                                <td class="font-bold" style="padding-left:1.5rem;color:#BC1823;">@(item.InvoiceNo ?? $"#{item.id}")</td>
                                <td class="font-medium">@item.CustomerName</td>
                                <td style="color:#64748b;">@item.Date</td>
                                <td class="font-sm">@item.DisplayName</td>
                                <td class="text-danger font-medium">@CurrencyService.GetSymbol()@(item.Discount.ToString("N2"))</td>
                                <td class="font-bold text-primary">@CurrencyService.GetSymbol()@(item.TotalPrice.ToString("N2"))</td>
                                <td class="font-sm">@item.Payment</td>
                                <td>
                                    <span class="status-badge @(item.Status=="Paid"?"status-active":(item.Status=="Pending"?"status-out-of-stock":"status-inactive"))">
                                        @(item.Status ?? "Draft")
                                    </span>
                                </td>
                                <td class="text-right" style="padding-right:1.5rem;">
                                    <div class="actions-container actions-right">
                                        <a href="/Invoice/Details/@item.id" class="btn-icon-sm"
                                           style="background:#eff6ff;color:#3b82f6;border:1px solid #bfdbfe;display:inline-flex;align-items:center;justify-content:center;text-decoration:none;"
                                           title="View Invoice">
                                            <i class="ph-eye"></i>
                                        </a>
                                        <form method="post" asp-page-handler="Delete" asp-route-id="@item.id"
                                              style="display:inline;" onsubmit="return confirm('Delete this invoice?')">
                                            <button type="submit" class="btn-icon-sm btn-delete">
                                                <i class="ph-trash"></i>
                                            </button>
                                        </form>
                                    </div>
                                </td>
                            </tr>
                        }
                        @if (!Model.Invoices.Any())
                        {
                            <tr>
                                <td colspan="9" class="empty-state">
                                    <i class="ph-file-text empty-state-icon"></i>
                                    <p>No invoices found. Click <strong>Create New Invoice</strong> to start.</p>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>

            @if (Model.Invoices.Any())
            {
                <div class="pagination-container">
                    <div class="pagination-info">
                        Showing <b>@((Model.PageNumber - 1) * Model.PageSize + 1)</b>
                        to <b>@(Math.Min(Model.PageNumber * Model.PageSize, Model.TotalCount))</b>
                        of <b>@Model.TotalCount</b>
                    </div>
                    <div class="pagination-controls">
                        @if (Model.PageNumber > 1)
                        { <a asp-page="./Index" asp-route-PageNumber="@(Model.PageNumber-1)" class="btn-pagination"><i class="ph-caret-left"></i></a> }
                        else { <button class="btn-pagination" disabled><i class="ph-caret-left"></i></button> }

                        @for (int i = 1; i <= Model.TotalPages; i++)
                        {
                            var pn = i;
                            if (i == 1 || i == Model.TotalPages || (i >= Model.PageNumber - 2 && i <= Model.PageNumber + 2))
                            { <a asp-page="./Index" asp-route-PageNumber="@pn" class="btn-pagination @(i==Model.PageNumber?"active":"")">@i</a> }
                            else if (i == Model.PageNumber - 3 || i == Model.PageNumber + 3)
                            { <span class="pagination-ellipsis">...</span> }
                        }

                        @if (Model.PageNumber < Model.TotalPages)
                        { <a asp-page="./Index" asp-route-PageNumber="@(Model.PageNumber+1)" class="btn-pagination"><i class="ph-caret-right"></i></a> }
                        else { <button class="btn-pagination" disabled><i class="ph-caret-right"></i></button> }
                    </div>
                </div>
            }
        </div>
    </div>
</div>

<!-- ════════════ INVOICE DETAIL MODAL ════════════ -->
<div id="invModal" style="display:none; position:fixed; inset:0; background:rgba(15,23,42,0.65); z-index:9999; align-items:center; justify-content:center; backdrop-filter:blur(6px);">
    <div id="invModalBox" style="background:white; border-radius:16px; width:750px; max-width:96vw; max-height:94vh; overflow:hidden; box-shadow:0 40px 100px rgba(0,0,0,0.35); display:flex; flex-direction:column;">

        <!-- Modal Toolbar -->
        <div style="background:#1e293b; padding:0.9rem 1.5rem; display:flex; justify-content:space-between; align-items:center; flex-shrink:0;">
            <div style="display:flex; align-items:center; gap:0.75rem;">
                <i class="ph-file-text" style="color:#94a3b8; font-size:1.2rem;"></i>
                <span style="color:white; font-weight:600; font-size:0.95rem;">Invoice Detail</span>
            </div>
            <div style="display:flex; gap:0.5rem; align-items:center;">
                <button onclick="window.print()" style="background:rgba(255,255,255,0.1); border:none; color:white; padding:0.4rem 0.9rem; border-radius:6px; cursor:pointer; font-size:0.82rem; display:flex; align-items:center; gap:0.4rem;">
                    <i class="ph-printer"></i> Print
                </button>
                <button id="invModalClose" style="background:rgba(255,255,255,0.1); border:none; color:white; width:32px; height:32px; border-radius:6px; cursor:pointer; font-size:1.1rem; display:flex; align-items:center; justify-content:center;">
                    <i class="ph-x"></i>
                </button>
            </div>
        </div>

        <!-- Invoice Paper -->
        <div id="invPrint" style="overflow-y:auto; flex:1; background:#cbd5e1; padding:2rem; display:flex; justify-content:center;">
            
            <div class="invoice" style="text-align: left;">
              <!-- BACKGROUND DESIGN -->
              <div class="bg-circle-1"></div>
              <div class="bg-circle-2"></div>

              <!-- HEADER -->
              <div class="header">
                <div class="header-content">
                  <div class="logo">
                    <div class="logo-icon">
                      <span></span>
                      <span></span>
                      <span></span>
                    </div>
                    <div class="brand">
                      <h1>SATA</h1>
                      <p>TECHNOLOGIES</p>
                    </div>
                  </div>
                  <div class="invoice-info">
                    <h2>INVOICE</h2>
                    <div class="mini-box">
                      <div class="mini-row">
                        <span>Invoice No:</span>
                        <span id="m-invno"></span>
                      </div>
                      <div class="mini-row">
                        <span>Date:</span>
                        <span id="m-date"></span>
                      </div>
                    </div>
                  </div>
                </div>
              </div>

              <!-- CLIENT SECTION -->
              <div class="clients">
                <div class="client-card">
                  <span class="tag"><i class="ph-buildings"></i> Company</span>
                  <div class="info">
                    <label>Seller:</label>
                    <h3 id="m-seller">SATA Technologies</h3>
                  </div>
                  <div class="info">
                    <label>Payment Method:</label>
                    <h3 id="m-payment">Credit Card</h3>
                  </div>
                </div>
                <div class="client-card">
                  <span class="tag"><i class="ph-user"></i> Client</span>
                  <div class="info">
                    <label>Billed To:</label>
                    <h3 id="m-customer">John Doe</h3>
                  </div>
                  <div class="info">
                    <label>Status:</label>
                    <h3><span id="m-status-badge">Paid</span></h3>
                  </div>
                </div>
              </div>

              <!-- TABLE -->
              <div class="table-wrapper">
                <div class="table-card">
                  <table>
                    <thead>
                      <tr>
                        <th style="width: 80px;">No</th>
                        <th>Item / Description</th>
                        <th style="text-align: right; width: 180px;">Unit Price</th>
                        <th style="text-align: center; width: 120px;">Qty</th>
                        <th style="text-align: right; width: 180px;">Total Price</th>
                      </tr>
                    </thead>
                    <tbody id="m-items"></tbody>
                  </table>
                </div>
              </div>

              <!-- BOTTOM -->
              <div class="bottom">
                <div class="message">
                  <h3>Thank You!</h3>
                  <p>We appreciate your business. If you have any questions about this invoice, please feel free to reach out to us. Keep this document for your warranty records.</p>
                </div>
                <div class="summary">
                  <div class="sum-row">
                    <span>Subtotal</span>
                    <span id="m-subtotal"></span>
                  </div>
                  <div class="sum-row">
                    <span>Discount</span>
                    <span id="m-discount"></span>
                  </div>
                  <div class="grand sum-row">
                    <span>Grand Total</span>
                    <span id="m-total"></span>
                  </div>
                </div>
              </div>

              <!-- FOOTER -->
              <div class="footer">
                <div class="footer-left">
                  <p>&copy; 2026 SATA Technologies. All rights reserved.</p>
                </div>
                <div class="footer-right">
                  <div class="social"><i class="ph-facebook-logo"></i></div>
                  <div class="social"><i class="ph-twitter-logo"></i></div>
                  <div class="social"><i class="ph-instagram-logo"></i></div>
                </div>
              </div>

            </div>

        </div>
    </div>
</div>

<style>
    @@keyframes modalIn { from { opacity:0; transform:scale(0.96) translateY(-10px); } to { opacity:1; transform:scale(1) translateY(0); } }
    #invModalBox { animation: modalIn 0.22s ease; }

    @@media print {
        body * { visibility: hidden !important; }
        #invPrint, #invPrint * { visibility: visible !important; }
        #invPrint { position: absolute !important; left: 0; top: 0; width: 100%; height: auto; margin: 0; padding: 0 !important; overflow: visible !important; }
        .invoice { transform: none !important; box-shadow: none !important; border-radius: 0 !important; width: 100% !important; margin: 0 !important; }
        #invModalBox { overflow: visible !important; }
    }
</style>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        document.addEventListener('click', function (e) {
            var btn = e.target.closest('.inv-view-btn');
            if (!btn) return;

            var d = btn.dataset;
            var cur = d.currency || '';

            // Header
            document.getElementById('m-invno').textContent    = d.invno    || '';
            document.getElementById('m-seller').textContent   = d.seller   || 'Company';
            document.getElementById('m-date').textContent     = d.date     || '';
            document.getElementById('m-payment').textContent  = d.payment  || '';
            document.getElementById('m-customer').textContent = d.customer || 'Walk-In Customer';
            document.getElementById('m-discount').textContent = '- ' + cur + parseFloat(d.discount || 0).toFixed(2);
            document.getElementById('m-total').textContent    = cur + parseFloat(d.total    || 0).toFixed(2);

            // Status badge
            var badge = document.getElementById('m-status-badge');
            badge.textContent = d.status || 'Draft';
            badge.style.background = d.status === 'Paid' ? 'rgba(34,197,94,0.2)' : d.status === 'Pending' ? 'rgba(234,179,8,0.2)' : 'rgba(148,163,184,0.2)';
            badge.style.color      = d.status === 'Paid' ? '#4ade80' : d.status === 'Pending' ? '#fbbf24' : '#94a3b8';

            // Items
            var tbody = document.getElementById('m-items');
            var subtotalEl = document.getElementById('m-subtotal');
            tbody.innerHTML = '';
            var subtotal = 0;
            try {
                var items = JSON.parse(d.items || '[]');
                if (Array.isArray(items) && items.length > 0) {
                    items.forEach(function (it, i) {
                        var name  = it.Name  || it.name  || '—';
                        var qty   = it.Qty   || it.qty   || 1;
                        var price = parseFloat(it.Price || it.price || 0);
                        var tot   = parseFloat(it.Total || it.total || 0);
                        subtotal += tot;
                        var tr = document.createElement('tr');
                        var odd = (i % 2 === 0);
                        tr.style.background = odd ? '#fafafa' : 'white';
                        tr.innerHTML =
                            '<td style="padding:24px; border-bottom:1px solid #edf0f5; font-size:15px; color:#6b7280; font-weight:600;">' + (i+1) + '</td>' +
                            '<td style="padding:24px; border-bottom:1px solid #edf0f5; font-size:15px; color:#111827; font-weight:600;">' + name + '</td>' +
                            '<td style="padding:24px; border-bottom:1px solid #edf0f5; font-size:15px; color:#374151; text-align:right;">' + cur + price.toFixed(2) + '</td>' +
                            '<td style="padding:24px; border-bottom:1px solid #edf0f5; font-size:15px; color:#374151; text-align:center; font-weight:600;">' + qty + '</td>' +
                            '<td style="padding:24px; border-bottom:1px solid #edf0f5; font-size:15px; color:#dc2626; text-align:right; font-weight:700;">' + cur + tot.toFixed(2) + '</td>';
                        tbody.appendChild(tr);
                    });
                    subtotalEl.textContent = cur + subtotal.toFixed(2);
                } else {
                    tbody.innerHTML = '<tr><td colspan="5" style="padding:1.5rem 0;text-align:center;color:#94a3b8;font-size:0.85rem;">No items found</td></tr>';
                    subtotalEl.textContent = cur + '0.00';
                }
            } catch(e) {
                tbody.innerHTML = '<tr><td colspan="5" style="padding:1.5rem 0;text-align:center;color:#94a3b8;">Could not load items</td></tr>';
                subtotalEl.textContent = cur + '0.00';
            }

            document.getElementById('invModal').style.display = 'flex';
        });

        document.getElementById('invModalClose').addEventListener('click', function () {
            document.getElementById('invModal').style.display = 'none';
        });
        document.getElementById('invModal').addEventListener('click', function (e) {
            if (e.target === this) this.style.display = 'none';
        });
    </script>
}

<!-- ════════════ CREATE INVOICE MODAL ════════════ -->
<div id="createInvModal" style="display:none; position:fixed; inset:0; background:rgba(15,23,42,0.65); z-index:9999; align-items:center; justify-content:center; backdrop-filter:blur(6px);">
    <div style="background:transparent; width:100%; max-width:800px; max-height:94vh; overflow-y:auto; position:relative; border-radius:16px;">
        <component type="typeof(E_Invoice_system.Components.Invoice.InvoiceEditor)"
                   render-mode="ServerPrerendered"
                   param-UserName='@HttpContext.Session.GetString("UserName")' />
    </div>
</div>
