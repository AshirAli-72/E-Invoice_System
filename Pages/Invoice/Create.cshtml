@page
@model E_Invoice_system.Pages.Invoice.CreateModel
@{
    ViewData["Title"] = "Generate New Invoice";
}

<div class="dashboard-panel">
    <div class="page-header">
        <h1 class="page-title-large">
            <i class="ph-file-plus form-icon-primary"></i>
            Generate New Invoice
        </h1>
        <a asp-page="/Invoice/Index" class="btn-secondary">
            <i class="ph-arrow-left"></i> Back to List
        </a>
    </div>

    <!-- Blazor Component for Invoice Editing -->
    <component type="typeof(E_Invoice_system.Components.Invoice.InvoiceEditor)" render-mode="ServerPrerendered" />
</div>

@section Scripts {
    <!-- No page-specific scripts needed, everything is in Blazor C# -->
}
