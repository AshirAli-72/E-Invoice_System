@page "{id:int}"
@model E_Invoice_system.Pages.Invoice.DetailsModel
@inject E_Invoice_system.Services.CurrencyService CurrencyService
@{
    ViewData["Title"] = "Invoice #" + (Model.Invoice.invoice_no ?? Model.Invoice.id.ToString());
    bool isAjax = Request.Headers["X-Requested-With"] == "XMLHttpRequest";
    if (isAjax) { Layout = null; }
    
    var billRef = Model.Invoice.invoice_no ?? Model.Invoice.id.ToString();
    var symbol = CurrencyService.GetSymbol() ?? "$";

    // Dynamic Logo Logic
    string logoUrl = "/images/sata-logo.png";
    if (Model.Store != null && !string.IsNullOrEmpty(Model.Store.LogoPath))
    {
        try { logoUrl = "/store-logo/" + System.IO.Path.GetFileName(Model.Store.LogoPath); } catch {}
    }
}

@section Styles {
    <link rel="stylesheet" href="~/lib/phosphor/icons.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/invoice/details.css" asp-append-version="true" />
}

<div class="invoice-details-page">

  <!-- Action Bar -->
  <div class="actions-bar no-print">
      <a href="/Invoice/Index" class="btn-action btn-back">
          <i class="ph-arrow-left"></i> Back to Invoices
      </a>
      <button onclick="window.print()" class="btn-action btn-print">
          <i class="ph-printer"></i> Print Invoice
      </button>
  </div>

  <!-- Main Invoice Card -->
  <div class="invoice">

    <!-- Header Section (Slate/Crimson Contrast) -->
    <div class="header">
      <div class="header-content">
        <div class="logo-block">
          <img src="@logoUrl" class="invoice-logo" alt="Logo"/>
          <div class="brand-info">
            <h1>@(Model.Store?.ShopName ?? "E-Invoice System")</h1>
            <span class="tagline">Digital Transaction Ledger</span>
          </div>
        </div>

        <div class="invoice-badge">
          <h2>INVOICE</h2>
          <span class="ref-no">#@billRef</span>
        </div>
      </div>
    </div>

    <!-- Metadata Grid Strip -->
    <div class="metadata-strip">
      <div class="meta-item">
        <div class="meta-icon"><i class="ph-file-text"></i></div>
        <div class="meta-details">
          <span class="meta-label">Invoice Ref</span>
          <span class="meta-val">#@billRef</span>
        </div>
      </div>
      <div class="meta-item">
        <div class="meta-icon"><i class="ph-calendar"></i></div>
        <div class="meta-details">
          <span class="meta-label">Issued Date</span>
          <span class="meta-val">@Model.Invoice.date</span>
        </div>
      </div>
      <div class="meta-item">
        <div class="meta-icon"><i class="ph-credit-card"></i></div>
        <div class="meta-details">
          <span class="meta-label">Payment Mode</span>
          <span class="meta-val">@Model.Invoice.payment</span>
        </div>
      </div>
      <div class="meta-item">
        <div class="meta-icon"><i class="ph-check-circle"></i></div>
        <div class="meta-details">
          <span class="meta-label">Status</span>
          <span class="meta-val">
            <span class="status-pill @(Model.Invoice.status?.ToLower() == "paid" ? "status-paid" : "status-pending")">
              <i class="@(Model.Invoice.status?.ToLower() == "paid" ? "ph-check-bold" : "ph-clock-bold")"></i>
              @(Model.Invoice.status ?? "Paid")
            </span>
          </span>
        </div>
      </div>
    </div>

    <!-- Client Cards Section -->
    <div class="clients-container">
      <!-- Billed From Card -->
      <div class="client-box box-seller">
        <div class="box-title"><i class="ph-buildings"></i> Billed From</div>
        <div class="client-row">
          <label>Company Name</label>
          <span>@(Model.Store?.ShopName ?? "SATA Technologies")</span>
        </div>
        <div class="client-row">
          <label>Seller Contact</label>
          <span>@(Model.Store?.Phone1 ?? "+92 300 1234567")</span>
        </div>
        <div class="client-row">
          <label>Seller Location</label>
          <span>@(Model.Store?.Address ?? "Islamabad, Pakistan")</span>
        </div>
      </div>

      <!-- Billed To Card -->
      <div class="client-box box-customer">
        <div class="box-title"><i class="ph-user"></i> Billed To</div>
        <div class="client-row">
          <label>Client Name</label>
          <span>@(string.IsNullOrEmpty(Model.Invoice.customer_name) ? "Walk-In Customer" : Model.Invoice.customer_name)</span>
        </div>
        <div class="client-row">
          <label>Phone Number</label>
          <span>@(Model.Invoice.customer_contact ?? "N/A")</span>
        </div>
        <div class="client-row">
          <label>Location</label>
          <span>@(Model.Invoice.customer_address ?? "N/A")</span>
        </div>
      </div>
    </div>

    <!-- Table of Items -->
    <div class="table-container">
      <div class="table-card">
        <table class="invoice-table">
          <thead>
            <tr>
              <th style="width: 50%;">Service / Product</th>
              <th style="text-align: center; width: 15%;">Qty</th>
              <th style="text-align: right; width: 15%;">Price</th>
              <th style="text-align: right; width: 20%;">Total</th>
            </tr>
          </thead>
          <tbody>
            @if (Model.IsMultiItem)
            {
                foreach (var item in Model.Items)
                {
                    <tr>
                        <td class="item-name">@item["name"]</td>
                        <td class="item-numeric" style="text-align: center;">@item["qty"]</td>
                        <td class="item-numeric" style="text-align: right;">@symbol@(((decimal)item["price"]).ToString("N2"))</td>
                        <td class="item-numeric" style="text-align: right;">@symbol@(((decimal)item["total"]).ToString("N2"))</td>
                    </tr>
                }
            }
            else
            {
                <tr>
                    <td class="item-name">@Model.Invoice.prod_name_service</td>
                    <td class="item-numeric" style="text-align: center;">@Model.Invoice.qty_unit_type</td>
                    <td class="item-numeric" style="text-align: right;">@symbol@Model.Invoice.price.ToString("N2")</td>
                    <td class="item-numeric" style="text-align: right;">@symbol@Model.Subtotal.ToString("N2")</td>
                </tr>
            }
          </tbody>
        </table>
      </div>
    </div>

    <!-- Bottom Summary Section -->
    <div class="bottom-section">
      <div class="terms-card">
        <h3><i class="ph-info"></i> Terms &amp; Conditions</h3>
        <p>
          Thank you for choosing @(Model.Store?.ShopName ?? "SATA Technologies"). Please complete outstanding balances within 7 working days. 
          For billing questions, please contact our helpline or support email.
        </p>
      </div>

      <div class="ledger-box">
        <div class="ledger-row">
          <span>Subtotal</span>
          <span>@symbol@Model.Subtotal.ToString("N2")</span>
        </div>
        <div class="ledger-row ledger-discount">
          <span>Discount</span>
          <span>-@symbol@Model.Invoice.discount.ToString("N2")</span>
        </div>
        <div class="ledger-row ledger-grand-total">
          <span>TOTAL</span>
          <span>@symbol@Model.Invoice.total_price.ToString("N2")</span>
        </div>
      </div>
    </div>

    <!-- Dark Corporate Footer -->
    <div class="footer">
      <div class="footer-left">
        &copy; @DateTime.Now.Year @(Model.Store?.ShopName ?? "SATA Technologies") &mdash; Digital Core Ledger
      </div>
      <div class="footer-right">
        <div class="social-circle"><i class="ph-envelope-simple"></i></div>
        <div class="social-circle"><i class="ph-phone"></i></div>
        <div class="social-circle"><i class="ph-globe-hemisphere-west"></i></div>
      </div>
    </div>

  </div>

</div>
