@page "{id:int}"
@model E_Invoice_system.Pages.Invoice.DetailsModel
@inject E_Invoice_system.Services.CurrencyService CurrencyService
@{
    ViewData["Title"] = "Invoice #" + (Model.Invoice.invoice_no ?? Model.Invoice.id.ToString());
    bool isAjax = Request.Headers["X-Requested-With"] == "XMLHttpRequest";
    if (isAjax) { Layout = null; }

    var billRef = Model.Invoice.invoice_no ?? Model.Invoice.id.ToString();
    var symbol = CurrencyService.GetSymbol() ?? "$";

    // ── Dynamic Logo ──
    string logoUrl = "/images/sata-logo.png";
    if (Model.Store != null && !string.IsNullOrEmpty(Model.Store.LogoPath))
    {
        try { logoUrl = "/store-logo/" + System.IO.Path.GetFileName(Model.Store.LogoPath); } catch { }
    }

    // ── Status ──
    var statusClass = (Model.Invoice.status ?? "").ToLower() switch
    {
        "paid" => "status-paid",
        "pending" => "status-pending",
        _ => "status-draft"
    };
}

@section Styles {
    <link rel="stylesheet" href="~/css/invoice/details.css" asp-append-version="true" />
}

<div class="invoice-details-page">

    <!-- Action Bar -->
    <div class="actions-bar no-print">
        <a href="/Invoice/Index" class="btn-action btn-back">
            &#8592; Back to Invoices
        </a>
        <button onclick="window.print()" class="btn-action btn-print">
            🖨 Print Invoice
        </button>
    </div>

    <!-- Invoice Shell -->
    <div class="invoice">

        <!-- ══ HEADER — unchanged white ══ -->
        <div class="header">
            <div class="header-content">
                <div class="logo-block">
                    <img src="@logoUrl" class="invoice-logo" alt="@(Model.Store?.ShopName ?? "Logo")" />
                </div>
                <div class="invoice-badge">
                    <h2>E-Invoice</h2>
                    <span class="ref-no" style="margin-right:60px;">#@billRef</span>
                </div>
            </div>
        </div>

        <!-- ══ ADDRESS STRIP ══ -->
        <div class="address-strip">

            <!-- Bill To (left) — red pill label same as Bill From -->
            <div class="address-col address-col-left">
                <span class="bill-to-label">Bill To</span>
                <div class="address-name">
                    @(string.IsNullOrEmpty(Model.Invoice.customer_name) ? "Walk-In Customer" : Model.Invoice.customer_name)
                </div>
                <div class="address-detail">
                    @if (!string.IsNullOrEmpty(Model.Invoice.customer_address))
                    {
                        <span>@Model.Invoice.customer_address</span><br />
                    }
                    @if (!string.IsNullOrEmpty(Model.Invoice.customer_contact))
                    {
                        <span>Phone: @Model.Invoice.customer_contact</span>
                    }
                </div>
            </div>

            <!-- Bill From (right) -->
            <div class="address-col address-col-right" style="text-align:right;">
                <div style="display:flex; justify-content:flex-end;">
                    <span class="invoice-from-label">Invoice From:</span>
                </div>
                <div class="address-name" style="margin-top:6px;">
                    @(Model.Store?.ShopName ?? "SATA Technologies")
                </div>
                <div class="address-detail">
                    @if (!string.IsNullOrEmpty(Model.Store?.Address))
                    {
                        <span>@Model.Store.Address</span><br />
                    }
                    @if (!string.IsNullOrEmpty(Model.Store?.Phone1))
                    {
                        <span>Phone: @Model.Store.Phone1</span><br />
                    }
                    <strong>Date: @Model.Invoice.date</strong>
                </div>
            </div>

        </div>

        <!-- ══ METADATA STRIP ══ -->
        <div class="metadata-strip">
            <div class="meta-group">
                <span class="meta-label">Status</span>
                <span class="meta-val">
                    <span class="status-pill @statusClass">
                        @(Model.Invoice.status ?? "Paid")
                    </span>
                </span>
            </div>
            <div class="meta-group">
                <span class="meta-label">Payment Method</span>
                <span class="meta-val">@Model.Invoice.payment</span>
            </div>
        </div>

        <!-- ══ ITEMS TABLE — full bleed, no side padding ══ -->
        <div class="table-container">
            <table class="invoice-table">
                <thead>
                    <tr>
                        <th class="col-product">Products/Services</th>
                        <th class="col-price">Price</th>
                        <th class="col-qty">Qty/Unit Type</th>
                        <th class="col-total">Total Price</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model.IsMultiItem)
                    {
                        foreach (var item in Model.Items)
                        {
                            <tr>
                                <td>
                                    <div class="item-name">@item["name"]</div>
                                    @if (item.ContainsKey("expiry") && item["expiry"] != null)
                                    {
                                        <span class="item-expiry">Expiry: @item["expiry"]</span>
                                    }
                                </td>
                                <td class="item-price">@symbol@(((decimal)item["price"]).ToString("N2"))</td>
                                <td class="item-qty">@item["qty"]</td>
                                <td class="item-total">@symbol@(((decimal)item["total"]).ToString("N2"))</td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td>
                                <div class="item-name">@Model.Invoice.prod_name_service</div>
                            </td>
                            <td class="item-price">@symbol@Model.Invoice.price.ToString("N2")</td>
                            <td class="item-qty">@Model.Invoice.qty_unit_type</td>
                            <td class="item-total">@symbol@Model.Subtotal.ToString("N2")</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>

        <!-- ══ BOTTOM SECTION ══ -->
        <div class="bottom-section">

            <!-- Terms & Signature -->
            <div class="terms-card">
                <h3>Terms &amp; Conditions</h3>
                <p>
                    Please make payment within 15 days of receiving this invoice.
                    Thank you for choosing @(Model.Store?.ShopName ?? "SATA Technologies") for your business needs.
                </p>
                <div class="signature-line">
                    <div class="signature-label">Authorized Signature</div>
                </div>
            </div>

            <!-- Totals Ledger -->
            <div class="ledger-box">
                <div class="ledger-row">
                    <span>Sub Total</span>
                    <span>@symbol@Model.Subtotal.ToString("N2")</span>
                </div>
                <div class="ledger-row ledger-discount">
                    <span>Discount</span>
                    <span>- @symbol@Model.Invoice.discount.ToString("N2")</span>
                </div>
                <div class="ledger-grand-total">
                    <span class="grand-label">Grand<br />Total</span>
                    <span class="grand-amount">@symbol@Model.Invoice.total_price.ToString("N2")</span>
                </div>
            </div>

        </div>

        <!-- ══ NEW FOOTER ══ -->
        <div class="footer">
            <div class="footer-inner">
                <div class="footer-brand">
                    <div class="footer-dot"></div>
                    <span class="footer-shop">@((Model.Store?.ShopName ?? "SATA Technologies").ToUpper())</span>
                </div>
                <span class="footer-center">E-Invoice System &nbsp;·&nbsp; Innovating The Future</span>
                <span class="footer-tagline">Thank you for your business</span>
            </div>
        </div>

    </div><!-- /invoice -->

</div><!-- /invoice-details-page -->
