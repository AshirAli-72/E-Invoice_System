@page "{id:int}"
@model E_Invoice_system.Pages.Customer.EditModel
@{
    ViewData["Title"] = "Edit Customer";
}

<div class="dashboard-panel">
    <div class="page-header">
        <h1 class="page-title-large">
            Edit Customer
        </h1>
        <a asp-page="./Index" class="btn-secondary">
            <i class="ph-arrow-left"></i> Back to Customers
        </a>
    </div>

    <component type="typeof(E_Invoice_system.Components.Customer.CustomerForm)" render-mode="ServerPrerendered" param-CustomerId="@Model.Customer.id" />
</div>
