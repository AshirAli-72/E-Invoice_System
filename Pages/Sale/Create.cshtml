@page
@model E_Invoice_system.Pages.Sale.CreateModel
@{
    Layout = "_SaleLayout";
    ViewData["Title"] = "Create Sale";
}

<component type="typeof(E_Invoice_system.Components.Sale.SaleEditor)" render-mode="ServerPrerendered" 
           param-UserName='@HttpContext.Session.GetString("UserName")' />

@section Scripts {
    <script src="~/lib/jsbarcode/JsBarcode.all.min.js"></script>

    <script>
        window.renderBarcode = (elementId, value) => {
            JsBarcode("#" + elementId, value, {
                format: "CODE128",
                width: 3,
                height: 80,
                displayValue: true,
                fontSize: 20,
                margin: 0
            });
        };
    </script>
    <partial name="_ValidationScriptsPartial" />
}
