@page "{id:int}"
@model E_Invoice_system.Pages.Product.EditModel
@{
    ViewData["Title"] = "Edit Product";
}

<div class="dashboard-panel">
    <div class="page-header">
        <h1 class="page-title-large">
            Edit Product
        </h1>
        <a asp-page="./Index" class="btn-secondary">
            <i class="ph-arrow-left"></i> Back to List
        </a>
    </div>

    <component type="typeof(E_Invoice_system.Components.Product.ProductForm)" render-mode="ServerPrerendered" param-ProductId="@Model.Product.id" />
</div>
