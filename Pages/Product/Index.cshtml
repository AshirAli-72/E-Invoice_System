@page
@model E_Invoice_system.Pages.Product.IndexModel
@{
    ViewData["Title"] = "Products & Services";
}

<div class="card card-no-padding">
    <div class="card-header card-header-flex" style="padding: 1.5rem 1.5rem 0 1.5rem;">
        <div class="card-title">Manage Products & Services</div>
        <a asp-page="/Product/Create" class="btn-primary">
            <i class="ph-plus-circle"></i> Add New Item
        </a>
    </div>
    
    <div class="table-responsive">
        <table class="styled-table">
            <thead>
                <tr>
                    <th style="padding-left: 1.5rem; width: 60px;">ID</th>
                    <th style="width: 80px;">Image</th>
                    <th>Item/Service Name</th>
                    <th>Barcode</th>
                    <th style="width: 140px;">QTY / UNIT</th>
                    <th style="width: 120px;">Price</th>
                    <th style="width: 100px;">Discount</th>
                    <th style="width: 120px;">Status</th>
                    <th class="text-right" style="padding-right: 1.5rem; width: 120px;">Actions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model.Products)
                {
                    <tr>
                        <td class="font-bold" style="padding-left: 1.5rem;">#@item.id</td>
                        <td>
                            @if (!string.IsNullOrEmpty(item.image))
                            {
                                <img src="/product-images/@System.IO.Path.GetFileName(item.image)" alt="Product" style="width: 50px; height: 50px; object-fit: cover; border-radius: 8px;" />
                            }
                            else
                            {
                                <div style="width: 50px; height: 50px; background: #f1f5f9; border-radius: 8px; display: flex; align-items: center; justify-content: center; color: #94a3b8;">
                                    <i class="ph-image" style="font-size: 1.5rem;"></i>
                                </div>
                            }
                        </td>
                        <td class="font-medium">@item.prod_name_service</td>
                        <td>@(item.barcode ?? "-")</td>
                        <td>@item.qty_unit_type</td>
                        <td class="font-bold">$@item.price.ToString("F2")</td>
                        <td class="text-danger font-medium">
                            <div style="display: flex; align-items: center; height: 50px;">
                                $@item.discount.ToString("F2")
                            </div>
                        </td>
                        <td>
                            <span class="status-badge @(item.status == "Available" ? "status-available" : "status-out-of-stock")">
                                @(item.status ?? "N/A")
                            </span>
                        </td>
                        <td class="text-right" style="padding-right: 1.5rem;">
                            <div class="actions-container actions-right">
                                <a asp-page="./Edit" asp-route-id="@item.id" class="btn-icon-sm btn-edit" title="Edit">
                                    <i class="ph-pencil"></i>
                                </a>
                                <form method="post" asp-page-handler="Delete" asp-route-id="@item.id" style="display:inline;" onsubmit="return confirm('Are you sure you want to delete this item?')">
                                    <button type="submit" class="btn-icon-sm btn-delete" title="Delete">
                                        <i class="ph-trash"></i>
                                    </button>
                                </form>
                            </div>
                        </td>
                    </tr>
                }
                @if (!Model.Products.Any())
                {
                    <tr>
                        <td colspan="9" class="empty-state">
                            <i class="ph-package empty-state-icon"></i>
                            <p>No products found. Click "Add New Item" to get started.</p>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>

    <!-- Pagination -->
    @if (Model.TotalPages > 1)
    {
        <div class="pagination-footer">
            <div class="pagination-info">
                Showing <span>@((Model.PageNumber - 1) * Model.PageSize + 1)</span> to <span>@(Math.Min(Model.PageNumber * Model.PageSize, Model.TotalCount))</span> of <span>@Model.TotalCount</span>
            </div>
            <div class="pagination-controls">
                @if (Model.PageNumber > 1)
                {
                    <a asp-page="./Index" asp-route-PageNumber="@(Model.PageNumber - 1)" class="page-link-btn">
                        <i class="ph-caret-left"></i> Previous
                    </a>
                }
                else
                {
                    <button class="page-link-btn disabled" disabled><i class="ph-caret-left"></i> Previous</button>
                }

                <div class="page-number-indicator">
                    Page @Model.PageNumber of @Model.TotalPages
                </div>

                @if (Model.PageNumber < Model.TotalPages)
                {
                    <a asp-page="./Index" asp-route-PageNumber="@(Model.PageNumber + 1)" class="page-link-btn">
                        Next <i class="ph-caret-right"></i>
                    </a>
                }
                else
                {
                    <button class="page-link-btn disabled" disabled>Next <i class="ph-caret-right"></i></button>
                }
            </div>
        </div>
    }
</div>

<style>
    /* Pagination Styles */
    .pagination-footer {
        padding: 1.25rem 1.5rem;
        background: #f8fafc;
        border-top: 1px solid rgba(0,0,0,0.05);
        display: flex;
        justify-content: space-between;
        align-items: center;
        flex-wrap: wrap;
        gap: 1.5rem;
    }

    .pagination-info {
        font-size: 0.85rem;
        color: #64748b;
    }

    .pagination-info span {
        font-weight: 700;
        color: #1e293b;
    }

    .pagination-controls {
        display: flex;
        align-items: center;
        gap: 1rem;
    }

    .page-link-btn {
        display: flex;
        align-items: center;
        gap: 8px;
        padding: 8px 16px;
        background: white;
        border: 1px solid #e2e8f0;
        border-radius: 10px;
        color: #1e293b;
        text-decoration: none;
        font-size: 0.85rem;
        font-weight: 600;
        transition: all 0.2s;
    }

    .page-link-btn:hover:not(.disabled) {
        border-color: var(--primary);
        color: var(--primary);
        background: #f0f9ff;
    }

    .page-link-btn.disabled {
        opacity: 0.5;
        cursor: not-allowed;
    }

    .page-number-indicator {
        font-size: 0.85rem;
        font-weight: 600;
        color: #64748b;
    }

    @@media (max-width: 768px) {
        .pagination-footer {
            flex-direction: column;
            align-items: center;
            text-align: center;
        }
    }
</style>
