@page
@model E_Invoice_system.Pages.Inventory.IndexModel
@{
    ViewData["Title"] = "Inventory";
}

<div class="card card-no-padding">
    <div class="card-header card-header-flex" style="padding: 1.5rem 1.5rem 1.5rem 1.5rem; border-bottom: 1px solid rgba(0,0,0,0.05);">
        <div style="display: flex; flex-direction: column; gap: 0.5rem;">
            <div class="card-title" style="margin: 0;">Inventory</div>
            <p class="text-muted font-sm">A read-only view of all products and stock levels.</p>
        </div>
    </div>

    <div class="table-container">
        <div class="table-responsive">
            <div style="padding: 1rem 1.5rem; background: #f8fafc; border-bottom: 1px solid rgba(0,0,0,0.05);">
                <span class="text-muted font-sm font-bold"><i class="ph-package"></i> ALL PRODUCTS</span>
            </div>
            <table class="styled-table" style="min-width: 1000px; margin-bottom: 0;">
            <thead>
                <tr>
                    <th style="padding-left: 1.5rem;">ID</th>
                    <th>Pic</th>
                    <th>Product Name</th>
                    <th>Barcode</th>
                    <th>State</th>
                    <th>Unit</th>
                    <th>Item Type</th>
                    <th>Size</th>
                    <th>Category</th>
                    <th>Brand</th>
                    <th>Status</th>
                </tr>
            </thead>
            <tbody>
                @if (Model.Products.Any())
                {
                    @foreach (var item in Model.Products)
                    {
                        <tr>
                            <td class="font-bold" style="padding-left: 1.5rem;">@item.id</td>
                            <td>
                                @if (!string.IsNullOrEmpty(item.pic))
                                {
                                    <img src="/product-images/@System.IO.Path.GetFileName(item.pic)" alt="Product" style="width: 40px; height: 40px; object-fit: cover; border-radius: 8px;" />
                                }
                                else
                                {
                                    <div style="width: 40px; height: 40px; background: #f1f5f9; border-radius: 8px; display: flex; align-items: center; justify-content: center; color: #94a3b8;">
                                        <i class="ph-image" style="font-size: 1.25rem;"></i>
                                    </div>
                                }
                            </td>
                            <td class="font-medium">@item.prod_name</td>
                            <td>@(item.barcode ?? "-")</td>
                            <td>@(item.prod_state ?? "-")</td>
                            <td>@(item.unit ?? "-")</td>
                            <td>@(item.item_type ?? "-")</td>
                            <td>@(item.size?.ToString() ?? "-")</td>
                            <td>@item.CategoryName</td>
                            <td>@item.BrandName</td>
                            <td>
                                <span class="status-badge @(item.status == "Enable" ? "status-enabled" : (item.status == "Disable" ? "status-discontinued" : "status-out-of-stock"))">
                                    @(item.status ?? "N/A")
                                </span>
                            </td>
                        </tr>
                    }
                }
                else
                {
                    <tr>
                        <td colspan="11" class="empty-state">
                            <i class="ph-package empty-state-icon"></i>
                            <p>No products found in inventory.</p>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>

    @if (Model.Products.Any())
    {
        <div class="pagination-container">
            <div class="pagination-info">
                Showing <b>@((Model.PageNumber - 1) * Model.PageSize + 1)</b> to <b>@(Math.Min(Model.PageNumber * Model.PageSize, Model.TotalCount))</b> of <b>@Model.TotalCount</b> entries
            </div>
            <div class="pagination-controls">
                @if (Model.PageNumber == 1)
                {
                    <button class="btn-pagination" disabled>
                        <i class="ph-caret-left"></i>
                    </button>
                }
                else
                {
                    <a class="btn-pagination" href="@Url.Page("./Index", new { pageNumber = Model.PageNumber - 1 })">
                        <i class="ph-caret-left"></i>
                    </a>
                }

                @for (int i = 1; i <= Model.TotalPages; i++)
                {
                    if (i == 1 || i == Model.TotalPages || (i >= Model.PageNumber - 2 && i <= Model.PageNumber + 2))
                    {
                        if (Model.PageNumber == i)
                        {
                            <button class="btn-pagination active">@i</button>
                        }
                        else
                        {
                            <a class="btn-pagination" href="@Url.Page("./Index", new { pageNumber = i })">@i</a>
                        }
                    }
                    else if (i == Model.PageNumber - 3 || i == Model.PageNumber + 3)
                    {
                        <span class="pagination-ellipsis">...</span>
                    }
                }

                @if (Model.PageNumber == Model.TotalPages)
                {
                    <button class="btn-pagination" disabled>
                        <i class="ph-caret-right"></i>
                    </button>
                }
                else
                {
                    <a class="btn-pagination" href="@Url.Page("./Index", new { pageNumber = Model.PageNumber + 1 })">
                        <i class="ph-caret-right"></i>
                    </a>
                }
            </div>
        </div>
    }
</div>
</div>


