@namespace E_Invoice_system.Components.Sale
@using Microsoft.EntityFrameworkCore
@using System.Text.RegularExpressions
@inject IDbContextFactory<ApplicationDbContext> DbFactory
@inject IJSRuntime JSRuntime
@inject NavigationManager NavigationManager

<div class="pos-container-v2" @onclick="CloseDropdowns">
    <!-- PRODUCT CANVAS (LEFT) -->
    <div class="product-canvas">
        <div class="canvas-header">
            <div class="canvas-header-top">
                <h3 class="canvas-title">Sales Transaction</h3>
                <div class="search-bar-v2-container" style="display: flex; gap: 8px; flex: 1; align-items: center;">
                    <div class="search-bar-v2" style="flex: 1;">
                        <i class="ph-magnifying-glass search-icon" style="color: @(searchType == "receipt" ? "var(--primary)" : "var(--text-muted)")"></i>
                        <input type="text" class="search-input" 
                               placeholder="@(searchType == "receipt" ? "Scan receipt barcode" : "Scan item barcode")"
                               @bind="searchQuery" @bind:event="oninput" @onkeyup="HandleSearchKeyUp" />
                    </div>
                </div>
                <div class="search-type-wrapper" style="min-width: 150px;">
                    <div class="select-wrapper-v2">
                        <i class="ph-magnifying-glass" style="font-size: 1.25rem;"></i>
                        <select class="search-type-select" @bind="searchType">
                            <option value="item">Scan Item</option>
                            <option value="receipt">Scan Receipt</option>
                        </select>
                        <i class="ph-caret-down" style="margin-left: auto;"></i>
                    </div>
                </div>
                <div class="quick-actions-v2">
                    <button type="button" class="btn-action-round" @onclick='ResetComponent' title="Clean Form"><i class="ph-arrows-clockwise"></i></button>
                    <button type="button" class="btn-action-round" @onclick="ToggleFullScreen" title="Full Screen"><i class="ph-corners-out"></i></button>
                    <a href="/Sale/Index" class="btn-action-round back" title="Back to List"><i class="ph-arrow-left"></i></a>
                </div>
            </div>
            <div class="category-tabs-v2">
                <div class="tab-item @(selectedCategory == "all" ? "active" : "")" @onclick='() => FilterByCategory("all")'>All</div>
                <div class="tab-item @(selectedCategory == "Foods" ? "active" : "")" @onclick='() => FilterByCategory("Foods")'>Products</div>
                <div class="tab-item @(selectedCategory == "Beverages" ? "active" : "")" @onclick='() => FilterByCategory("Beverages")'>Services</div>
            </div>
        </div>

        <div class="product-grid-v2">
            @if (isLoading)
            {
                <div style="grid-column: 1 / -1; display: flex; flex-direction: column; align-items: center; justify-content: center; padding: 60px 20px; color: var(--text-muted); text-align: center;">
                    <i class="ph-spinner-gap" style="font-size: 3.5rem; color: var(--primary); opacity: 0.8; animation: spin 1s linear infinite; margin-bottom: 16px;"></i>
                    <h3 style="margin: 0; font-weight: 700; color: var(--text-main);">Loading Products...</h3>
                    <p style="margin: 8px 0 0; font-size: 0.9rem;">Fetching real-time inventory and pricing</p>
                    <style>@@keyframes spin { 100% { transform: rotate(360deg); } }</style>
                </div>
            }
            else
            {
                @if (!filteredProducts.Any())
                {
                    <div style="grid-column: 1 / -1; text-align: center; padding: 40px; color: var(--text-muted);">
                        <i class="ph-package" style="font-size: 3rem; margin-bottom: 12px; opacity: 0.5;"></i>
                        <h4>No products found</h4>
                    </div>
                }
                @foreach (var p in filteredProducts)
                {
                    <div class="product-card-v2" @onclick="() => AddToSale(p)">
                        <div class="card-image">
                            @if (!string.IsNullOrEmpty(p.Image))
                            {
                                <img src="/product-images/@System.IO.Path.GetFileName(p.Image)" alt="Product" />
                            }
                            else
                            {
                                <div class="image-placeholder">
                                    <i class="@(p.IsService ? "ph-wrench" : "ph-cube-transparent")" style="font-size:3rem;color:#cbd5e1;"></i>
                                </div>
                            }
                        </div>
                        <div class="card-info">
                            <h4 class="card-name">@p.Name</h4>
                            <div class="card-price-row">
                                <span class="price-tag">@CurrencyService.GetSymbol()@p.Price.ToString("N2")</span>
                                @if (p.Discount > 0)
                                {
                                    <span class="discount-pill">@CurrencyService.GetSymbol()@p.Discount.ToString("N2")</span>
                                }
                            </div>
                        </div>
                    </div>
                }
            }
        </div>
    </div>

    <!-- CHECKOUT PANEL (RIGHT) -->
    <div class="checkout-center">
        <div class="checkout-form">
            <div class="checkout-header">
                @if (transMode == "return")
                {
                    <div class="return-warning-banner" style="display: flex;"><i class="ph-warning"></i> RETURN MODE ACTIVE</div>
                }
                <div class="checkout-header-main">
                    <div>
                        <h3 class="order-detail-title">Order Detail</h3>
                        <div class="item-count-badge">@saleItems.Count item@(saleItems.Count != 1 ? "s" : "") selected</div>
                    </div>
                    <div class="checkout-header-actions">
                        <div class="mode-toggle-v2 compact">
                            <div class="toggle-pill">
                                <button type="button" class="toggle-item @(transMode == "sale" ? "active" : "")" @onclick='() => SetTransMode("sale")'>Sale</button>
                                <button type="button" class="toggle-item @(transMode == "return" ? "active" : "")" @onclick='() => SetTransMode("return")'>Return</button>
                            </div>
                        </div>
                        <button type="button" class="btn-clear-v2" @onclick="ClearSaleItems" title="Clear Order">
                            <i class="ph-trash"></i>
                        </button>
                    </div>
                </div>
            </div>

            <!-- Customer Selector -->
            <div class="customer-selector-v2" @onclick:stopPropagation>
                <div class="select-wrapper-v2" style="flex: 1;">
                    <i class="ph-user-circle" style="font-size: 1.25rem;"></i>
                    <div class="customer-search-container" style="flex: 1; position: relative;">
                        <input type="text" class="customer-search-input" placeholder="Search Customer..." 
                               style="border: none; background: transparent; width: 100%; outline: none; font-weight: 600;"
                               @bind="customerSearchQuery" @bind:event="oninput" @bind:after="FilterCustomers"
                               @onfocus="OnCustomerSearchFocus" 
                               @onclick:stopPropagation />
                        
                        @if (showCustomerDropdown)
                        {
                            <div class="customer-dropdown-results shadow-luxury show">
                                @foreach (var c in filteredCustomersList)
                                {
                                    <div class="customer-result-item" @onclick="() => SelectCustomer(c)" @onclick:stopPropagation>
                                        <div class="cust-avatar">@(string.IsNullOrEmpty(c.name) ? "?" : c.name[0].ToString().ToUpper())</div>
                                        <div class="cust-info-main">
                                            <span class="cust-name">@c.name</span>
                                            @if (!string.IsNullOrEmpty(c.contact))
                                            {
                                                <span class="cust-details">@c.contact</span>
                                            }
                                        </div>
                                        <i class="ph-check select-icon"></i>
                                    </div>
                                }
                                @if (!filteredCustomersList.Any())
                                {
                                    <div class="customer-result-item" style="cursor:default;color:var(--text-muted);justify-content:center;" @onclick:stopPropagation>
                                        <i class="ph-user-minus" style="font-size:1.2rem;margin-right:8px;"></i> No customers found
                                    </div>
                                }
                            </div>
                        }
                    </div>
                    <i class="ph-caret-down"></i>
                </div>
                <button type="button" @onclick="() => showAddCustomerModal = true" class="btn-add-customer">
                    <i class="ph-plus-circle"></i><span>New Customer</span>
                </button>
            </div>

            <!-- Items List -->
            <div class="checkout-items-v2">
                @foreach (var item in saleItems)
                {
                    <div class="item-v2">
                        <div class="item-v2-img">
                            @if (!string.IsNullOrEmpty(item.image))
                            {
                                <img src="/product-images/@System.IO.Path.GetFileName(item.image)" />
                            }
                            else
                            {
                                <i class="ph-package" style="font-size:1.5rem;color:#cbd5e1;"></i>
                            }
                        </div>
                        <div class="item-v2-info">
                            <div class="title">@item.prod_name_service</div>
                            <div class="price-input-container">
                                <span>@CurrencyService.GetSymbol()</span>
                                <input type="number" step="0.01" class="manual-price-input" 
                                       @bind="item.price" @onbind:after="() => CalculateSaleItemTotal(item)" />
                            </div>
                        </div>
                        <div class="item-v2-controls">
                            <div class="qty-stepper">
                                <button type="button" @onclick="() => DecreaseQty(item)">-</button>
                                <input type="number" class="manual-qty-input" 
                                       value="@item.qty" 
                                       @onchange="(e) => UpdateItemQty(item, e.Value?.ToString())" />
                                <button type="button" @onclick="() => IncreaseQty(item)">+</button>
                            </div>
                        </div>
                        <div class="item-total-info">
                            <div class="price-sub">@CurrencyService.GetSymbol()@item.total_price.ToString("N2")</div>
                        </div>
                        <i class="ph-trash btn-remove-item" @onclick="() => RemoveItem(item)"></i>
                    </div>
                }

                @if (!saleItems.Any())
                {
                    <div class="empty-state-v2" style="display: flex;">
                        <div class="empty-glow"></div>
                        <i class="ph-shopping-cart-simple"></i>
                        <p>Bag is empty</p>
                    </div>
                }
            </div>

            <!-- Checkout Footer -->
            <div class="checkout-footer-v2">
                <div class="price-summary-v2">
                    <div class="summary-line"><span>Subtotal</span><span>@FormatCurrency(totalSub)</span></div>
                    <div class="summary-line" style="color:var(--success);"><span>Discount</span><span>@FormatCurrency(totalDisc)</span></div>
                    
                    @if (!string.IsNullOrEmpty(stockAlert))
                    {
                        <div class="alert-v2" style="display:block;">
                            <i class="ph-warning"></i> <span>@stockAlert</span>
                        </div>
                    }

                    <div class="grand-total-row">
                        <div class="total-label">Grand Total</div>
                        <div class="total-value">@FormatCurrency(currentTotal)</div>
                    </div>
                </div>
                <button type="button" class="btn-pay-v2" @onclick="OpenPaymentModal">
                    <i class="ph-credit-card"></i> Proceed to Payment
                </button>
            </div>
        </div>
    </div>
</div>

<!-- PAYMENT MODAL -->
@if (showPaymentModal)
{
    <div class="modal-overlay show" style="display: flex;">
        <div class="payment-card">
            <div class="payment-left">
                <h1 class="payment-title">Checkout</h1>
                <p class="payment-subtitle">Complete your transaction by selecting a payment method.</p>
                <div class="method-tabs">
                    <div class="method-tab @(paymentMethod == "Cash" ? "active" : "")" @onclick='() => SetPaymentMethod("Cash")'><i class="ph-money"></i> <span>Cash</span></div>
                    <div class="method-tab @(paymentMethod == "Card" ? "active" : "")" @onclick='() => SetPaymentMethod("Card")'><i class="ph-credit-card"></i> <span>Card</span></div>
                    <div class="method-tab @(paymentMethod == "Transfer" ? "active" : "")" @onclick='() => SetPaymentMethod("Transfer")'><i class="ph-bank"></i> <span>Bank</span></div>
                    <div class="method-tab @(paymentMethod == "Credit" ? "active" : "")" @onclick='() => SetPaymentMethod("Credit")'><i class="ph-user-focus"></i> <span>Credit</span></div>
                </div>
                <div class="web-input-group">
                    <label>Amount Tendered</label>
                    <input type="number" class="web-input" step="0.01" @bind="tenderedAmount" @bind:event="oninput" placeholder="0.00" />
                    <div class="quick-pills">
                        @foreach (var amt in new[] { 10, 20, 50, 100, 500, 1000, 5000 })
                        {
                            <div class="quick-pill" @onclick="() => tenderedAmount = (tenderedAmount ?? 0) + amt">+ @CurrencyService.GetSymbol()@amt</div>
                        }
                        <div class="quick-pill" @onclick="() => tenderedAmount = Math.Abs(currentTotal)">Match Total</div>
                    </div>
                </div>
                <div class="web-input-group">
                    <label>Reference / Note</label>
                    <input type="text" class="web-input" @bind="notes" placeholder="Transaction notes (optional)" />
                </div>
            </div>
            <div class="payment-right">
                <div class="summary-box-web">
                    <div class="summary-web-line">
                        <span style="color:var(--text-muted);font-weight:600;">Total Amount Due</span>
                        <span style="font-weight:700;">@FormatCurrency(currentTotal)</span>
                    </div>
                    <div class="summary-web-line" style="margin-top:8px;">
                        <span style="color:var(--text-muted);font-weight:600;">Total Tendered</span>
                        <span style="font-weight:700;">@FormatCurrency(tenderedAmount ?? 0)</span>
                    </div>
                    @{
                        var change = (tenderedAmount ?? 0) - Math.Abs(currentTotal);
                        <div class="summary-web-line grand">
                            <span>Change Due</span>
                            <span style="color: @(change >= 0 ? "#22c55e" : "#ef4444")">@FormatCurrency(Math.Abs(change))</span>
                        </div>
                    }
                    <div style="display:flex;align-items:center;justify-content:space-between;margin-top:18px;padding:12px 16px;background:var(--surface);border-radius:10px;border:1px solid var(--border);">
                        <label style="font-weight:600;color:var(--text-main);cursor:pointer;display:flex;align-items:center;gap:8px;">
                            <i class="ph-printer" style="font-size:1.2rem;color:var(--primary);"></i> Print Receipt
                        </label>
                        <label class="toggle-switch">
                            <input type="checkbox" @bind="shouldPrintReceipt">
                            <span class="toggle-slider"></span>
                        </label>
                    </div>
                </div>
                <div style="margin-top:auto;">
                    <p style="font-size:.75rem;color:var(--text-muted);text-align:center;margin-bottom:24px;line-height:1.5;">
                        By completing this order, you agree to generate an official invoice and update stock levels.
                    </p>
                    <div style="display:flex;gap:16px;">
                        <button type="button" class="btn-confirm-web cancel" style="flex:1;" @onclick="() => showPaymentModal = false">Cancel</button>
                        <button type="button" class="btn-confirm-web confirm @(isSubmitting ? "processing" : "")" style="flex:1;" @onclick="SubmitSale" disabled="@isSubmitting">
                            @if (!isSubmitting) { <span>Complete Order</span> <i class="ph-check-circle"></i> }
                        </button>
                    </div>
                </div>
            </div>
        </div>
    </div>
}

<!-- ADD CUSTOMER MODAL -->
@if (showAddCustomerModal)
{
    <div class="modal-overlay show" style="display: flex;">
        <div class="payment-card" style="max-width:900px;width:95%;flex-direction:column;overflow-y:auto;max-height:90vh;padding:40px;">
            <div class="dashboard-panel">
                <div class="page-header">
                    <h1 class="page-title-large">Add New Customer</h1>
                    <button type="button" class="btn-secondary" @onclick="() => showAddCustomerModal = false">
                        <i class="ph-arrow-left"></i> Back
                    </button>
                </div>
                <div class="form-wrapper form-layout-left-wide">
                    <div class="form-section">
                        <div class="form-section-header">
                            <h3 class="form-section-title"><i class="ph-users form-icon-primary"></i> Customer Information</h3>
                        </div>
                        <div class="form-group">
                            <label class="form-label">Full Name</label>
                            <input type="text" class="form-control" @bind="newCustomer.name" placeholder="Enter customer's full name" />
                        </div>
                        <div class="form-group">
                            <label class="form-label">Contact Number</label>
                            <input type="text" class="form-control" @bind="newCustomer.contact" placeholder="Enter contact number" />
                        </div>
                        <div class="form-group">
                            <label class="form-label">Email Address</label>
                            <input type="email" class="form-control" @bind="newCustomer.email" placeholder="Enter email address" />
                        </div>
                        <div class="form-group">
                            <label class="form-label">Address</label>
                            <textarea class="form-control" rows="3" @bind="newCustomer.address" placeholder="Enter physical address"></textarea>
                        </div>
                        <div class="form-group">
                            <label class="form-label">Status</label>
                            <select class="form-control" @bind="newCustomer.status">
                                <option value="Active">Active</option>
                                <option value="Inactive">Inactive</option>
                            </select>
                        </div>
                    </div>
                    <div class="form-actions-sticky" style="display:flex;gap:16px;margin-top:32px;">
                        <button type="button" class="btn-confirm-web" style="flex:1;background:#991b1b;color:#fff;border:none;box-shadow: 0 4px 6px -1px rgba(0,0,0,0.1);" @onclick="() => showAddCustomerModal = false">Cancel</button>
                        <button type="button" class="btn-confirm-web" style="flex:1;background:#166534;color:#fff;border:none;box-shadow: 0 4px 6px -1px rgba(0,0,0,0.1);" @onclick="SaveNewCustomer">
                            <i class="ph-check"></i> Save Customer
                        </button>
                    </div>

                </div>
            </div>
        </div>
    </div>
}

<!-- THERMAL RECEIPT (DESIGN REFRESH) -->
<div id="thermalReceipt">

    <div class="rcpt-header">
        <div class="rcpt-shop-name">@(currentStore?.ShopName ?? "THE SATA POS")</div>
        <div class="rcpt-address">@(currentStore?.Address ?? "Address")</div>
        <div class="rcpt-phone">@(currentStore?.Phone1 ?? "0313-3879645")</div>
    </div>

    <div class="rcpt-info">
        <div class="rcpt-info-line"><b>Order:</b> @orderBillNo</div>
        <div class="rcpt-info-line"><b>Cashier:</b> @(UserEmail?.Split('@')[0] ?? "nill")</div>
        <div class="rcpt-info-line"><b>Customer:</b> @(selectedCustomer?.name ?? "Walk-In")</div>
    </div>

    <table class="rcpt-table">
        <thead>
            <tr>
                <th class="col-prod" style="text-align: left;">PRODUCT</th>
                <th class="col-qty" style="text-align: center;">QTY</th>
                <th class="col-price" style="text-align: right;">PRICE</th>
                <th class="col-amt" style="text-align: right;">AMOUNT</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in saleItems)
            {
                <tr>
                    <td class="col-prod">@item.prod_name_service</td>
                    <td class="col-qty">@Math.Abs(item.qty)</td>
                    <td class="col-price">@item.price.ToString("N0")</td>
                    <td class="col-amt">@((item.price * Math.Abs(item.qty)).ToString("N0"))</td>
                </tr>
            }
        </tbody>
    </table>

    <div class="rcpt-totals">
        <div class="rcpt-total-line"><span>SUB TOTAL</span><span>@CurrencyService.GetSymbol()@Math.Abs(totalSub).ToString("N0")</span></div>
        @if (totalDisc != 0)
        {
            <div class="rcpt-total-line"><span>DISCOUNT</span><span>-@CurrencyService.GetSymbol()@Math.Abs(totalDisc).ToString("N0")</span></div>
        }
        <hr class="rcpt-hr-thin">
        <div class="rcpt-total-line"><span>GRAND TOTAL</span><span>@CurrencyService.GetSymbol()@Math.Abs(currentTotal).ToString("N0")</span></div>
        <div class="rcpt-total-line"><span>CASH SALE</span><span>@CurrencyService.GetSymbol()@(tenderedAmount?.ToString("N0") ?? Math.Abs(currentTotal).ToString("N0"))</span></div>
        <div class="rcpt-total-line"><span>PAY TYPE</span><span>@paymentMethod</span></div>
    </div>

    <div class="rcpt-footer">
        <hr class="rcpt-hr-thick">
        <div class="rcpt-thank-you">THANK YOU!</div>
        <hr class="rcpt-hr-thick">
        <div class="rcpt-promo">*** Refer a Friend To Smoke Drop &amp; Get 5% off. ***</div>
        <hr class="rcpt-hr-thin">
        <div class="rcpt-copyright">Copyrights 2023, Powered by The SATA POS</div>
        <hr class="rcpt-hr-thin">
    </div>

    <div class="rcpt-bottom">
        <div class="rcpt-bottom-left">
            <div class="rcpt-date">Generated on @DateTime.Now.ToString("M/d/yyyy h:mm:ss tt")</div>
        </div>
        @if (transMode != "return")
        {
            <div class="rcpt-barcode-wrap">
                <svg id="rcptBarcodeSvg"></svg>
            </div>
        }
    </div>

</div>


@code {
    private List<ProductDisplay> allProducts = new();
    private List<ProductDisplay> filteredProducts = new();
    private List<customers> allCustomersList = new();
    private List<customers> filteredCustomersList = new();
    private List<SaleItem> saleItems = new();

    private string searchQuery = "";
    private string searchType = "item";
    private string selectedCategory = "all";
    private string transMode = "sale";
    private string? customerSearchQuery;
    private customers? selectedCustomer;
    private bool showCustomerDropdown = false;
    private bool showPaymentModal = false;
    private bool showAddCustomerModal = false;
    private string paymentMethod = "Cash";
    private decimal? tenderedAmount = null;
    private string notes = "";  
    private bool shouldPrintReceipt = true;
    private string? stockAlert;
    private bool isSubmitting = false;
    private string orderBillNo = "";
    private customers newCustomer = new customers { status = "Active" };
    private StoreConfiguration? currentStore;

    [Parameter] public string? UserEmail { get; set; }
    [Parameter] public string? UserName { get; set; }

    private bool isLoading = true;

    protected override async Task OnInitializedAsync()
    {
        // Prime currency symbol before data loading
        await CurrencyService.GetSymbolAsync();

        // Non-blocking initialization so the UI renders instantly
        _ = LoadDataAsync();
    }

    private async Task LoadDataAsync()
    {
        isLoading = true;
        await InvokeAsync(StateHasChanged);

        try 
        {
            using var context = DbFactory.CreateDbContext();
            // Sequential data fetching to avoid EF Core concurrency issues
            var prodsData = await context.products_services
                .AsNoTracking()
                .Where(p => p.status == "Enable")
                .Select(p => new { 
                    p.id, p.prod_name, p.pic, p.barcode,
                    p.expiry_date, p.prod_state, p.unit, p.size, p.item_type,
                    p.category_id, p.brand_id
                })
                .OrderByDescending(p => p.id)
                .Take(50) 
                .ToListAsync();

            allCustomersList = await context.customers
                .AsNoTracking()
                .OrderBy(c => c.name)
                .Take(50) 
                .ToListAsync();

            currentStore = await context.store_configurations.AsNoTracking().FirstOrDefaultAsync();

            allProducts = prodsData.Select(p => {
                decimal stock = p.size ?? 999999;
                bool isSvc = p.item_type == "Service";
                return new ProductDisplay { 
                    Id = p.id, Name = p.prod_name ?? "", Price = 0, Discount = 0, 
                    Expiry = p.expiry_date, Stock = stock, IsService = isSvc, Image = p.pic, 
                    Category = isSvc ? "Beverages" : "Foods", Barcode = p.barcode 
                };
            }).ToList();
            
            filteredProducts = allProducts;
            filteredCustomersList = allCustomersList;

            // Optional: simulate network delay briefly for skeleton testing if desired
            // await Task.Delay(500);
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error loading data: {ex.Message}");
        }
        finally 
        {
            isLoading = false;
            await InvokeAsync(StateHasChanged);
        }
    }

    private void FilterByCategory(string cat)
    {
        selectedCategory = cat;
        if (cat == "all") filteredProducts = allProducts;
        else filteredProducts = allProducts.Where(p => p.Category == cat).ToList();
    }

    private void HandleSearchKeyUp(KeyboardEventArgs e)
    {
        if (string.IsNullOrEmpty(searchQuery)) return;

        // Auto-detect Receipt Scan (SALE_ or RETURN_)
        if (searchQuery.ToUpper().StartsWith("SALE_") || searchQuery.ToUpper().StartsWith("RETURN_")) {
            _ = LoadFromReceipt(searchQuery);
            searchQuery = "";
            return;
        }

        if (searchType == "item") {
            var query = searchQuery.ToLower();
            filteredProducts = allProducts.Where(p => p.Name.ToLower().Contains(query) || (p.Barcode != null && p.Barcode.ToLower() == query)).ToList();
            
            var exact = allProducts.FirstOrDefault(p => p.Barcode != null && p.Barcode.ToLower() == query);
            if (exact != null) {
                AddToSale(exact);
                searchQuery = "";
                filteredProducts = allProducts;
            }
        } else if (e.Key == "Enter" && searchType == "receipt") {
            _ = LoadFromReceipt(searchQuery);
            searchQuery = "";
        }
    }

    private async Task LoadFromReceipt(string billNo)
    {
        using var context = DbFactory.CreateDbContext();
        var sales = await context.sales.Where(s => s.billNo == billNo).ToListAsync();
        if (sales.Any()) {
            transMode = "return";
            saleItems = sales.Select(s => {
                return new SaleItem {
                    prod_name_service = "Item #" + s.id,
                    qty = -s.qty,
                    price = s.price,
                    discount = s.qty != 0 ? s.discount / s.qty : 0,
                    expiry_date = s.expiry_date,
                    maxStock = (decimal)s.qty,
                    total_price = Math.Abs(s.total_price),
                    OriginalSaleId = s.id
                };
            }).ToList();
            StateHasChanged();
        }
    }

    private void AddToSale(ProductDisplay p)
    {
        decimal qty = transMode == "return" ? -1 : 1;
        var existing = saleItems.FirstOrDefault(i => i.prod_name_service == p.Name);
        if (existing != null) {
            if (transMode == "sale" && (existing.qty + 1) > p.Stock) { ShowAlert("Insufficient stock."); return; }
            existing.qty += qty;
            if (existing.qty == 0) saleItems.Remove(existing);
            else existing.total_price = (existing.price * existing.qty) - (existing.discount * existing.qty);
        } else {
            if (transMode == "sale" && p.Stock < 1) { ShowAlert("Out of stock."); return; }
            saleItems.Add(new SaleItem {
                prod_name_service = p.Name, qty = qty, 
                price = p.Price, discount = p.Discount, expiry_date = p.Expiry, 
                maxStock = p.Stock, image = p.Image, total_price = (p.Price * qty) - (p.Discount * qty)
            });
        }
    }

    private void RemoveItem(SaleItem i) { saleItems.Remove(i); }

    private void ClearSaleItems() { saleItems.Clear(); }

    private void CloseDropdowns() { showCustomerDropdown = false; }

    private void SetTransMode(string mode) {
        transMode = mode;
        foreach (var item in saleItems) {
            decimal abs = Math.Abs(item.qty);
            item.qty = mode == "return" ? -abs : abs;
            item.total_price = (item.price * item.qty) - (item.discount * item.qty);
        }
    }

    private void OnCustomerSearchFocus() {
        showCustomerDropdown = true;
        FilterCustomers();
    }

    private void FilterCustomers() {
        if (string.IsNullOrEmpty(customerSearchQuery)) {
            filteredCustomersList = allCustomersList;
            selectedCustomer = null; 
        }
        else filteredCustomersList = allCustomersList.Where(c => c.name.ToLower().Contains(customerSearchQuery.ToLower()) || (c.contact != null && c.contact.Contains(customerSearchQuery))).ToList();
    }

    private void SelectCustomer(customers c) { selectedCustomer = c; customerSearchQuery = c.name; showCustomerDropdown = false; }

    private void UpdateItemQty(SaleItem item, string? val) {
        if (decimal.TryParse(val, out decimal q)) {
            q = Math.Abs(q);
            if (transMode == "return") q = -q;
            if (q == 0) { saleItems.Remove(item); return; }
            if (transMode == "sale" && q > item.maxStock) { ShowAlert("Stock limit reached."); q = item.maxStock; }
            item.qty = q;
            item.total_price = (item.price * item.qty) - (item.discount * item.qty);
        }
    }

    private void CalculateSaleItemTotal(SaleItem item) {
        item.total_price = (item.price * item.qty) - (item.discount * item.qty);
    }

    private void IncreaseQty(SaleItem i) => UpdateItemQty(i, (Math.Abs(i.qty) + 1).ToString());
    private void DecreaseQty(SaleItem i) => UpdateItemQty(i, (Math.Abs(i.qty) - 1).ToString());

    private decimal totalSub => saleItems.Sum(i => i.price * i.qty);
    private decimal totalDisc => saleItems.Sum(i => i.discount * i.qty);
    private decimal currentTotal => totalSub - totalDisc;

    private void OpenPaymentModal() { if (!saleItems.Any()) return; showPaymentModal = true; tenderedAmount = null; }

    private void SetPaymentMethod(string m) { paymentMethod = m; }

    private void ShowAlert(string msg) { stockAlert = msg; StateHasChanged(); Task.Delay(3000).ContinueWith(_ => { stockAlert = null; InvokeAsync(StateHasChanged); }); }

    private async Task SaveNewCustomer() {
        if (string.IsNullOrEmpty(newCustomer.name)) return;
        using var context = DbFactory.CreateDbContext();
        context.customers.Add(newCustomer);
        await context.SaveChangesAsync();
        allCustomersList.Add(newCustomer);
        SelectCustomer(newCustomer);
        newCustomer = new customers { status = "Active" };
        showAddCustomerModal = false;
    }

    private async Task SubmitSale() {
        if (isSubmitting) return;
        if (!saleItems.Any()) { ShowAlert("Cannot complete an empty order."); return; }

        isSubmitting = true;
        try {
            using var context = DbFactory.CreateDbContext();
            int nextIdNum = 1;
            var prefix = transMode == "return" ? "RETURN_" : "SALE_";
            
            // OPTIMIZED: Fetch ONLY the most recent bill number instead of the entire list
            string? lastBillNo = null;
            if (transMode == "return") {
                lastBillNo = await context.returns
                    .Where(r => r.billNo != null && r.billNo.StartsWith(prefix))
                    .OrderByDescending(r => r.Id)
                    .Select(r => r.billNo)
                    .FirstOrDefaultAsync();
            } else {
                lastBillNo = await context.sales
                    .Where(s => s.billNo != null && s.billNo.StartsWith(prefix))
                    .OrderByDescending(s => s.id)
                    .Select(s => s.billNo)
                    .FirstOrDefaultAsync();
            }

            if (!string.IsNullOrEmpty(lastBillNo)) {
                var parts = lastBillNo.Split(new[] { '_', '-' });
                if (parts.Length > 1 && int.TryParse(parts[1], out int n)) nextIdNum = n + 1;
            }
            orderBillNo = $"{prefix}{nextIdNum}";

            
            string customerInfo = selectedCustomer != null ? $" [Customer: {selectedCustomer.name}]" : " [Walk-In]";
            string saleDescription = ((notes ?? "") + customerInfo);
            if (saleDescription.Length > 200) saleDescription = saleDescription.Substring(0, 200);

            // OPTIMIZED: Batch fetch all products in the sale at once instead of N times in loop
            var productNames = saleItems.Select(i => i.prod_name_service).Distinct().ToList();
            var productsToUpdate = await context.products_services
                .Where(p => productNames.Contains(p.prod_name))
                .ToListAsync();

            foreach (var item in saleItems) {
                if (transMode == "return") {
                    if (item.OriginalSaleId == 0) {
                        var recentSale = await context.sales
                            .Where(s => s.billNo != null && s.billNo.StartsWith("SALE_"))
                            .OrderByDescending(s => s.id)
                            .FirstOrDefaultAsync();
                        if (recentSale != null) {
                            item.OriginalSaleId = recentSale.id;
                        }
                    }

                    var returnRec = new Models.ReturnDetail {
                        billNo = orderBillNo,
                        SaleId = item.OriginalSaleId,
                        Date = DateTime.Now,
                        no_of_items = saleItems.Count,
                        qty = Math.Abs(item.qty),
                        total_qty = saleItems.Sum(i => Math.Abs(i.qty)),
                        Amount = Math.Abs(item.total_price),
                        Method = paymentMethod,
                        Status = "RETURN"
                    };
                    context.returns.Add(returnRec);
                } else {
                    var sale = new Models.Sale {
                        billNo = orderBillNo, 
                        date = DateTime.Now.ToString("MM-dd-yyyy h:mm tt"), 
                        no_of_items = saleItems.Count,
                        qty = item.qty,
                        total_qty = saleItems.Sum(i => Math.Abs(i.qty)),
                        price = item.price,
                        discount = item.discount, 
                        total_price = item.total_price, 
                        payment_method = paymentMethod, 
                        status = (paymentMethod == "Credit" || paymentMethod == "Pending") ? "Pending" : "Paid",
                        is_returned = false, 
                        description = saleDescription,
                        expiry_date = item.expiry_date ?? DateTime.Now 
                    };
                    context.sales.Add(sale);
                }
                
                // OPTIMIZED: Use cached product lookup
                try {
                    var prod = productsToUpdate.FirstOrDefault(p => p.prod_name == item.prod_name_service);
                    if (prod != null) {
                        if (prod.size.HasValue) {
                            var newQty = (int)(prod.size.Value - item.qty);
                            prod.size = newQty;
                            if (newQty <= 0) prod.status = "Disabled";
                            context.products_services.Update(prod);
                        }
                    }
                } catch (Exception ex) { 
                    Console.WriteLine("Stock Update Error: " + ex.Message); 
                }
            }

            await context.SaveChangesAsync();

            StateHasChanged();
            await Task.Delay(100); // Allow DOM to render the orderBillNo
            
            if (shouldPrintReceipt) {
                try {
                    if (transMode != "return") {
                        await JSRuntime.InvokeVoidAsync("renderBarcode", "rcptBarcodeSvg", orderBillNo);
                    }
                    await JSRuntime.InvokeVoidAsync("window.print");
                } catch (Exception jsEx) {
                    Console.WriteLine("Print Error: " + jsEx.Message);
                }
            }
            
            ShowAlert("Transaction successfully completed!");
            ResetComponent();
        } catch (Exception ex) { 
            string errMessage = ex.Message;
            if (ex.InnerException != null) errMessage += " | " + ex.InnerException.Message;
            ShowAlert("Save Error: " + errMessage); 
            StateHasChanged();
        } finally {
            isSubmitting = false;
        }
    }

    private void ResetComponent()
    {
        saleItems.Clear();
        transMode = "sale";
        selectedCustomer = null;
        customerSearchQuery = "";
        searchQuery = "";
        paymentMethod = "Cash";
        tenderedAmount = null;
        notes = "";
        showPaymentModal = false;
        filteredProducts = allProducts;
        StateHasChanged();
    }

    private string FormatCurrency(decimal val) => (val < 0 ? "-" : "") + CurrencyService.GetSymbol() + Math.Abs(val).ToString("N2");

    private async Task ToggleFullScreen() => await JSRuntime.InvokeVoidAsync("eval", "if (!document.fullscreenElement) document.documentElement.requestFullscreen(); else document.exitFullscreen();");

