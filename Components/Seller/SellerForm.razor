@namespace E_Invoice_system.Components.Seller
@using Microsoft.EntityFrameworkCore
@inject ApplicationDbContext DbContext
@inject NavigationManager NavigationManager
@inject IJSRuntime JSRuntime

<div class="form-wrapper form-layout-left-wide">
    <div class="form-section">
        <div class="form-section-header">
            <h3 class="form-section-title">
                <i class="ph-buildings form-icon-primary"></i>
                Seller Information
            </h3>
        </div>

        @if (!string.IsNullOrEmpty(errorMessage))
        {
            <div class="alert alert-danger" style="margin-bottom: 1.5rem; padding: 1rem; border-radius: 8px; background: #fee2e2; color: #ef4444; border: 1px solid #fecaca;">
                <i class="ph-warning"></i> @errorMessage
            </div>
        }

        <div class="form-group">
            <label class="form-label">Company Name</label>
            <input class="form-control" @bind="seller.name" placeholder="Enter company name" required />
        </div>
        
        <div class="form-group">
            <label class="form-label">Contact Number</label>
            <input class="form-control" @bind="seller.contact" placeholder="Enter contact number" />
        </div>
        
        <div class="form-group">
            <label class="form-label">Email Address</label>
            <input type="email" class="form-control" @bind="seller.email" placeholder="Enter email address" />
        </div>
        
        <div class="form-group">
            <label class="form-label">Address</label>
            <textarea class="form-control" rows="3" @bind="seller.address" placeholder="Enter physical address"></textarea>
        </div>
        
        <div class="form-group">
            <label class="form-label">Status</label>
            <select class="form-control" @bind="seller.status">
                <option value="Active">Active</option>
                <option value="Inactive">Inactive</option>
            </select>
        </div>
    </div>

    <div class="form-actions-sticky">
        <button type="button" class="btn-secondary" @onclick="Cancel">Cancel</button>
        <button type="button" class="btn-primary" @onclick="SaveSeller" disabled="@isSubmitting">
            <span>
                @if (isSubmitting)
                {
                    <i class="ph-spinner ph-spin"></i> @("Saving...")
                }
                else
                {
                    <i class="ph-check"></i> @(SellerId == 0 ? "Save Seller" : "Update Seller")
                }
            </span>
        </button>
    </div>
</div>

@code {
    [Parameter] public int SellerId { get; set; }
    
    private Sellers seller = new Sellers { status = "Active" };
    private string? originalName;
    private bool isSubmitting = false;
    private string? errorMessage;

    protected override async Task OnInitializedAsync()
    {
        if (SellerId != 0)
        {
            var existing = await DbContext.sellers.FindAsync(SellerId);
            if (existing != null)
            {
                seller = existing;
                originalName = existing.name;
            }
        }
    }

    private async Task SaveSeller()
    {
        if (string.IsNullOrWhiteSpace(seller.name)) { errorMessage = "Company Name is required."; return; }

        isSubmitting = true;
        try
        {
            if (SellerId == 0)
            {
                DbContext.sellers.Add(seller);
            }
            else
            {
                // Handle name change logic for invoices
                if (!string.IsNullOrEmpty(originalName) && originalName != seller.name)
                {
                    var associatedInvoices = await DbContext.invoices.Where(i => i.seller_name == originalName).ToListAsync();
                    foreach (var inv in associatedInvoices)
                    {
                        inv.seller_name = seller.name;
                        DbContext.invoices.Update(inv);
                    }
                }
                DbContext.sellers.Update(seller);
            }

            await DbContext.SaveChangesAsync();
            
            // Standard Blazor Navigation
            NavigationManager.NavigateTo("/Seller/Index", true);
        }
        catch (Exception ex)
        {
            errorMessage = "Error saving seller: " + ex.Message;
            isSubmitting = false;
        }
    }

    private void Cancel() => NavigationManager.NavigateTo("/Seller/Index", true);
}
