@using E_Invoice_system.Models
@using E_Invoice_system.Data
@using Microsoft.EntityFrameworkCore
@using System.IO
@inject IDbContextFactory<ApplicationDbContext> DbFactory
@inject NavigationManager Nav
@rendermode RenderMode.InteractiveServer

<div class="management-container @(showForm ? "modal-active" : "")">
    <div class="card card-no-padding">
        <div class="card-header card-header-flex" style="padding: 1.25rem 1.5rem;">
            <div style="display:flex; align-items:center; gap:0.6rem;">
                <i class="ph-users-three" style="font-size:1.3rem; color: var(--primary, #BC1823);"></i>
                <div class="card-title" style="margin: 0;">Employee Management</div>
            </div>
            <button class="btn-primary" @onclick="ShowAddForm" style="display: flex; align-items: center; gap: 8px; padding: 0.6rem 1.2rem; border: none; border-radius: 8px; background: var(--primary); color: white; font-weight: 600; cursor: pointer; font-size: 0.9rem;">
                <i class="ph-user-plus"></i> Add Employee
            </button>
        </div>

        <div class="table-responsive">
            <table class="styled-table">
                <thead>
                    <tr>
                        <th style="padding-left: 1.5rem;">Full Name</th>
                        <th>CNIC</th>
                        <th>Mobile</th>
                        <th>Address</th>
                        <th>Email</th>
                        <th>Salary</th>
                        <th>Status</th>
                        <th class="text-right" style="padding-right: 1.5rem;">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var emp in employeeList)
                    {
                        <tr>
                            <td class="font-bold" style="padding-left: 1.5rem;">@emp.full_name</td>
                            <td class="text-muted">@emp.cnic</td>
                            <td>@emp.mobile_no</td>
                            <td class="text-muted" style="font-size: 0.85rem; max-width: 200px; overflow: hidden; text-overflow: ellipsis; white-space: nowrap;">@emp.address</td>
                            <td>@emp.email</td>
                            <td class="font-bold">@emp.salary.ToString("N2")</td>
                            <td>
                                <span class="badge @(emp.status == "Active" ? "badge-success" : "badge-danger")">
                                    @emp.status
                                </span>
                            </td>
                            <td class="text-right" style="padding-right: 1.5rem;">
                                <div class="actions-container actions-right">
                                    <button class="btn-icon-sm btn-edit" @onclick="() => EditEmployee(emp)" title="Edit">
                                        <i class="ph-pencil"></i>
                                    </button>
                                    <button class="btn-icon-sm btn-delete" @onclick="() => DeleteEmployee(emp.id)" title="Delete">
                                        <i class="ph-trash"></i>
                                    </button>
                                </div>
                            </td>
                        </tr>
                    }
                    @if (!employeeList.Any())
                    {
                        <tr>
                            <td colspan="8" class="empty-state">
                                <i class="ph-users-three empty-state-icon"></i>
                                <p>No employees found. Add your first employee to get started.</p>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
        
        @if (totalCount > pageSize)
        {
            <div class="pagination-container">
                <div class="pagination-info">
                    Showing <b>@((currentPage - 1) * pageSize + 1)</b> to <b>@(Math.Min(currentPage * pageSize, totalCount))</b> of <b>@totalCount</b> entries
                </div>
                <div class="pagination-controls">
                    <button class="btn-pagination" @onclick="PreviousPage" disabled="@(currentPage == 1)">
                        <i class="ph-caret-left"></i>
                    </button>
                    
                    @for (int i = 1; i <= TotalPages; i++)
                    {
                        var pageNumber = i;
                        @if (i == 1 || i == TotalPages || (i >= currentPage - 2 && i <= currentPage + 2))
                        {
                            <button class="btn-pagination @(currentPage == pageNumber ? "active" : "")" @onclick="() => GoToPage(pageNumber)">
                                @pageNumber
                            </button>
                        }
                        else if (i == currentPage - 3 || i == currentPage + 3)
                        {
                            <span class="pagination-ellipsis">...</span>
                        }
                    }

                    <button class="btn-pagination" @onclick="NextPage" disabled="@(currentPage == TotalPages)">
                        <i class="ph-caret-right"></i>
                    </button>
                </div>
            </div>
        }
    </div>
</div>

@if (showForm)
{
    <div class="modal-overlay">
        <div class="modal-content" style="max-width: 650px;">
            <div class="card" style="margin-bottom: 0; border: none;">
                <div class="card-header card-header-flex">
                    <div class="form-section-title">
                        <i class="ph-user-circle @(editingEmployee == null ? "form-icon-primary" : "")"></i>
                        @(editingEmployee == null ? "Register New Employee" : "Edit Employee Details")
                    </div>
                    <button type="button" class="btn-icon-sm" @onclick="HideForm" style="border: none; background: transparent;"><i class="ph-x" style="font-size: 1.25rem;"></i></button>
                </div>

                <EditForm Model="employeeModel" OnValidSubmit="SaveEmployee">
                    <DataAnnotationsValidator />
                    
                    <div style="padding: 0 1.5rem 1.5rem 1.5rem; max-height: calc(100vh - 200px); overflow-y: auto;">
                        @if (!string.IsNullOrEmpty(errorMessage))
                        {
                            <div class="rp-alert rp-alert-error" style="margin-bottom: 1rem;">
                                <i class="ph-warning"></i> @errorMessage
                            </div>
                        }

                        <div class="form-grid" style="grid-template-columns: 1fr; gap: 1rem; margin-bottom: 1rem;">
                            <div class="form-group">
                                <label class="form-label">Full Name</label>
                                <InputText @bind-Value="employeeModel.full_name" class="form-control" placeholder="Enter full name" />
                                <ValidationMessage For="@(() => employeeModel.full_name)" />
                            </div>
                            <div class="form-group">
                                <label class="form-label">Employee Code</label>
                                <div style="position: relative;">
                                    <InputText @bind-Value="employeeModel.emp_code" class="form-control" placeholder="Auto-generated" readonly />
                                    @if (isLoadingCode)
                                    {
                                        <div style="position: absolute; right: 10px; top: 50%; transform: translateY(-50%);">
                                            <i class="ph-spinner ph-spin" style="color: var(--primary);"></i>
                                        </div>
                                    }
                                </div>
                            </div>
                        </div>

                        <div class="form-grid" style="grid-template-columns: 1fr; gap: 1rem; margin-bottom: 1rem;">
                            <div class="form-group">
                                <label class="form-label">CNIC / ID Number</label>
                                <InputText @bind-Value="employeeModel.cnic" class="form-control" placeholder="e.g. 42101-XXXXXXX-X" />
                                <ValidationMessage For="@(() => employeeModel.cnic)" />
                            </div>
                            <div class="form-group">
                                <label class="form-label">Mobile Number</label>
                                <InputText @bind-Value="employeeModel.mobile_no" class="form-control" placeholder="e.g. 0300-XXXXXXX" />
                                <ValidationMessage For="@(() => employeeModel.mobile_no)" />
                            </div>
                        </div>

                        <div class="form-group" style="margin-bottom: 1rem;">
                            <label class="form-label">Email Address</label>
                            <InputText @bind-Value="employeeModel.email" class="form-control" placeholder="employee@example.com" />
                            <ValidationMessage For="@(() => employeeModel.email)" />
                        </div>

                        <div class="form-group" style="margin-bottom: 1rem;">
                            <label class="form-label">Residential Address</label>
                            <InputTextArea @bind-Value="employeeModel.address" class="form-control" rows="2" placeholder="Enter full address" />
                            <ValidationMessage For="@(() => employeeModel.address)" />
                        </div>

                        <div class="form-grid" style="grid-template-columns: 1fr; gap: 1rem; margin-bottom: 1rem;">
                            <div class="form-group">
                                <label class="form-label">Monthly Salary</label>
                                <InputNumber @bind-Value="employeeModel.salary" class="form-control" placeholder="0.00" />
                                <ValidationMessage For="@(() => employeeModel.salary)" />
                            </div>
                            <div class="form-group">
                                <label class="form-label">Joining Date</label>
                                <InputDate @bind-Value="employeeModel.date" class="form-control" />
                                <ValidationMessage For="@(() => employeeModel.date)" />
                            </div>
                        </div>

                        <div class="form-group" style="margin-bottom: 1.5rem;">
                            <label class="form-label">Status</label>
                            <InputSelect @bind-Value="employeeModel.status" class="form-control">
                                <option value="Active">Active</option>
                                <option value="Inactive">Inactive</option>
                            </InputSelect>
                        </div>

                        <!-- Profile Image Section -->
                        <div class="form-group" style="margin-bottom: 1.5rem;">
                            <label class="form-label">Profile Image</label>
                            <div style="display:flex; gap:1.5rem; align-items:flex-start; background: #fff5f6; padding:1.25rem; border-radius:12px; border:2px dashed #fecdd3;">
                                <div style="width:90px; height:90px; border-radius:50%; background: white; display:flex; align-items:center; justify-content:center; overflow:hidden; border: 3px solid white; box-shadow: 0 4px 10px rgba(188, 24, 35, 0.1);">
                                    @if (!string.IsNullOrEmpty(imgUrl))
                                    {
                                        <img src="@imgUrl" style="width:100%; height:100%; object-fit:cover;" />
                                    }
                                    else if (!string.IsNullOrEmpty(employeeModel.image_path))
                                    {
                                        <img src="@GetDisplayImageUrl(employeeModel.image_path)" style="width:100%; height:100%; object-fit:cover;" />
                                    }
                                    else
                                    {
                                        <i class="ph-user-focus" style="font-size:2rem; color: #fecdd3;"></i>
                                    }
                                </div>
                                <div style="flex:1;">
                                    <InputFile OnChange="HandleFileSelected" class="form-control" accept="image/*" style="border: 1px solid #fecdd3; background: white;" />
                                    <p style="font-size:.78rem; color:#475569; margin-top:.6rem; font-weight: 500;">
                                        <i class="ph-info" style="color: var(--primary);"></i> Recommended size: 500x500px. Max 5MB.
                                    </p>
                                </div>
                            </div>
                        </div>

                        <div style="display: flex; justify-content: flex-end; gap: 0.75rem; padding-top: 1.25rem; border-top: 1px solid #f1f5f9;">
                            @if (editingEmployee != null)
                            {
                                <button type="button" @onclick="() => DeleteEmployee(editingEmployee.id)" class="btn-delete" style="display:inline-flex; align-items:center; gap:0.4rem; padding: 0.65rem 1.25rem; border-radius: 8px; border: none; background: #fee2e2; color: #dc2626; font-weight: 600; cursor:pointer; font-size:0.9rem;" disabled="@isSubmitting">
                                    <i class="ph-trash"></i> Delete Account
                                </button>
                            }
                            <button type="button" @onclick="HideForm" style="display:inline-flex; align-items:center; gap:0.4rem; background: #f1f5f9; color: #475569; padding: 0.65rem 1.25rem; border-radius: 8px; border: 1px solid #e2e8f0; font-weight: 600; cursor:pointer; font-size:0.9rem;" disabled="@isSubmitting"><i class="ph-x"></i> Cancel</button>
                            <button type="button" @onclick="SaveEmployee" style="display:inline-flex; align-items:center; gap:0.4rem; padding: 0.65rem 1.5rem; border: none; border-radius: 8px; background: var(--primary); color: white; font-weight: 600; cursor: pointer; font-size:0.9rem; transition:all 0.2s;" disabled="@isSubmitting">
                                @if (isSubmitting)
                                {
                                    <i class="ph-spinner ph-spin"></i>
                                }
                                else
                                {
                                    <i class="ph-check"></i>
                                }
                                <span>@(editingEmployee == null ? "Register Employee" : "Update Details")</span>
                            </button>
                        </div>
                    </div>
                </EditForm>
            </div>
        </div>
    </div>
}



@code {
    private List<Employee> employeeList = new();
    private Employee employeeModel = new();
    private bool showForm = false;
    private Employee? editingEmployee = null;
    private bool isSubmitting = false;
    private bool isLoadingCode = false;
    private string? errorMessage;
    private IBrowserFile? selectedFile;
    private string? imgUrl;

    // Pagination state
    private int currentPage = 1;
    private int pageSize = 10;
    private int totalCount = 0;
    private int TotalPages => (int)Math.Ceiling((double)totalCount / pageSize);

    protected override async Task OnInitializedAsync()
    {
        await LoadEmployees();
    }

    private async Task LoadEmployees()
    {
        using var context = DbFactory.CreateDbContext();
        totalCount = await context.employees.CountAsync();
        
        employeeList = await context.employees
            .OrderByDescending(e => e.id)
            .Skip((currentPage - 1) * pageSize)
            .Take(pageSize)
            .ToListAsync();
            
        await InvokeAsync(StateHasChanged);
    }

    private async Task GoToPage(int page)
    {
        currentPage = page;
        await LoadEmployees();
    }

    private async Task NextPage()
    {
        if (currentPage < TotalPages)
        {
            currentPage++;
            await LoadEmployees();
        }
    }

    private async Task PreviousPage()
    {
        if (currentPage > 1)
        {
            currentPage--;
            await LoadEmployees();
        }
    }

    private string GetDisplayImageUrl(string? path)
    {
        if (string.IsNullOrEmpty(path)) return "";
        try { return "/emp-image/" + Path.GetFileName(path); }
        catch { return ""; }
    }

    private async Task ShowAddForm()
    {
        errorMessage = null;
        editingEmployee = null;
        selectedFile = null;
        imgUrl = null;
        showForm = true;
        isLoadingCode = true;
        
        employeeModel = new Employee 
        { 
            date = DateTime.Now.Date,
            status = "Active",
            emp_code = "Generating..."
        };
        
        await InvokeAsync(StateHasChanged);

        try
        {
            employeeModel.emp_code = await GenerateEmployeeCode();
        }
        catch (Exception ex)
        {
            errorMessage = "Error generating code: " + ex.Message;
        }
        finally
        {
            isLoadingCode = false;
            await InvokeAsync(StateHasChanged);
        }
    }

    private void EditEmployee(Employee item)
    {
        editingEmployee = item;
        employeeModel = new Employee
        {
            id = item.id,
            full_name = item.full_name,
            emp_code = item.emp_code,
            cnic = item.cnic,
            email = item.email,
            mobile_no = item.mobile_no,
            address = item.address,
            image_path = item.image_path,
            salary = item.salary,
            date = item.date,
            status = item.status
        };
        errorMessage = null;
        selectedFile = null;
        imgUrl = null;
        showForm = true;
    }

    private void HideForm()
    {
        showForm = false;
    }

    private async Task HandleFileSelected(InputFileChangeEventArgs e)
    {
        try
        {
            selectedFile = e.File;
            if (selectedFile.Size > 5120000)
            {
                errorMessage = "Select an image less than 5MB.";
                selectedFile = null;
                return;
            }
            using var stream = selectedFile.OpenReadStream(5120000);
            using var ms = new MemoryStream();
            await stream.CopyToAsync(ms);
            imgUrl = $"data:{selectedFile.ContentType};base64,{Convert.ToBase64String(ms.ToArray())}";
            StateHasChanged();
        }
        catch (Exception ex)
        {
            errorMessage = "Preview error: " + ex.Message;
        }
    }

    private async Task SaveEmployee()
    {
        if (string.IsNullOrWhiteSpace(employeeModel.full_name)) { errorMessage = "Full name is required."; return; }

        isSubmitting = true;
        try
        {
            string storagePath = @"D:\netcore\E-Invoice_system\bin\Debug\emp_image";
            if (!Directory.Exists(storagePath)) Directory.CreateDirectory(storagePath);

            if (selectedFile != null)
            {
                string fileName = Guid.NewGuid().ToString() + Path.GetExtension(selectedFile.Name);
                string fullPath = Path.Combine(storagePath, fileName);

                // Delete old image if updating
                if (!string.IsNullOrEmpty(employeeModel.image_path))
                    if (File.Exists(employeeModel.image_path)) try { File.Delete(employeeModel.image_path); } catch { }

                await using var stream = selectedFile.OpenReadStream(5120000);
                await using var fs = new FileStream(fullPath, FileMode.Create);
                await stream.CopyToAsync(fs);
                employeeModel.image_path = fullPath; // Store full absolute path
            }

            using var context = DbFactory.CreateDbContext();
            if (editingEmployee == null)
            {
                context.employees.Add(employeeModel);
            }
            else
            {
                context.employees.Update(employeeModel);
            }

            await context.SaveChangesAsync();
            await LoadEmployees();
            HideForm();
        }
        catch (Exception ex)
        {
            errorMessage = "Error saving employee: " + ex.Message;
        }
        finally
        {
            isSubmitting = false;
        }
    }

    private async Task<string> GenerateEmployeeCode()
    {
        using var context = DbFactory.CreateDbContext();
        var lastCode = await context.employees
            .OrderByDescending(e => e.emp_code)
            .Select(e => e.emp_code)
            .FirstOrDefaultAsync();

        if (string.IsNullOrEmpty(lastCode)) return "1000001";

        if (long.TryParse(lastCode, out long codeValue))
        {
            return (codeValue + 1).ToString();
        }
        return "1000001";
    }

    private async Task DeleteEmployee(int id)
    {
        using var context = DbFactory.CreateDbContext();
        var emp = await context.employees.FindAsync(id);
        if (emp != null)
        {
            // Delete image file
            if (!string.IsNullOrEmpty(emp.image_path) && File.Exists(emp.image_path))
                try { File.Delete(emp.image_path); } catch { }

            context.employees.Remove(emp);
            await context.SaveChangesAsync();
            await LoadEmployees();
        }
    }
}
