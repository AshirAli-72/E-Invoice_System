@using E_Invoice_system.Models
@using E_Invoice_system.Data
@namespace E_Invoice_system.Components.Invoice
@using Microsoft.EntityFrameworkCore
@inject IDbContextFactory<ApplicationDbContext> DbFactory
@inject NavigationManager NavigationManager
@inject E_Invoice_system.Services.CurrencyService CurrencyService
@inject IJSRuntime JS

<style>
    .inv-panel { background:#fff; border-radius:16px; border:1px solid #e8edf3; box-shadow:0 4px 20px rgba(0,0,0,0.05); overflow:hidden; max-width:800px; }
    .inv-panel-header { background:linear-gradient(135deg,#BC1823 0%,#7f0d14 100%); padding:1.25rem 2rem; display:flex; align-items:center; gap:1rem; }
    .inv-panel-header h3 { color:white; font-size:1.2rem; font-weight:700; margin:0; }
    .inv-panel-header p { color:rgba(255,255,255,0.7); font-size:0.8rem; margin:0; }
    .inv-body { padding:2rem; }
    .inv-field { margin-bottom:1.2rem; }
    .inv-label { display:block; font-size:0.75rem; font-weight:700; color:#64748b; text-transform:uppercase; letter-spacing:0.6px; margin-bottom:0.4rem; }
    .inv-input { width:100%; padding:0.7rem 1rem; border-radius:9px; border:1.5px solid #e2e8f0; background:#f8fafc; font-size:0.92rem; color:#1e293b; transition:all 0.2s; outline:none; font-family:inherit; }
    .inv-input:focus { border-color:#BC1823; box-shadow:0 0 0 3px rgba(188,24,35,0.1); background:#fff; }
    .inv-select { appearance:auto; }
    .inv-divider { border:none; border-top:1px dashed #e2e8f0; margin:1.4rem 0; }
    .inv-section-label { font-size:0.75rem; font-weight:700; color:#BC1823; text-transform:uppercase; letter-spacing:0.8px; margin-bottom:1rem; display:flex; align-items:center; gap:0.5rem; }
    .add-row { display:flex; gap:0.75rem; align-items:flex-end; background:#f8fafc; padding:1rem; border-radius:10px; border:1px solid #e2e8f0; margin-bottom:1rem; }
    .add-row > div { flex:1; }
    .btn-add-item { height:44px; padding:0 1.5rem; background:#BC1823; color:white; border:none; border-radius:9px; font-weight:700; font-size:0.9rem; cursor:pointer; white-space:nowrap; display:flex; align-items:center; gap:0.4rem; flex-shrink:0; transition:all 0.2s; }
    .btn-add-item:hover:not(:disabled) { background:#9b141d; transform:translateY(-1px); }
    .btn-add-item:disabled { background:#94a3b8; cursor:not-allowed; transform:none; }
    .inv-table-wrap { border:1px solid #e8edf3; border-radius:12px; overflow:hidden; margin-bottom:1.5rem; }
    .inv-table { width:100%; border-collapse:collapse; }
    .inv-table th { background:#f8fafc; padding:0.75rem 1rem; text-align:left; font-size:0.72rem; font-weight:700; color:#64748b; text-transform:uppercase; letter-spacing:0.5px; border-bottom:2px solid #e8edf3; }
    .inv-table td { padding:0.75rem 1rem; border-bottom:1px solid #f1f5f9; vertical-align:middle; font-size:0.9rem; color:#1e293b; }
    .inv-table tr:last-child td { border-bottom:none; }
    .qty-stepper { display:flex; align-items:center; gap:5px; }
    .qty-btn { width:26px; height:26px; border-radius:6px; border:1px solid #e2e8f0; background:white; color:#BC1823; font-weight:900; cursor:pointer; font-size:1rem; display:flex; align-items:center; justify-content:center; transition:all 0.15s; }
    .qty-btn:hover { background:#BC1823; color:white; border-color:#BC1823; }
    .qty-display { width:36px; text-align:center; font-weight:700; color:#1e293b; }
    .totals-box { background:#f8fafc; border:1px solid #e2e8f0; border-radius:12px; padding:1.25rem; }
    .totals-row { display:flex; justify-content:space-between; align-items:center; padding:0.4rem 0; font-size:0.92rem; }
    .totals-final { font-size:1.2rem; font-weight:800; color:#BC1823; border-top:2px dashed #e2e8f0; padding-top:0.75rem; margin-top:0.5rem; }
    .discount-input { width:100px; padding:0.3rem 0.6rem; border-radius:6px; border:1px solid #e2e8f0; text-align:right; font-size:0.9rem; font-weight:600; background:white; }
    .btn-submit-inv { width:100%; padding:1rem; background:#BC1823; color:white; border:none; border-radius:10px; font-weight:700; font-size:1.05rem; cursor:pointer; display:flex; align-items:center; justify-content:center; gap:0.6rem; margin-top:1.25rem; transition:all 0.2s; box-shadow:0 4px 15px rgba(188,24,35,0.2); }
    .btn-submit-inv:hover:not(:disabled) { background:#9b141d; transform:translateY(-2px); box-shadow:0 8px 25px rgba(188,24,35,0.3); }
    .btn-submit-inv:disabled { background:#94a3b8; cursor:not-allowed; box-shadow:none; transform:none; }
    .toast-success { padding:0.6rem 0.9rem; background:#ecfdf5; color:#065f46; border:1px solid #a7f3d0; border-radius:8px; font-size:0.85rem; display:flex; align-items:center; gap:0.5rem; margin-bottom:0.75rem; }
    .toast-error { padding:0.6rem 0.9rem; background:#fef2f2; color:#991b1b; border:1px solid #fecaca; border-radius:8px; font-size:0.85rem; display:flex; align-items:center; gap:0.5rem; margin-bottom:0.75rem; }
    .empty-items { text-align:center; padding:3rem 1rem; color:#94a3b8; }
    .empty-items i { font-size:3rem; display:block; margin-bottom:0.75rem; opacity:0.25; }
    .not-ready-overlay { text-align:center; padding:1rem; color:#64748b; font-size:0.85rem; display:flex; align-items:center; gap:0.5rem; justify-content:center; }
</style>

<div class="inv-panel">
    <div class="inv-panel-header" style="display:flex; justify-content:space-between; align-items:center;">
        <div style="display:flex; align-items:center; gap:1rem;">
            <i class="ph-file-plus" style="font-size:2rem; color:white;"></i>
            <div>
                <h3>Create New Invoice</h3>
                <p>Fill in the details and add products below</p>
            </div>
        </div>
        <button type="button" onclick="document.getElementById('createInvModal').style.display='none'"
                style="background:rgba(255,255,255,0.15); border:none; color:white; width:36px; height:36px; border-radius:50%; display:flex; align-items:center; justify-content:center; cursor:pointer; font-size:1.2rem; transition: background 0.2s;"
                onmouseover="this.style.background='rgba(255,255,255,0.3)'"
                onmouseout="this.style.background='rgba(255,255,255,0.15)'">
            <i class="ph-x"></i>
        </button>
    </div>
    <div class="inv-body">

        <!-- Invoice Number -->
        <div class="inv-field">
            <label class="inv-label">Invoice Number</label>
            <input type="text" @bind="invoiceNo" class="inv-input" placeholder="Auto-generated if blank" />
        </div>
        <!-- Invoice Date -->
        <div class="inv-field">
            <label class="inv-label">Invoice Date</label>
            <input type="date" @bind="invoiceDate" @bind:format="yyyy-MM-dd" class="inv-input" />
        </div>
        <!-- Company -->
        <div class="inv-field">
            <label class="inv-label">Company / Seller Name</label>
            <input type="text" @bind="companyName" class="inv-input" placeholder="Your store name" />
        </div>
        <!-- Phone -->
        <div class="inv-field">
            <label class="inv-label">Seller Contact</label>
            <input type="text" @bind="companyPhone" class="inv-input" placeholder="Phone number" />
        </div>
        <!-- Customer -->
        <div class="inv-field">
            <label class="inv-label">
                Customer &nbsp;<span style="font-size:0.7rem;background:#f1f5f9;color:#94a3b8;padding:2px 8px;border-radius:20px;font-weight:500;text-transform:none;letter-spacing:0;">Optional</span>
            </label>
            <select class="inv-input inv-select" @onchange="OnCustomerChanged">
                <option value="0">-- Walk-In Customer --</option>
                @foreach (var c in customersList)
                {
                    <option value="@c.id">@c.name</option>
                }
            </select>
        </div>

        <!-- Customer Purchase History -->
        @if (selectedCustomer != null)
        {
            <div style="background:#f8fafc; border:1px solid #e2e8f0; border-radius:12px; padding:1.25rem; margin-bottom:1.2rem;">
                <div style="display:flex; justify-content:space-between; align-items:center; margin-bottom:0.75rem;">
                    <span style="font-size:0.75rem; font-weight:700; color:#BC1823; text-transform:uppercase; letter-spacing:0.6px; display:flex; align-items:center; gap:0.4rem;">
                        <i class="ph-clock-counter-clockwise" style="font-size:1rem;"></i> Customer Purchase History
                    </span>
                    <span style="font-size:0.75rem; color:#64748b; font-weight:600;">
                        @customerPreviousItems.Count item(s) found
                    </span>
                </div>
                
                @if (customerPreviousItems.Any())
                {
                    <div style="max-height:180px; overflow-y:auto; border:1px solid #edf2f7; border-radius:8px; background:white;">
                        <table style="width:100%; border-collapse:collapse; font-size:0.85rem;">
                            <thead>
                                <tr style="background:#f1f5f9; border-bottom:1px solid #e2e8f0; text-align:left;">
                                    <th style="padding:0.6rem 0.8rem; font-weight:600; color:#475569;">Item Name</th>
                                    <th style="padding:0.6rem 0.8rem; font-weight:600; color:#475569; text-align:right;">Last Price</th>
                                    <th style="padding:0.6rem 0.8rem; font-weight:600; color:#475569; text-align:center; width:70px;">Action</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var prevItem in customerPreviousItems)
                                {
                                    <tr style="border-bottom: 1px solid #f1f5f9;">
                                        <td style="padding:0.6rem 0.8rem; color:#1e293b; font-weight:500;">
                                            <div style="font-weight:600;">@prevItem.Name</div>
                                            <div style="font-size:0.72rem; color:#94a3b8; margin-top:2px;">Inv: #@prevItem.InvoiceNo | @prevItem.Date</div>
                                        </td>
                                        <td style="padding:0.6rem 0.8rem; color:#475569; font-weight:700; text-align:right;">
                                            @CurrencyService.GetSymbol()@prevItem.Price.ToString("N2")
                                        </td>
                                        <td style="padding:0.6rem 0.8rem; text-align:center;">
                                            <button type="button" @onclick="() => AddPreviousItem(prevItem)"
                                                    style="background:#fef2f2; color:#BC1823; border:1px solid #fecaca; border-radius:6px; padding:4px 8px; cursor:pointer; font-size:0.78rem; font-weight:700; display:inline-flex; align-items:center; gap:3px; transition:all 0.15s;"
                                                    onmouseover="this.style.background='#BC1823'; this.style.color='white'; this.style.borderColor='#BC1823';"
                                                    onmouseout="this.style.background='#fef2f2'; this.style.color='#BC1823'; this.style.borderColor='#fecaca';">
                                                <i class="ph-plus-bold"></i> Add
                                            </button>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }
                else
                {
                    <div style="font-size:0.8rem; color:#94a3b8; text-align:center; padding:1.25rem 0;">
                        No previous purchases found for this customer.
                    </div>
                }
            </div>
        }
        <!-- Payment -->
        <div class="inv-field">
            <label class="inv-label">Payment Method</label>
            <select @bind="paymentMethod" class="inv-input inv-select">
                <option value="Cash">Cash</option>
                <option value="Bank Transfer">Bank Transfer</option>
                <option value="Credit Card">Credit Card</option>
                <option value="Check">Check</option>
            </select>
        </div>
        <!-- Status -->
        <div class="inv-field">
            <label class="inv-label">Invoice Status</label>
            <select @bind="status" class="inv-input inv-select">
                <option value="Paid">Paid</option>
                <option value="Pending">Pending</option>
                <option value="Draft">Draft</option>
            </select>
        </div>

        <hr class="inv-divider" />

        <!-- Add Line Items -->
        <div class="inv-section-label">
            <i class="ph-shopping-cart"></i> Add Line Items
        </div>

        <div class="add-row">
            <div>
                <label class="inv-label">Select Product / Service</label>
                <select class="inv-input inv-select" value="@selectedProductId" @onchange="OnProductSelected">
                    <option value="0">-- Choose a product --</option>
                    @foreach (var p in GetFilteredProducts())
                    {
                        <option value="@p.id">@p.prod_name (@(p.item_type ?? "General"))</option>
                    }
                </select>
            </div>
            <button type="button" class="btn-add-item" @onclick="AddItem">
                <i class="ph-plus-bold"></i> Add Item
            </button>
        </div>

        <!-- Items Table -->
        @if (invoiceItems.Any())
        {
            <div class="inv-table-wrap">
                <table class="inv-table">
                    <thead>
                        <tr>
                            <th>#</th>
                            <th>Product / Service</th>
                            <th style="width:140px;text-align:center;">Qty</th>
                            <th style="width:110px;text-align:right;">Unit Price</th>
                            <th style="width:110px;text-align:right;">Total</th>
                            <th style="width:50px;"></th>
                        </tr>
                    </thead>
                    <tbody>
                        @{ int rowNum = 1; }
                        @foreach (var item in invoiceItems)
                        {
                            <tr>
                                <td style="color:#94a3b8;font-weight:600;">@rowNum</td>
                                <td>
                                    <div style="font-weight:600;color:#1e293b;">@item.Name</div>
                                    @if (!string.IsNullOrEmpty(item.ExpiryDate))
                                    {
                                        <div style="font-size:0.75rem;color:#94a3b8;">Exp: @item.ExpiryDate</div>
                                    }
                                </td>
                                <td style="text-align:center;">
                                    <div class="qty-stepper" style="justify-content:center;">
                                        <button type="button" class="qty-btn" @onclick="() => DecrementQty(item)">−</button>
                                        <span class="qty-display">@item.Qty</span>
                                        <button type="button" class="qty-btn" @onclick="() => IncrementQty(item)">+</button>
                                    </div>
                                </td>
                                <td style="text-align:right;color:#475569;font-weight:500;">
                                    @CurrencyService.GetSymbol()@item.Price.ToString("N2")
                                </td>
                                <td style="text-align:right;font-weight:700;color:#BC1823;">
                                    @CurrencyService.GetSymbol()@item.Total.ToString("N2")
                                </td>
                                <td style="text-align:center;">
                                    <button type="button" @onclick="() => RemoveItem(item)"
                                            style="background:#fef2f2;color:#ef4444;border:1px solid #fecaca;border-radius:6px;padding:4px 8px;cursor:pointer;font-size:0.85rem;">
                                        <i class="ph-trash"></i>
                                    </button>
                                </td>
                            </tr>
                            rowNum++;
                        }
                    </tbody>
                </table>
            </div>
        }
        else
        {
            <div class="empty-items">
                <i class="ph-receipt"></i>
                <div style="font-weight:600;font-size:0.95rem;color:#64748b;">No items added yet</div>
                <div style="font-size:0.82rem;margin-top:0.3rem;">Select a product and click <strong>Add Item</strong></div>
            </div>
        }

        <!-- Totals -->
        @if (invoiceItems.Any())
        {
            <div class="totals-box">
                <div class="totals-row">
                    <span style="color:#64748b;font-weight:500;">Subtotal</span>
                    <span style="font-weight:700;">@CurrencyService.GetSymbol()@subtotal.ToString("N2")</span>
                </div>
                <div class="totals-row">
                    <span style="color:#64748b;font-weight:500;">Discount</span>
                    <input type="number" min="0" @bind="discount" @bind:after="CalculateTotals" class="discount-input" />
                </div>
                <div class="totals-row totals-final">
                    <span>Total Amount</span>
                    <span>@CurrencyService.GetSymbol()@total.ToString("N2")</span>
                </div>
            </div>
        }

        <button type="button" class="btn-submit-inv" @onclick="SubmitInvoice" disabled="@isSubmitting">
            @if (isSubmitting)
            {
                <i class="ph-spinner ph-spin"></i><span>Saving Invoice...</span>
            }
            else
            {
                <i class="ph-check-circle"></i><span>Generate &amp; Save Invoice</span>
            }
        </button>
    </div>
</div>

@code {
    [Parameter] public string? UserName { get; set; }

    // ── Form ──────────────────────────────────────
    private string companyName = "";
    private string companyPhone = "";
    private string companyAddress = "";
    private string invoiceNo = "";
    private DateTime invoiceDate = DateTime.Now;

    // ── Customer ──────────────────────────────────
    private List<customers> customersList = new();
    private customers? selectedCustomer;

    // ── Products ──────────────────────────────────
    private List<ProductService> productsList = new();
    private int selectedProductId = 0;

    // ── Items ─────────────────────────────────────
    private List<InvoiceItem> invoiceItems = new();

    // ── Totals ────────────────────────────────────
    private decimal subtotal;
    private decimal discount;
    private decimal total;

    // ── Payment ───────────────────────────────────
    private string paymentMethod = "Cash";
    private string status = "Paid";

    // ── UI ────────────────────────────────────────
    private bool isSubmitting = false;

    // ── Init ──────────────────────────────────────
    protected override async Task OnInitializedAsync()
    {
        try
        {
            await CurrencyService.GetSymbolAsync();
            using var ctx = DbFactory.CreateDbContext();

            var cfg = await ctx.store_configurations.FirstOrDefaultAsync();
            companyName = cfg?.ShopName ?? "";
            companyPhone = cfg?.Phone1 ?? "";
            companyAddress = cfg?.Address ?? "";

            customersList = await ctx.customers.OrderBy(c => c.name).ToListAsync();

            var all = await ctx.products_services.ToListAsync();
            productsList = all
                .Where(p => !string.IsNullOrEmpty(p.status) &&
                            p.status.Trim().Equals("Enable", StringComparison.OrdinalIgnoreCase))
                .OrderBy(p => p.prod_name)
                .ToList();
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error loading initial data: {ex.Message}");
        }
    }

    // ── Customer ──────────────────────────────────
    private List<PreviousCustomerItem> customerPreviousItems = new();

    private async Task OnCustomerChanged(ChangeEventArgs e)
    {
        customerPreviousItems.Clear();
        if (int.TryParse(e.Value?.ToString(), out int id) && id > 0)
        {
            selectedCustomer = customersList.FirstOrDefault(c => c.id == id);
            if (selectedCustomer != null)
            {
                await LoadCustomerPreviousItems(selectedCustomer);
            }
        }
        else
        {
            selectedCustomer = null;
        }
    }

    private async Task LoadCustomerPreviousItems(customers customer)
    {
        try
        {
            using var ctx = DbFactory.CreateDbContext();
            var name = customer.name;
            var contact = customer.contact;

            var itemsList = new List<PreviousCustomerItem>();

            // Fetch only from POS Sales table (parsing structured description field) as requested
            var posSales = await ctx.sales
                .Where(s => s.description != null && 
                            (s.description.Contains("Contact: " + contact) || 
                             (s.description.Contains("Customer: " + name) && name != "Walk-In Customer")))
                .OrderByDescending(s => s.id)
                .Take(20)
                .ToListAsync();

            foreach (var sale in posSales)
            {
                if (!string.IsNullOrEmpty(sale.description))
                {
                    var parts = sale.description.Split(new[] { " | " }, StringSplitOptions.None);
                    if (parts.Length >= 3)
                    {
                        var prodName = parts[0];
                        var prod = productsList.FirstOrDefault(p => p.prod_name == prodName);
                        itemsList.Add(new PreviousCustomerItem
                        {
                            InvoiceNo = sale.billNo ?? sale.id.ToString(),
                            Date = sale.date,
                            ProductId = prod?.id ?? 0,
                            Name = prodName,
                            Price = sale.price,
                            Qty = (int)sale.qty,
                            ExpiryDate = sale.expiry_date ?? prod?.expiry_date
                        });
                    }
                }
            }

            // Sort chronologically and take top 10 items
            customerPreviousItems = itemsList
                .OrderByDescending(x => x.Date)
                .ThenByDescending(x => x.InvoiceNo)
                .Take(10)
                .ToList();
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error loading customer previous items: {ex.Message}");
        }
    }

    private void AddPreviousItem(PreviousCustomerItem prevItem)
    {
        var existingItem = invoiceItems.FirstOrDefault(i => 
            (prevItem.ProductId > 0 && i.ProductId == prevItem.ProductId) || 
            (prevItem.ProductId == 0 && i.Name == prevItem.Name));

        if (existingItem != null)
        {
            existingItem.Qty++;
            existingItem.Total = existingItem.Qty * existingItem.Price;
        }
        else
        {
            invoiceItems.Add(new InvoiceItem
            {
                ProductId = prevItem.ProductId,
                Name = prevItem.Name,
                Qty = 1,
                Price = prevItem.Price,
                ExpiryDate = prevItem.ExpiryDate,
                Total = prevItem.Price
            });
        }
        CalculateTotals();
        // Flasher notification removed as requested
    }

    public class PreviousCustomerItem
    {
        public string InvoiceNo { get; set; } = "";
        public string Date { get; set; } = "";
        public int ProductId { get; set; }
        public string Name { get; set; } = "";
        public decimal Price { get; set; }
        public int Qty { get; set; }
        public string? ExpiryDate { get; set; }
    }

    // ── Product Select ────────────────────────────
    private void OnProductSelected(ChangeEventArgs e)
    {
        if (int.TryParse(e.Value?.ToString(), out int id))
            selectedProductId = id;
        else
            selectedProductId = 0;
    }

    private List<ProductService> GetFilteredProducts()
    {
        if (selectedCustomer == null || !customerPreviousItems.Any())
        {
            return productsList;
        }

        var purchasedNames = customerPreviousItems
            .Select(item => item.Name.Trim().ToLower())
            .ToHashSet();

        var filtered = productsList
            .Where(p => p.prod_name != null && purchasedNames.Contains(p.prod_name.Trim().ToLower()))
            .ToList();

        if (!filtered.Any())
        {
            return productsList;
        }
        return filtered;
    }

    // ── Add Item ──────────────────────────────────
    // FIX: If same product exists, just increment qty instead of adding new row
    private async Task AddItem()
    {
        if (selectedProductId == 0)
        {
            _ = JS.InvokeVoidAsync("showToast", "Error", "Please select a product first.", "error");
            return;
        }

        var pid = selectedProductId;

        // Check if product already in list — if yes, just increment qty
        var existingItem = invoiceItems.FirstOrDefault(i => i.ProductId == pid);
        if (existingItem != null)
        {
            existingItem.Qty++;
            existingItem.Total = existingItem.Qty * existingItem.Price;
            CalculateTotals();
            // _ = JS.InvokeVoidAsync("showToast", "Success", $"Qty updated for \"{existingItem.Name}\".", "success");
            selectedProductId = 0;
            return;
        }

        using var ctx = DbFactory.CreateDbContext();
        var prod = await ctx.products_services.FirstOrDefaultAsync(p => p.id == pid);
        if (prod == null) { _ = JS.InvokeVoidAsync("showToast", "Error", "Product not found.", "error"); return; }

        var stock = await ctx.stock_details
            .Where(s => s.item_barcode == prod.barcode)
            .OrderByDescending(s => s.id)
            .FirstOrDefaultAsync();

        decimal unitPrice = stock?.sale_price ?? 0m;

        invoiceItems.Add(new InvoiceItem
        {
            ProductId  = pid,
            Name       = prod.prod_name ?? "Unknown",
            Qty        = 1,
            Price      = unitPrice,
            ExpiryDate = prod.expiry_date,
            Total      = unitPrice
        });

        CalculateTotals();
        // _ = JS.InvokeVoidAsync("showToast", "Success", $"\"{prod.prod_name}\" added!", "success");
        selectedProductId = 0;
    }

    // ── Qty ───────────────────────────────────────
    private void IncrementQty(InvoiceItem item) { item.Qty++; item.Total = item.Qty * item.Price; CalculateTotals(); }
    private void DecrementQty(InvoiceItem item) { if (item.Qty > 1) item.Qty--; item.Total = item.Qty * item.Price; CalculateTotals(); }

    private void CalculateTotals()
    {
        subtotal = invoiceItems.Sum(i => i.Total);
        total    = subtotal - discount;
        StateHasChanged();
    }

    private void RemoveItem(InvoiceItem item) { invoiceItems.Remove(item); CalculateTotals(); }

    private async Task SubmitInvoice()
    {
        if (!invoiceItems.Any()) { _ = JS.InvokeVoidAsync("showToast", "Error", "Please add at least one item.", "error"); return; }

        isSubmitting = true;
        try
        {
            using var ctx = DbFactory.CreateDbContext();
            var inv = new invoices
            {
                invoice_no       = string.IsNullOrWhiteSpace(invoiceNo) ? $"INV-{DateTime.Now:ddMMyyHHmm}" : invoiceNo,
                date             = invoiceDate.ToString("yyyy-MM-dd"),
                seller_name      = companyName,
                seller_contact   = companyPhone,
                seller_address   = companyAddress,
                customer_name    = selectedCustomer?.name ?? "Walk-In Customer",
                customer_contact = selectedCustomer?.contact,
                customer_address = selectedCustomer?.address,
                prod_name_service = string.Join(", ", invoiceItems.Select(i => i.Name)),
                qty_unit_type    = invoiceItems.Count == 1
                    ? invoiceItems[0].Qty.ToString()
                    : string.Join(", ", invoiceItems.Select(i => i.Qty.ToString())),
                price            = invoiceItems.Count == 1 ? invoiceItems[0].Price : subtotal,
                discount         = discount,
                total_price      = total,
                payment          = paymentMethod,
                status           = status
            };
            ctx.invoices.Add(inv);
            await ctx.SaveChangesAsync();

            await JS.InvokeVoidAsync("showToast", "Success", "Invoice has been saved successfully.", "success");
            await JS.InvokeVoidAsync("eval", "document.getElementById('createInvModal').style.display='none'");
            await Task.Delay(500);
            NavigationManager.NavigateTo("/Invoice?success=true", true);
        }
        catch (Exception ex)
        {
            _ = JS.InvokeVoidAsync("showToast", "Error", "Save failed: " + ex.Message, "error");
            isSubmitting = false;
        }
    }

    // ── Model ─────────────────────────────────────
    public class InvoiceItem
    {
        public int     ProductId  { get; set; }
        public string? Name       { get; set; }
        public int     Qty        { get; set; }
        public decimal Price      { get; set; }
        public string? ExpiryDate { get; set; }
        public decimal Total      { get; set; }
    }
}
