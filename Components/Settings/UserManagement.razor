@using E_Invoice_system.Models
@using E_Invoice_system.Data
@using Microsoft.EntityFrameworkCore
@inject IDbContextFactory<ApplicationDbContext> DbFactory
@inject NavigationManager Nav
@inject IJSRuntime JS
@using Microsoft.AspNetCore.Components.Web
@rendermode RenderMode.InteractiveServer

<div class="management-container @(showForm ? "modal-active" : "")">

    <div class="card card-no-padding">
        <div class="card-header card-header-flex" style="padding: 1.25rem 1.5rem;">
            <!-- Title -->
            <div style="display:flex; align-items:center; gap:0.6rem;">
                <i class="ph-users-three" style="font-size:1.3rem; color: var(--primary);"></i>
                <div class="card-title" style="margin: 0;">User Management</div>
            </div>
            <!-- Right: back + add buttons -->
            <div style="display:flex; align-items:center; gap:0.6rem;">
                <a href="/settings" class="btn-back-settings">
                    <i class="ph-arrow-left"></i> Back to Settings
                </a>
                <button class="btn-primary" @onclick="ShowAddForm" style="display: flex; align-items: center; gap: 8px; padding: 0.6rem 1.2rem; border: none; border-radius: 8px; background: var(--primary); color: white; font-weight: 600; cursor: pointer; font-size: 0.9rem;">
                    <i class="ph-user-plus"></i> Add New User
                </button>
            </div>
        </div>

        <div class="table-responsive">
            <table class="styled-table">
                <thead>
                    <tr>
                        <th style="padding-left: 1.5rem;">ID</th>
                        <th>Full Name</th>
                        <th>Email Address</th>
                        <th>Security Role</th>
                        <th>Status</th>
                        <th class="text-right" style="padding-right: 1.5rem;">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @if (userList.Count == 0)
                    {
                        <tr>
                            <td colspan="6" class="empty-state">
                                <i class="ph-users empty-state-icon"></i>
                                <p>No users found. Click <strong>Add New User</strong> to get started.</p>
                            </td>
                        </tr>
                    }
                    @foreach (var user in userList)
                    {
                        <tr>
                            <td class="font-bold" style="padding-left: 1.5rem;">#@user.id</td>
                            <td>
                                <div style="display:flex; align-items:center; gap:0.5rem;">
                                    <span class="user-avatar-chip">@(user.username?.Length > 0 ? user.username[0].ToString().ToUpper() : "?")</span>
                                    @user.username
                                </div>
                            </td>
                            <td class="text-muted" style="font-size:0.9rem;">@user.email</td>
                            <td>
                                <span class="role-badge">@user.role</span>
                            </td>
                            <td>
                                <span class="status-badge @(user.status == "Active" ? "status-active" : "status-inactive")">
                                    @(user.status ?? "Inactive")
                                </span>
                            </td>
                            <td class="text-right" style="padding-right: 1.5rem;">
                                <div class="actions-container actions-right">
                                    <button class="btn-icon-sm btn-edit" @onclick="() => EditUser(user)" title="Edit">
                                        <i class="ph-pencil"></i>
                                    </button>
                                    <button class="btn-icon-sm btn-delete" @onclick="() => DeleteUser(user.id)" title="Delete">
                                        <i class="ph-trash"></i>
                                    </button>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

@if (showForm)
{
    <div class="modal-overlay">
        <div class="modal-content">
            <div class="card" style="margin-bottom: 0; border: none;">
                <div class="card-header card-header-flex">
                    <div class="form-section-title">
                        <i class="ph-user @(editingUser == null ? "form-icon-primary" : "")"></i>
                        @(editingUser == null ? "Add New User" : "Edit User Account")
                    </div>
                    <button type="button" class="btn-icon-sm" @onclick="HideForm" style="border: none; background: transparent;"><i class="ph-x" style="font-size: 1.25rem;"></i></button>
                </div>

                <EditForm Model="userModel" OnValidSubmit="SaveUser">
                    <DataAnnotationsValidator />
                    
                    <div style="padding: 0 1.5rem 1.5rem 1.5rem;">
                        <div class="form-group" style="margin-bottom: 1rem;">
                            <label class="form-label">Full Name / Display Name</label>
                            <InputText @bind-Value="userModel.username" class="form-control" placeholder="e.g. John Doe or Manager1" />
                            <ValidationMessage For="@(() => userModel.username)" />
                        </div>

                        <div class="form-group" style="margin-bottom: 1rem;">
                            <label class="form-label">Email Address</label>
                            <InputText @bind-Value="userModel.email" class="form-control" placeholder="Enter user's email address" />
                            <ValidationMessage For="@(() => userModel.email)" />
                        </div>

                        <div class="form-group" style="margin-bottom: 1rem;">
                            <label class="form-label">Account Password</label>
                            <InputText @bind-Value="userModel.password" type="password" class="form-control" placeholder="••••••••" />
                            <ValidationMessage For="@(() => userModel.password)" />
                        </div>

                        <div class="form-grid" style="grid-template-columns: 1fr 1fr; gap: 1rem; margin-bottom: 1.5rem;">
                            <div class="form-group">
                                <label class="form-label">Role</label>
                                <input type="text" list="rolesDataList" @bind="userModel.role" class="form-control" placeholder="Select or type role..." />
                                <datalist id="rolesDataList">
                                    @foreach (var role in rolesList)
                                    {
                                        <option value="@role.RoleTitle">@role.RoleTitle</option>
                                    }
                                </datalist>
                            </div>
                            <div class="form-group">
                                <label class="form-label">Account Status</label>
                                <select @bind="userModel.status" class="form-control">
                                    <option value="Active">Active</option>
                                    <option value="Inactive">Inactive</option>
                                </select>
                            </div>
                        </div>

                        <div style="display: flex; justify-content: flex-end; gap: 0.75rem; padding-top: 0.75rem; border-top: 1px solid #f1f5f9;">
                            @if (editingUser != null)
                            {
                                <button type="button" @onclick="() => DeleteUser(editingUser.id)" class="btn-delete" style="display:inline-flex; align-items:center; gap:0.4rem; padding: 0.6rem 1.2rem; border-radius: 8px; border: none; background: #fee2e2; color: #dc2626; font-weight: 600; cursor:pointer; font-size:0.9rem;" disabled="@isSubmitting">
                                    <i class="ph-trash"></i> Delete
                                </button>
                            }
                            <button type="button" @onclick="HideForm" style="display:inline-flex; align-items:center; gap:0.4rem; background: #f1f5f9; color: #475569; padding: 0.6rem 1.2rem; border-radius: 8px; border: 1px solid #e2e8f0; font-weight: 600; cursor:pointer; font-size:0.9rem;" disabled="@isSubmitting"><i class="ph-x"></i> Cancel</button>
                            <button type="button" @onclick="SaveUser" style="display:inline-flex; align-items:center; gap:0.4rem; padding: 0.6rem 1.4rem; border: none; border-radius: 8px; background: var(--primary, #BC1823); color: white; font-weight: 600; cursor: pointer; font-size:0.9rem; transition:all 0.2s;" disabled="@isSubmitting">
                                @if (isSubmitting)
                                {
                                    <i class="ph-spinner ph-spin"></i>
                                }
                                else
                                {
                                    <i class="ph-check"></i>
                                }
                                <span>@(editingUser == null ? "Save User" : "Update User")</span>
                            </button>
                        </div>
                    </div>
                </EditForm>
            </div>
        </div>
    </div>
}

<style>
    .management-container {
        position: relative;
    }

    .modal-active .card {
        pointer-events: none;
        opacity: 0.7;
        transition: all 0.3s ease;
    }

    /* Back button — top right of card header */
    .btn-back-settings {
        display: inline-flex;
        align-items: center;
        gap: 6px;
        padding: 0.45rem 1rem;
        background: #f1f5f9;
        border: 1px solid #e2e8f0;
        border-radius: 8px;
        color: #475569;
        font-weight: 600;
        font-size: 0.82rem;
        text-decoration: none;
        white-space: nowrap;
        transition: all 0.2s;
    }

    .btn-back-settings:hover {
        background: var(--primary, #BC1823);
        border-color: var(--primary, #BC1823);
        color: white;
    }

    .styled-table tbody tr {
        transition: all 0.2s ease;
    }

    .styled-table tbody tr:hover {
        background-color: #fff5f6 !important;
    }

    /* User avatar chip in table */
    .user-avatar-chip {
        width: 30px;
        height: 30px;
        min-width: 30px;
        background: var(--primary, #BC1823);
        color: white;
        border-radius: 50%;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        font-size: 0.75rem;
        font-weight: 700;
    }

    /* Role badge */
    .role-badge {
        display: inline-block;
        padding: 3px 10px;
        background: #fff5f6;
        color: var(--primary, #BC1823);
        border: 1px solid #fecdd3;
        border-radius: 20px;
        font-size: 0.78rem;
        font-weight: 700;
        letter-spacing: 0.02em;
    }

    .modal-overlay {
        position: fixed;
        top: 0;
        left: 0;
        width: 100%;
        height: 100%;
        background: rgba(15, 23, 42, 0.45);
        display: flex;
        align-items: center;
        justify-content: center;
        z-index: 1000;
        animation: modalFadeIn 0.2s ease;
    }

    .modal-content {
        background: white;
        padding: 0;
        border-radius: 16px;
        width: 100%;
        max-width: 500px;
        box-shadow: 0 20px 40px rgba(0, 0, 0, 0.15);
        animation: modalScaleIn 0.28s cubic-bezier(0.34, 1.56, 0.64, 1);
    }

    .modal-content .card-header {
        background: linear-gradient(135deg, #fff5f6 0%, #fff 100%);
        border-bottom: 1px solid #f1f5f9;
        border-radius: 16px 16px 0 0;
    }

    @@keyframes modalFadeIn { from { opacity: 0; } to { opacity: 1; } }
    @@keyframes modalScaleIn { from { transform: scale(0.95); opacity: 0; } to { transform: scale(1); opacity: 1; } }
</style>

@code {
    private List<users> userList = new();
    private users userModel = new();
    private bool showForm = false;
    private users? editingUser = null;
    private List<Role> rolesList = new();
    private bool isSubmitting = false;

    protected override async Task OnInitializedAsync()
    {
        await LoadRoles();
        await LoadUsers();
    }

    private async Task LoadRoles()
    {
        try
        {
            using var context = DbFactory.CreateDbContext();
            rolesList = await context.roles.OrderBy(r => r.Id).ToListAsync();
        }
        catch { }
    }

    private async Task LoadUsers()
    {
        using var context = DbFactory.CreateDbContext();
        userList = await context.users.ToListAsync();
        await InvokeAsync(StateHasChanged);
    }

    private async Task ShowAddForm()
    {
        await LoadRoles();
        userModel = new users { status = "Active", role = rolesList.FirstOrDefault()?.RoleTitle ?? "" };
        editingUser = null;
        showForm = true;
    }

    private async Task EditUser(users user)
    {
        await LoadRoles();
        editingUser = user;
        userModel = new users
        {
            id = user.id,
            email = user.email,
            username = user.username,
            password = user.password,
            role = user.role,
            status = user.status
        };
        showForm = true;
    }

    private void HideForm()
    {
        showForm = false;
    }

    private async Task SaveUser()
    {
        if (isSubmitting) return;
        isSubmitting = true;
        try {
            using var context = DbFactory.CreateDbContext();
            if (editingUser == null)
            {
                context.users.Add(userModel);
            }
            else
            {
                context.users.Update(userModel);
            }
            await context.SaveChangesAsync();
            await LoadUsers();
            HideForm();
        } finally {
            isSubmitting = false;
            await InvokeAsync(StateHasChanged);
        }
    }

    private async Task DeleteUser(int id)
    {
        if (isSubmitting) return;
        if (!await JS.InvokeAsync<bool>("confirm", $"Are you sure you want to delete this user?")) return;
        
        isSubmitting = true;
        try {
            using var context = DbFactory.CreateDbContext();
            var user = await context.users.FindAsync(id);
            if (user != null)
            {
                context.users.Remove(user);
                await context.SaveChangesAsync();
                await LoadUsers();
                if (showForm) HideForm();
            }
        } finally {
            isSubmitting = false;
            await InvokeAsync(StateHasChanged);
        }
    }
}
