@using E_Invoice_system.Models
@using E_Invoice_system.Data
@using Microsoft.EntityFrameworkCore
@inject IDbContextFactory<ApplicationDbContext> DbFactory
@inject NavigationManager Nav
@using Microsoft.AspNetCore.Components.Web
@rendermode RenderMode.InteractiveServer

<div class="management-container">
    @if (!showForm)
    {
        <a href="/settings" class="btn-back-hub">
            <i class="ph-arrow-left"></i> Back to Settings
        </a>

        <div class="card card-no-padding">
            <div class="card-header card-header-flex" style="padding: 1.5rem 1.5rem 0 1.5rem;">
                <div class="form-section-title" style="margin: 0; font-size: 1.25rem;">User Management</div>
                <button class="btn-primary" @onclick="ShowAddForm" style="display: flex; align-items: center; gap: 8px; padding: 0.6rem 1.2rem; border: none; border-radius: 8px; background: var(--primary); color: white; font-weight: 600; cursor: pointer;">
                    <i class="ph-user-plus"></i> Add New User
                </button>
            </div>

            <div class="table-responsive">
                <table class="styled-table">
                    <thead>
                        <tr>
                            <th style="padding-left: 1.5rem;">ID</th>
                            <th>Email Address</th>
                            <th>Authentication Status</th>
                            <th class="text-right" style="padding-right: 1.5rem;">Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var user in userList)
                        {
                            <tr>
                                <td class="font-bold" style="padding-left: 1.5rem;">@user.id</td>
                                <td>@user.email</td>
                                <td>
                                    <span class="status-badge @(user.status == "Active" ? "status-active" : "status-inactive")">
                                        @(user.status ?? "Inactive")
                                    </span>
                                </td>
                                <td class="text-right" style="padding-right: 1.5rem;">
                                    <div class="actions-container actions-right">
                                        <button class="btn-icon-sm btn-edit" @onclick="() => EditUser(user)" title="Edit">
                                            <i class="ph-pencil"></i>
                                        </button>
                                        <button class="btn-icon-sm btn-delete" @onclick="() => DeleteUser(user.id)" title="Delete">
                                            <i class="ph-trash"></i>
                                        </button>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    }
    else
    {
        <div class="form-wrapper">
            <div class="form-section-header">
                <h3 class="form-section-title">
                    <i class="ph-user form-icon-primary"></i>
                    @(editingUser == null ? "User Information" : "Edit User Account")
                </h3>
            </div>

            <EditForm Model="userModel" OnValidSubmit="SaveUser">
                <DataAnnotationsValidator />
                
                <div class="form-section">
                    <div class="form-group" style="margin-bottom: 1.5rem;">
                        <label class="form-label">Email Address</label>
                        <InputText @bind-Value="userModel.email" class="form-control" placeholder="Enter user's email address" />
                        <ValidationMessage For="@(() => userModel.email)" />
                    </div>

                    <div class="form-group" style="margin-bottom: 1.5rem;">
                        <label class="form-label">Account Password</label>
                        <InputText @bind-Value="userModel.password" type="password" class="form-control" placeholder="••••••••" />
                        <ValidationMessage For="@(() => userModel.password)" />
                    </div>

                    <div class="form-group">
                        <label class="form-label">Account Status</label>
                        <select @bind="userModel.status" class="form-control">
                            <option value="Active">Active</option>
                            <option value="Inactive">Inactive</option>
                        </select>
                    </div>
                </div>

                <div class="form-actions-sticky">
                    <button type="button" class="btn-icon-sm" @onclick="HideForm" style="background: #f1f5f9; color: #475569; padding: 0.75rem 1.5rem; border-radius: 8px; border: 1px solid #e2e8f0; font-weight: 600;">
                        Cancel
                    </button>
                    <button type="submit" class="btn-primary" style="padding: 0.75rem 1.5rem; border: none; border-radius: 8px; background: var(--primary); color: white; font-weight: 600; cursor: pointer;">
                        <i class="ph-check"></i> @(editingUser == null ? "Save User Account" : "Update User Account")
                    </button>
                </div>
            </EditForm>
        </div>
    }
</div>

@code {
    private List<users> userList = new();
    private users userModel = new();
    private bool showForm = false;
    private users? editingUser = null;

    protected override async Task OnInitializedAsync()
    {
        await LoadUsers();
    }

    private async Task LoadUsers()
    {
        using var context = DbFactory.CreateDbContext();
        userList = await context.users.ToListAsync();
    }

    private void ShowAddForm()
    {
        userModel = new users { status = "Active" };
        editingUser = null;
        showForm = true;
    }

    private void EditUser(users user)
    {
        editingUser = user;
        userModel = new users
        {
            id = user.id,
            email = user.email,
            password = user.password,
            status = user.status
        };
        showForm = true;
    }

    private void HideForm()
    {
        showForm = false;
    }

    private async Task SaveUser()
    {
        using var context = DbFactory.CreateDbContext();
        if (editingUser == null)
        {
            context.users.Add(userModel);
        }
        else
        {
            context.users.Update(userModel);
        }
        await context.SaveChangesAsync();
        await LoadUsers();
        HideForm();
    }

    private async Task DeleteUser(int id)
    {
        using var context = DbFactory.CreateDbContext();
        var user = await context.users.FindAsync(id);
        if (user != null)
        {
            context.users.Remove(user);
            await context.SaveChangesAsync();
            await LoadUsers();
        }
    }
}
