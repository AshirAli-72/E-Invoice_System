@using E_Invoice_system.Models
@using E_Invoice_system.Data
@using Microsoft.EntityFrameworkCore
@inject IDbContextFactory<ApplicationDbContext> DbFactory
@inject NavigationManager Nav
@using Microsoft.AspNetCore.Components.Web
@rendermode RenderMode.InteractiveServer

<div class="management-container">
    @if (!showForm)
    {
        <a href="/settings" class="btn-back-hub">
            <i class="ph-arrow-left"></i> Back to Settings
        </a>

        @* Quick Search & Add Row *@
        <div class="quick-action-row animate-in">
            <div class="search-input-group">
                <input type="text" list="currency-options" @bind="searchQuery" @bind:event="oninput" class="search-field" placeholder="Search country or currency code (e.g. Saudi Arabia, USD)..." @onkeydown="@(e => { if (e.Key == "Enter") QuickAddCurrency(); })" />
                <datalist id="currency-options">
                    @foreach (var gc in globalCurrencies)
                    {
                        <option value="@($"{gc.name} ({gc.code})")">@gc.country</option>
                    }
                </datalist>
                <button type="button" class="btn-select-add" @onclick="QuickAddCurrency" disabled="@isProcessing">
                    <i class="ph-check-square"></i> Select & Add
                </button>
            </div>
            <button type="button" class="btn-primary" @onclick="ShowAddForm" disabled="@isProcessing" style="white-space: nowrap; padding: 0.75rem 1.5rem; border: none; border-radius: 8px; background: var(--primary); color: white; font-weight: 700; cursor: pointer;">
                <i class="ph-plus-circle"></i> Add Custom
            </button>
        </div>

        <div class="card card-no-padding">
            <div class="card-header card-header-flex" style="padding: 1.5rem 1.5rem 0 1.5rem;">
                <div class="card-title" style="margin: 0;">System Currencies</div>
            </div>

            <div class="table-responsive">
                <table class="styled-table" style="table-layout: fixed;">
                        <thead>
                            <tr>
                                <th style="padding-left: 1.5rem; width: 14.28%;">Name</th>
                                <th style="width: 14.28%;">ISO Code</th>
                                <th style="width: 14.28%;">Symbol</th>
                                <th style="width: 14.28%;">Rate</th>
                                <th style="width: 14.28%;">Status</th>
                                <th style="text-align: center; width: 14.28%;">Action</th>
                                <th style="text-align: right; padding-right: 1.5rem; width: 14.28%;">Is Active</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var curr in currencyList)
                            {
                                <tr class="@(curr.is_active ? "active-currency-row" : "")">
                                    <td style="padding-left: 1.5rem;" class="font-bold">@curr.name</td>
                                    <td>
                                        <span class="badge badge-light">@curr.code</span>
                                    </td>
                                    <td style="color: #BC1823; font-weight: 700;">@curr.symbol</td>
                                    <td class="text-muted">@curr.exchange_rate.ToString("F2")</td>
                                    <td>
                                        @if (curr.status == "Active")
                                        {
                                            <span class="status-badge status-active">Active</span>
                                        }
                                        else
                                        {
                                            <span class="status-badge status-inactive" style="background: #f1f5f9; color: #64748b;">Inactive</span>
                                        }
                                    </td>
                                    <td style="text-align: center;">
                                        <div style="display: flex; gap: 0.5rem; justify-content: center;">
                                            <button class="action-btn" @onclick="() => EditCurrency(curr)" title="Edit">
                                                <i class="ph-pencil-simple"></i>
                                            </button>
                                            <button class="action-btn delete" @onclick="() => DeleteCurrency(curr.id)" title="Delete">
                                                <i class="ph-trash"></i>
                                            </button>
                                        </div>
                                    </td>
                                    <td style="text-align: right; padding-right: 1.5rem;">
                                        @if (curr.is_active)
                                        {
                                            <span class="status-badge" style="background: #059669; color: #ffffff; font-weight: 700;">Active Base</span>
                                        }
                                        else
                                        {
                                            <button class="status-badge" @onclick="() => SetActiveCurrency(curr.id)" 
                                                    style="background: #1e1b4b; border: 1px solid #1e1b4b; color: #ffffff; cursor: pointer; font-weight: 700; padding: 0.4rem 0.8rem;">
                                                Select as Base
                                            </button>
                                        }
                                    </td>
                                </tr>
                            }
                            @if (!currencyList.Any())
                            {
                                <tr>
                                    <td colspan="7" style="padding: 3rem; text-align: center; color: #64748b;">
                                        <i class="ph-currency-circle-dollar" style="font-size: 2.5rem; display: block; margin-bottom: 1rem; opacity: 0.2;"></i>
                                        <p style="font-weight: 600;">No currencies found. Search and select above to add.</p>
                                    </td>
                                </tr>
                            }
                        </tbody>
                </table>
            </div>
        </div>
    }
</div>

@if (showForm)
{
    @* Modal Pop-up for Custom/Edit *@
    <div class="modal-overlay">
        <div class="modal-content">
            <div class="card" style="margin-bottom: 0; border: none;">
                <div class="card-header card-header-flex">
                    <div class="form-section-title">@(editingCurrency == null ? "Custom Currency" : "Edit Currency")</div>
                    <button type="button" class="btn-icon-sm" @onclick="HideForm" style="border: none; background: transparent;"><i class="ph-x" style="font-size: 1.25rem;"></i></button>
                </div>
                
                <EditForm Model="currencyModel" OnValidSubmit="SaveCurrency">
                    <DataAnnotationsValidator />
                    <div style="padding: 0 1.5rem 1.5rem 1.5rem;">
                        <div class="form-group" style="margin-bottom: 1rem;">
                            <label class="form-label">Currency Name</label>
                            <InputText @bind-Value="currencyModel.name" class="form-control" placeholder="e.g. US Dollar" />
                        </div>
                        <div class="form-grid" style="grid-template-columns: 1fr 1fr; gap: 1rem; margin-bottom: 1rem;">
                            <div class="form-group">
                                <label class="form-label">ISO Code</label>
                                <InputText @bind-Value="currencyModel.code" class="form-control" placeholder="e.g. USD" />
                            </div>
                            <div class="form-group">
                                <label class="form-label">Symbol</label>
                                <InputText @bind-Value="currencyModel.symbol" class="form-control" placeholder="e.g. $" />
                            </div>
                        </div>
                        <div class="form-group" style="margin-bottom: 1.5rem;">
                            <label class="form-label">Exchange Rate (to Base)</label>
                            <InputNumber @bind-Value="currencyModel.exchange_rate" class="form-control" step="0.01" />
                        </div>
                        
                        <div style="display: flex; justify-content: flex-end; gap: 1rem;">
                            <button type="button" class="btn-icon-sm" @onclick="HideForm" style="background: #f1f5f9; color: #475569; padding: 0.6rem 1.2rem; border-radius: 8px; border: 1px solid #e2e8f0; font-weight: 600;">Cancel</button>
                            <button type="submit" class="btn-primary" disabled="@isProcessing" style="padding: 0.6rem 1.25rem; border: none; border-radius: 8px; background: var(--primary); color: white; font-weight: 600; cursor: pointer;">
                                @(isProcessing ? "Saving..." : "Save Currency")
                            </button>
                        </div>
                    </div>
                </EditForm>
            </div>
        </div>
    </div>
}

<style>
    .active-currency-row {
        background-color: #fdf2f2 !important;
    }
</style>

@code {
    private List<Currency> currencyList = new();
    private Currency currencyModel = new();
    private bool showForm = false;
    private Currency? editingCurrency = null;
    private string searchQuery = "";
    private bool isProcessing = false;

    private class GlobalCurrency { public string country; public string name; public string code; public string symbol; }
    private List<GlobalCurrency> globalCurrencies = new()
    {
        new() { country = "United States", name = "US Dollar", code = "USD", symbol = "$" },
        new() { country = "European Union", name = "Euro", code = "EUR", symbol = "€" },
        new() { country = "United Kingdom", name = "British Pound", code = "GBP", symbol = "£" },
        new() { country = "Saudi Arabia", name = "Saudi Riyal", code = "SAR", symbol = "SR" },
        new() { country = "United Arab Emirates", name = "UAE Dirham", code = "AED", symbol = "DH" },
        new() { country = "Pakistan", name = "Pakistani Rupee", code = "PKR", symbol = "Rs" },
        new() { country = "India", name = "Indian Rupee", code = "INR", symbol = "₹" },
        new() { country = "China", name = "Chinese Yuan", code = "CNY", symbol = "¥" },
        new() { country = "Japan", name = "Japanese Yen", code = "JPY", symbol = "¥" },
        new() { country = "Turkey", name = "Turkish Lira", code = "TRY", symbol = "₺" },
        new() { country = "Canada", name = "Canadian Dollar", code = "CAD", symbol = "$" },
        new() { country = "Australia", name = "Australian Dollar", code = "AUD", symbol = "$" },
        new() { country = "Kuwait", name = "Kuwaiti Dinar", code = "KWD", symbol = "KD" },
        new() { country = "Oman", name = "Omani Rial", code = "OMR", symbol = "RO" },
        new() { country = "Qatar", name = "Qatari Rial", code = "QAR", symbol = "QR" },
        new() { country = "Bahrain", name = "Bahraini Dinar", code = "BHD", symbol = "BD" }
    };

    protected override async Task OnInitializedAsync()
    {
        await LoadCurrencies();
    }

    private async Task LoadCurrencies()
    {
        try
        {
            using var context = DbFactory.CreateDbContext();
            currencyList = await context.currencies.OrderByDescending(c => c.is_active).ThenBy(c => c.name).ToListAsync();
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error loading currencies: {ex.Message}");
        }
    }

    private void ShowAddForm()
    {
        currencyModel = new Currency { exchange_rate = 1.0m };
        editingCurrency = null;
        showForm = true;
    }

    private async Task QuickAddCurrency()
    {
        if (string.IsNullOrWhiteSpace(searchQuery) || isProcessing) return;
        isProcessing = true;
        
        // Robust extraction...
        string code = "";
        var openBracket = searchQuery.LastIndexOf('(');
        var closeBracket = searchQuery.LastIndexOf(')');
        
        if (openBracket != -1 && closeBracket > openBracket)
        {
            code = searchQuery.Substring(openBracket + 1, closeBracket - openBracket - 1).Trim();
        }
        else
        {
            code = searchQuery.Trim();
        }

        var queryTrim = searchQuery.Trim();
        var match = globalCurrencies.FirstOrDefault(c => 
            string.Equals(c.code, code, StringComparison.OrdinalIgnoreCase) || 
            string.Equals(c.name, queryTrim, StringComparison.OrdinalIgnoreCase) ||
            string.Equals(queryTrim, $"{c.name} ({c.code})", StringComparison.OrdinalIgnoreCase));

        try
        {
            if (match != null)
            {
                using var context = DbFactory.CreateDbContext();
                var existing = await context.currencies.FirstOrDefaultAsync(c => c.code == match.code);
                
                if (existing == null)
                {
                    var newCurrency = new Currency 
                    { 
                        name = match.name, 
                        code = match.code, 
                        symbol = match.symbol, 
                        exchange_rate = 1.0m,
                        status = "Active",
                        is_active = true // Auto select as active base
                    };
                    
                    // Set all others to Inactive Base
                    var all = await context.currencies.ToListAsync();
                    foreach (var c in all) c.is_active = false;
                    
                    context.currencies.Add(newCurrency);
                    await context.SaveChangesAsync();
                }
                else
                {
                    // If it already exists, just make it the active base
                    var all = await context.currencies.ToListAsync();
                    foreach (var c in all)
                    {
                        c.is_active = (c.id == existing.id);
                        if (c.is_active) c.status = "Active";
                    }
                    await context.SaveChangesAsync();
                }
                
                await LoadCurrencies();
                searchQuery = "";
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine($"QuickAdd Error: {ex.Message}");
        }
        finally
        {
            isProcessing = false;
            StateHasChanged();
        }
    }

    private async Task SetActiveCurrency(int id)
    {
        using var context = DbFactory.CreateDbContext();
        var all = await context.currencies.ToListAsync();
        foreach (var c in all)
        {
            c.is_active = (c.id == id);
            if (c.is_active) c.status = "Active"; // Ensure base currency is always Active status
        }
        await context.SaveChangesAsync();
        await LoadCurrencies();
    }

    private void EditCurrency(Currency curr)
    {
        editingCurrency = curr;
        currencyModel = new Currency
        {
            id = curr.id,
            name = curr.name,
            code = curr.code,
            symbol = curr.symbol,
            exchange_rate = curr.exchange_rate,
            status = curr.status
        };
        showForm = true;
    }

    private void HideForm()
    {
        showForm = false;
    }

    private async Task SaveCurrency()
    {
        if (isProcessing) return;
        isProcessing = true;
        try
        {
            using var context = DbFactory.CreateDbContext();
            if (editingCurrency == null)
            {
                currencyModel.status = "Active"; // Default to Active for new custom ones
                currencyModel.is_active = false; // Default to normal currency
                context.currencies.Add(currencyModel);
            }
            else
            {
                context.currencies.Update(currencyModel);
            }
            await context.SaveChangesAsync();
            await LoadCurrencies();
            HideForm();
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Save Error: {ex.Message}");
        }
        finally
        {
            isProcessing = false;
            StateHasChanged();
        }
    }

    private async Task DeleteCurrency(int id)
    {
        using var context = DbFactory.CreateDbContext();
        var curr = await context.currencies.FindAsync(id);
        if (curr != null)
        {
            context.currencies.Remove(curr);
            await context.SaveChangesAsync();
            await LoadCurrencies();
        }
    }
}
