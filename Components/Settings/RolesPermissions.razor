@using E_Invoice_system.Models
@using E_Invoice_system.Data
@using Microsoft.EntityFrameworkCore
@using System.Text.Json
@inject IDbContextFactory<ApplicationDbContext> DbFactory
@rendermode RenderMode.InteractiveServer

<div class="card card-no-padding" style="border: 1px solid #e2e8f0; background: #fff; border-radius: 12px; box-shadow: 0 4px 6px -1px rgba(0,0,0,0.05);">
    <div class="card-header card-header-flex" style="padding: 1.5rem; border-bottom: 1px solid #f1f5f9;">
        <div style="display:flex; align-items:center; gap:0.6rem;">
            <i class="ph-shield-check" style="font-size:1.3rem; color: var(--primary);"></i>
            <div class="card-title" style="margin: 0;">Roles &amp; Permissions</div>
        </div>
        <a href="/settings" class="btn-back-hub" style="margin: 0;">
            <i class="ph-arrow-left"></i> Back to Settings
        </a>
    </div>

    <div style="padding: 1.5rem;">
        <p class="rp-subtitle" style="margin-bottom: 1.5rem;">Control access and feature visibility per user role</p>

    <!-- Top Role Selector Bar -->
    <div class="rp-topbar">
        <div class="rp-role-group">
            <label class="rp-role-label">Select Role:</label>
            <div class="rp-role-select-wrapper">
                <select class="rp-role-select" @onchange="OnRoleChangedInternal">
                    @foreach (var role in rolesList)
                    {
                        <option value="@role.RoleTitle" selected="@(role.RoleTitle == selectedRole)">@role.RoleTitle</option>
                    }
                </select>
            </div>
            
            <div class="rp-role-controls">
                <button class="rp-control-btn btn-add" @onclick="OpenAddRoleModal" title="Manage Roles">
                    <i class="ph-plus" style="font-weight:bold; font-size: 1.2rem;"></i>
                </button>
            </div>
        </div>
    </div>

    @if (!string.IsNullOrEmpty(successMessage))
    {
        <div class="rp-alert rp-alert-success">
            <i class="ph-check-circle"></i> @successMessage
        </div>
    }
    @if (!string.IsNullOrEmpty(errorMessage))
    {
        <div class="rp-alert rp-alert-error">
            <i class="ph-warning-circle"></i> @errorMessage
        </div>
    }

    <!-- SECTION 1: SYSTEM AUTHORITIES -->
    <div class="rp-section">
        <div class="rp-section-header">
            <span class="rp-section-title">SYSTEM AUTHORITIES:</span>
            <input type="checkbox" class="rp-check-all" title="Select/Deselect All"
                   checked="@AllSystemChecked"
                   @onchange="ToggleAllSystem" />
        </div>
        <div class="rp-check-grid">
            <label class="rp-check-item">
                <input type="checkbox" @bind="currentPermissions.Dashboard" />
                <span class="rp-check-box @(currentPermissions.Dashboard ? "checked" : "")">
                    @if (currentPermissions.Dashboard) { <i class="ph-check-bold"></i> }
                </span>
                <span class="rp-check-label">Dashboard</span>
            </label>
            <label class="rp-check-item">
                <input type="checkbox" @bind="currentPermissions.Customers" />
                <span class="rp-check-box @(currentPermissions.Customers ? "checked" : "")">
                    @if (currentPermissions.Customers) { <i class="ph-check-bold"></i> }
                </span>
                <span class="rp-check-label">Customers</span>
            </label>
            <label class="rp-check-item">
                <input type="checkbox" @bind="currentPermissions.Products" />
                <span class="rp-check-box @(currentPermissions.Products ? "checked" : "")">
                    @if (currentPermissions.Products) { <i class="ph-check-bold"></i> }
                </span>
                <span class="rp-check-label">Products</span>
            </label>
             <label class="rp-check-item">
                <input type="checkbox" @bind="currentPermissions.Sales" />
                <span class="rp-check-box @(currentPermissions.Sales ? "checked" : "")">
                    @if (currentPermissions.Sales) { <i class="ph-check-bold"></i> }
                </span>
                <span class="rp-check-label">Sales / POS</span>
            </label>
            <label class="rp-check-item">
                <input type="checkbox" @bind="currentPermissions.Invoices" />
                <span class="rp-check-box @(currentPermissions.Invoices ? "checked" : "")">
                    @if (currentPermissions.Invoices) { <i class="ph-check-bold"></i> }
                </span>
                <span class="rp-check-label">Invoices</span>
            </label>
            <label class="rp-check-item">
                <input type="checkbox" @bind="currentPermissions.Settings" />
                <span class="rp-check-box @(currentPermissions.Settings ? "checked" : "")">
                    @if (currentPermissions.Settings) { <i class="ph-check-bold"></i> }
                </span>
                <span class="rp-check-label">Settings</span>
            </label>
            <label class="rp-check-item">
                <input type="checkbox" @bind="currentPermissions.Inventory" />
                <span class="rp-check-box @(currentPermissions.Inventory ? "checked" : "")">
                    @if (currentPermissions.Inventory) { <i class="ph-check-bold"></i> }
                </span>
                <span class="rp-check-label">Inventory</span>
            </label>
        </div>
    </div>

    <!-- SECTION 2: REPORTS SHOW/HIDDEN -->
    <div class="rp-section">
        <div class="rp-section-header">
            <span class="rp-section-title">REPORTS SHOW/HIDDEN:</span>
            <input type="checkbox" class="rp-check-all" title="Select/Deselect All"
                   checked="@AllReportsChecked"
                   @onchange="ToggleAllReports" />
        </div>
        <div class="rp-check-grid">
            <label class="rp-check-item">
                <input type="checkbox" @bind="currentPermissions.CustomerReport" />
                <span class="rp-check-box @(currentPermissions.CustomerReport ? "checked" : "")">
                    @if (currentPermissions.CustomerReport) { <i class="ph-check-bold"></i> }
                </span>
                <span class="rp-check-label">Customer Report</span>
            </label>
            <label class="rp-check-item">
                <input type="checkbox" @bind="currentPermissions.SaleReport" />
                <span class="rp-check-box @(currentPermissions.SaleReport ? "checked" : "")">
                    @if (currentPermissions.SaleReport) { <i class="ph-check-bold"></i> }
                </span>
                <span class="rp-check-label">Sales Report</span>
            </label>
            <label class="rp-check-item">
                <input type="checkbox" @bind="currentPermissions.ProductReport" />
                <span class="rp-check-box @(currentPermissions.ProductReport ? "checked" : "")">
                    @if (currentPermissions.ProductReport) { <i class="ph-check-bold"></i> }
                </span>
                <span class="rp-check-label">Product Report</span>
            </label>
            <label class="rp-check-item">
                <input type="checkbox" @bind="currentPermissions.InvoiceReport" />
                <span class="rp-check-box @(currentPermissions.InvoiceReport ? "checked" : "")">
                    @if (currentPermissions.InvoiceReport) { <i class="ph-check-bold"></i> }
                </span>
                <span class="rp-check-label">Invoice Report</span>
            </label>
            <label class="rp-check-item">
                <input type="checkbox" @bind="currentPermissions.ReturnsReport" />
                <span class="rp-check-box @(currentPermissions.ReturnsReport ? "checked" : "")">
                    @if (currentPermissions.ReturnsReport) { <i class="ph-check-bold"></i> }
                </span>
                <span class="rp-check-label">Returns Report</span>
            </label>
            <label class="rp-check-item">
                <input type="checkbox" @bind="currentPermissions.DailySummary" />
                <span class="rp-check-box @(currentPermissions.DailySummary ? "checked" : "")">
                    @if (currentPermissions.DailySummary) { <i class="ph-check-bold"></i> }
                </span>
                <span class="rp-check-label">Daily Summary</span>
            </label>
        </div>
    </div>

        <div style="display: flex; justify-content: flex-end; margin-top: 1.5rem; padding-top: 1.25rem; border-top: 1px solid #e2e8f0;">
            <button class="rp-btn-primary" @onclick="SavePermissions" disabled="@isSaving" style="padding: 0.625rem 1.4rem;">
                @if (isSaving)
                {
                    <i class="ph-spinner ph-spin"></i> <span>Saving...</span>
                }
                else
                {
                    <i class="ph-floppy-disk"></i> <span>Save Permissions</span>
                }
            </button>
        </div>
    </div>
</div>

<!-- Add Role Modal -->
@if (showAddRoleModal)
{
    <div class="rp-modal-overlay" @onclick="CloseAddRoleModal"></div>
    <div class="rp-modal">
        <div class="rp-modal-header">
            <div class="rp-modal-title">
                <div class="rp-modal-icon-plus">+</div>
                <span>Roles</span>
            </div>
            <button class="rp-modal-close" @onclick="CloseAddRoleModal">
                <i class="ph-x"></i>
            </button>
        </div>
        <div class="rp-modal-body">
            @if (isDeleteConfirmMode)
            {
                <!-- Delete Confirmation Message -->
                <div class="rp-modal-warning">
                    <div class="rp-modal-warning-icon">
                        <i class="ph-warning"></i>
                    </div>
                    <div class="rp-modal-warning-text">
                        <strong>Confirm Deletion</strong>
                        <p>Are you sure you want to delete the role <strong>"@editingRole?.RoleTitle"</strong>? All permissions for this role will be removed.</p>
                    </div>
                </div>
            }
            else
            {
                <!-- Consolidated Management Field (Combobox) -->
                <div class="rp-modal-row">
                    <label class="rp-modal-label">Role Name:</label>
                    <div class="rp-combo-container">
                        <input type="text" class="rp-combo-input" @bind="roleManagementInput" @bind:event="oninput" placeholder="e.g. Manager (Type or Select)" autocomplete="off" />
                        <div class="rp-combo-btn" @onclick="() => showComboDropdown = !showComboDropdown">
                            <i class="ph-caret-down" style="font-size: 1.2rem;"></i>
                        </div>
                        @if (showComboDropdown)
                        {
                            <div class="rp-combo-list">
                                @foreach (var role in rolesList)
                                {
                                    <div class="rp-combo-item" @onclick="() => { roleManagementInput = role.RoleTitle; editingRole = role; showComboDropdown = false; }">
                                        @role.RoleTitle
                                    </div>
                                }
                            </div>
                        }
                    </div>
                </div>
            }

            <div class="rp-modal-actions">
                <button class="modal-btn btn-del" @onclick="DeleteRole" 
                        disabled="@isSubmitting">
                    @if (isDeleteConfirmMode)
                    {
                        @if (isSubmitting) { <i class="ph-spinner ph-spin"></i> }
                        else { <span>Confirm Delete</span> <i class="ph-trash"></i> }
                    }
                    else
                    {
                        @if (isSubmitting) { <i class="ph-spinner ph-spin"></i> }
                        else { <span>Delete</span> <i class="ph-trash"></i> }
                    }
                </button>
                @if (isDeleteConfirmMode)
                {
                    <button class="modal-btn btn-upd" @onclick="CancelDelete" 
                            disabled="@isSubmitting">
                        <span>Cancel</span> <i class="ph-x"></i>
                    </button>
                }
                else
                {
                    <button class="modal-btn btn-upd" @onclick="UpdateRole" 
                            disabled="@isSubmitting">
                        @if (isSubmitting) { <i class="ph-spinner ph-spin"></i> }
                        else { <span>Update</span> <i class="ph-arrows-clockwise"></i> }
                    </button>
                    <button class="modal-btn btn-sav" @onclick="SaveNewRole" 
                            disabled="@isSubmitting">
                        @if (isSubmitting) { <i class="ph-spinner ph-spin"></i> }
                        else { <span>Save</span> <i class="ph-floppy-disk"></i> }
                    </button>
                }
            </div>
        </div>
    </div>
}



@code {
    private string selectedRole = "";
    private bool showComboDropdown = false;
    private bool isSaving = false;
    private bool isSubmitting = false;
    private string? successMessage;
    private string? errorMessage;

    // Roles list from database
    private List<Role> rolesList = new();
    private bool showAddRoleModal = false;
    
    private string _roleManagementInput = "";
    private string roleManagementInput 
    {
        get => _roleManagementInput;
        set 
        {
            _roleManagementInput = value;
            var matchedRole = rolesList.FirstOrDefault(r => r.RoleTitle.Equals(value, StringComparison.OrdinalIgnoreCase));
            if (matchedRole != null)
            {
                editingRole = matchedRole;
            }
        }
    }
    
    private Role? editingRole = null;
    private bool isDeleteConfirmMode = false; // Flag to show delete confirmation in modal

    // Permission model
    private RolePermission currentPermissions = new();

    private bool AllSystemChecked => currentPermissions.Dashboard && currentPermissions.Customers && currentPermissions.Products && currentPermissions.Sales && currentPermissions.Invoices && currentPermissions.Settings && currentPermissions.Inventory;
    private bool AllReportsChecked => currentPermissions.CustomerReport && currentPermissions.SaleReport && currentPermissions.ProductReport && currentPermissions.InvoiceReport && currentPermissions.ReturnsReport && currentPermissions.DailySummary;

    protected override async Task OnInitializedAsync()
    {
        await LoadRoles();
        await LoadPermissions();
    }

    private async Task LoadRoles()
    {
        try
        {
            using var context = DbFactory.CreateDbContext();
            rolesList = await context.roles.OrderBy(r => r.Id).ToListAsync();

            // Set default selected role if not already set to a valid role
            if (string.IsNullOrEmpty(selectedRole) || !rolesList.Any(r => r.RoleTitle == selectedRole))
            {
                selectedRole = rolesList.FirstOrDefault()?.RoleTitle ?? "";
            }
        }
        catch (Exception ex)
        {
            errorMessage = "Error loading roles: " + ex.Message;
        }
    }

    private async Task OnRoleChanged(ChangeEventArgs e)
    {
        selectedRole = e.Value?.ToString() ?? "";
        await LoadPermissions();
    }

    private async Task LoadPermissions()
    {
        successMessage = null;
        errorMessage = null;
        currentPermissions = new RolePermission(); // Reset to empty defaults

        try
        {
            using var context = DbFactory.CreateDbContext();
            var role = await context.roles.FirstOrDefaultAsync(r => r.RoleTitle == selectedRole);
            if (role != null)
            {
                var perms = await context.roles_permissions.FirstOrDefaultAsync(p => p.RoleId == role.Id);
                if (perms != null)
                {
                    currentPermissions = perms;
                }
                else if (selectedRole == "Admin")
                {
                    // Admin gets all by default if no record exists
                    currentPermissions.Dashboard = true;
                    currentPermissions.Customers = true;
                    currentPermissions.Products = true;
                    currentPermissions.Sales = true;
                    currentPermissions.Invoices = true;
                    currentPermissions.Settings = true;
                    currentPermissions.Inventory = true;
                    currentPermissions.CustomerReport = true;
                    currentPermissions.SaleReport = true;
                    currentPermissions.ProductReport = true;
                    currentPermissions.InvoiceReport = true;
                    currentPermissions.ReturnsReport = true;
                    currentPermissions.DailySummary = true;
                }
            }
        }
        catch (Exception ex)
        {
            errorMessage = "Error loading permissions: " + ex.Message;
        }

        await InvokeAsync(StateHasChanged);
    }

    private async Task SavePermissions()
    {
        isSaving = true;
        successMessage = null;
        errorMessage = null;
        await InvokeAsync(StateHasChanged);

        try
        {
            using var context = DbFactory.CreateDbContext();
            var role = await context.roles.FirstOrDefaultAsync(r => r.RoleTitle == selectedRole);
            if (role == null)
            {
                // Special case: if it's "Admin" and it's missing from roles table, create it
                if (selectedRole == "Admin")
                {
                    role = new Role { RoleTitle = "Admin" };
                    context.roles.Add(role);
                    await context.SaveChangesAsync();
                }
                else
                {
                    errorMessage = "Role not found in the roles table.";
                    return;
                }
            }

            var perms = await context.roles_permissions.FirstOrDefaultAsync(p => p.RoleId == role.Id);
            bool isNew = false;
            if (perms == null)
            {
                perms = new RolePermission { RoleId = role.Id };
                isNew = true;
            }

            // Explicitly copy values from currentPermissions (which is bound to UI)
            perms.Dashboard = currentPermissions.Dashboard;
            perms.Customers = currentPermissions.Customers;
            perms.Products = currentPermissions.Products;
            perms.Sales = currentPermissions.Sales;
            perms.Invoices = currentPermissions.Invoices;
            perms.Settings = currentPermissions.Settings;
            perms.Inventory = currentPermissions.Inventory;

            perms.CustomerReport = currentPermissions.CustomerReport;
            perms.SaleReport = currentPermissions.SaleReport;
            perms.ProductReport = currentPermissions.ProductReport;
            perms.InvoiceReport = currentPermissions.InvoiceReport;
            perms.ReturnsReport = currentPermissions.ReturnsReport;
            perms.DailySummary = currentPermissions.DailySummary;

            if (isNew)
            {
                context.roles_permissions.Add(perms);
            }
            else
            {
                context.roles_permissions.Update(perms);
            }

            await context.SaveChangesAsync();
            successMessage = $"Permissions for '{selectedRole}' saved successfully!";
        }
        catch (Exception ex)
        {
            errorMessage = "Error saving: " + ex.InnerException?.Message ?? ex.Message;
        }
        finally
        {
            isSaving = false;
            await InvokeAsync(StateHasChanged);
            await Task.Delay(3000);
            successMessage = null;
            await InvokeAsync(StateHasChanged);
        }
    }

    private void ToggleAllSystem(ChangeEventArgs e)
    {
        var val = (bool)(e.Value ?? false);
        currentPermissions.Dashboard = val;
        currentPermissions.Customers = val;
        currentPermissions.Products = val;
        currentPermissions.Sales = val;
        currentPermissions.Invoices = val;
        currentPermissions.Settings = val;
        currentPermissions.Inventory = val;
    }

    private void ToggleAllReports(ChangeEventArgs e)
    {
        var val = (bool)(e.Value ?? false);
        currentPermissions.CustomerReport = val;
        currentPermissions.SaleReport = val;
        currentPermissions.ProductReport = val;
        currentPermissions.InvoiceReport = val;
        currentPermissions.ReturnsReport = val;
        currentPermissions.DailySummary = val;
    }

    // Role Management Methods
    private void OpenAddRoleModal()
    {
        // Pre-populate with currently selected role from the main dropdown
        editingRole = rolesList.FirstOrDefault(r => r.RoleTitle == selectedRole);
        roleManagementInput = selectedRole; // Always pre-fill with selected role
        isDeleteConfirmMode = false;
        showAddRoleModal = true;
    }

    private void OpenRenameModal()
    {
        if (selectedRole == "Admin") return;
        editingRole = rolesList.FirstOrDefault(r => r.RoleTitle == selectedRole);
        roleManagementInput = selectedRole;
        showAddRoleModal = true;
    }

    private async Task OnRoleChangedInternal(ChangeEventArgs e)
    {
        selectedRole = e.Value?.ToString() ?? "";
        await OnRoleChanged(e);
    }

    private void CloseAddRoleModal()
    {
        showAddRoleModal = false;
        roleManagementInput = "";
        editingRole = null;
        isDeleteConfirmMode = false;
    }

    private void CancelDelete()
    {
        isDeleteConfirmMode = false;
        StateHasChanged();
    }

    // Removed OnManageRoleSelected as we use a single field now

    private async Task SaveNewRole()
    {
        if (string.IsNullOrWhiteSpace(roleManagementInput))
        {
            errorMessage = "Please enter a role name first.";
            return;
        }

        isSubmitting = true;
        errorMessage = null; 
        try
        {
            using var context = DbFactory.CreateDbContext();
            
            // Check if role already exists
            if (await context.roles.AnyAsync(r => r.RoleTitle.ToLower() == roleManagementInput.ToLower()))
            {
                errorMessage = $"'{roleManagementInput}' already exists!";
                isSubmitting = false;
                return;
            }

            var newRole = new Role { RoleTitle = roleManagementInput.Trim() };
            context.roles.Add(newRole);
            await context.SaveChangesAsync();

            await LoadRoles();
            CloseAddRoleModal();
            successMessage = $"Role '{roleManagementInput}' created successfully!";
        }
        catch (Exception ex)
        {
            errorMessage = "Error creating role: " + ex.Message;
        }
        finally
        {
            isSubmitting = false;
        }
    }

    private async Task UpdateRole()
    {
        if (editingRole == null)
        {
            errorMessage = "Please select a role from the list first (or select it on the main page).";
            return;
        }

        string newName = roleManagementInput.Trim();
        if (string.IsNullOrWhiteSpace(newName))
        {
            errorMessage = "New role name cannot be empty.";
            return;
        }

        if (newName.Equals(editingRole.RoleTitle, StringComparison.OrdinalIgnoreCase))
        {
            errorMessage = "New name is the same as the current name.";
            return;
        }

        isSubmitting = true;
        errorMessage = null; 
        try
        {
            using var context = DbFactory.CreateDbContext();

            // Check if another role with same name exists
            if (await context.roles.AnyAsync(r => r.Id != editingRole.Id && r.RoleTitle.ToLower() == newName.ToLower()))
            {
                errorMessage = $"'{newName}' already exists!";
                isSubmitting = false;
                return;
            }

            var dbRole = await context.roles.FindAsync(editingRole.Id);
            if (dbRole != null)
            {
                string oldTitle = dbRole.RoleTitle;
                string newTitle = newName;
                dbRole.RoleTitle = newTitle;
                await context.SaveChangesAsync();
                
                // Update local state
                selectedRole = newTitle;
            }

            await LoadRoles();
            await LoadPermissions(); // Reload perms for the new name
            CloseAddRoleModal();
            successMessage = $"Role renamed to '{newName}' successfully!";
        }
        catch (Exception ex)
        {
            errorMessage = "Error updating role: " + ex.Message;
        }
        finally
        {
            isSubmitting = false;
        }
    }

    private async Task DeleteRole()
    {
        if (editingRole == null)
        {
            errorMessage = "Select a role to delete first.";
            return;
        }

        // If not already in confirm mode, show confirmation
        if (!isDeleteConfirmMode)
        {
            isDeleteConfirmMode = true;
            StateHasChanged();
            return;
        }

        // Proceed with deletion after confirmation
        isSubmitting = true;
        errorMessage = null; 
        try
        {
            using var context = DbFactory.CreateDbContext();
            var dbRole = await context.roles.FindAsync(editingRole.Id);
            if (dbRole != null)
            {
                context.roles.Remove(dbRole);
                await context.SaveChangesAsync();
            }

            await LoadRoles();
            selectedRole = rolesList.FirstOrDefault()?.RoleTitle ?? "Admin";
            await LoadPermissions();
            CloseAddRoleModal();
            successMessage = "Role deleted successfully!";
        }
        catch (Exception ex)
        {
            errorMessage = "Error deleting role: " + ex.Message;
        }
        finally
        {
            isSubmitting = false;
        }
    }
}
