@code {
    private string selectedRole = "";
    private bool isSaving = false;
    private bool isSubmitting = false;
    private string? successMessage;
    private string? errorMessage;

    // Roles list from database
    private List<Role> rolesList = new();
    private bool showAddRoleModal = false;
    private string roleManagementInput = "";
    private Role? editingRole = null;
    private bool isDeleteConfirmMode = false; // Flag to show delete confirmation in modal

    // Permission model
    private RolePermission currentPermissions = new();

    private bool AllSystemChecked => currentPermissions.Dashboard && currentPermissions.Customers && currentPermissions.Products && currentPermissions.Sales && currentPermissions.Invoices && currentPermissions.Settings && currentPermissions.Inventory;
    private bool AllReportsChecked => currentPermissions.CustomerReport && currentPermissions.SaleReport && currentPermissions.ProductReport && currentPermissions.InvoiceReport && currentPermissions.ReturnsReport && currentPermissions.DailySummary;

    protected override async Task OnInitializedAsync()
    {
        await LoadRoles();
        await LoadPermissions();
    }

    private async Task LoadRoles()
    {
        try
        {
            using var context = DbFactory.CreateDbContext();
            rolesList = await context.roles.OrderBy(r => r.Id).ToListAsync();

            // Set default selected role if not already set to a valid role
            if (string.IsNullOrEmpty(selectedRole) || !rolesList.Any(r => r.RoleTitle == selectedRole))
            {
                selectedRole = rolesList.FirstOrDefault()?.RoleTitle ?? "";
            }
        }
        catch (Exception ex)
        {
            errorMessage = "Error loading roles: " + ex.Message;
        }
    }

    private async Task OnRoleChanged(ChangeEventArgs e)
    {
        selectedRole = e.Value?.ToString() ?? "";
        await LoadPermissions();
    }

    private async Task LoadPermissions()
    {
        successMessage = null;
        errorMessage = null;
        currentPermissions = new RolePermission(); // Reset to empty defaults

        try
        {
            using var context = DbFactory.CreateDbContext();
            var role = await context.roles.FirstOrDefaultAsync(r => r.RoleTitle == selectedRole);
            if (role != null)
            {
                var perms = await context.roles_permissions.FirstOrDefaultAsync(p => p.RoleId == role.Id);
                if (perms != null)
                {
                    currentPermissions = perms;
                }
                else if (selectedRole == "Admin")
                {
                    // Admin gets all by default if no record exists
                    currentPermissions.Dashboard = true;
                    currentPermissions.Customers = true;
                    currentPermissions.Products = true;
                    currentPermissions.Sales = true;
                    currentPermissions.Invoices = true;
                    currentPermissions.Settings = true;
                    currentPermissions.Inventory = true;
                    currentPermissions.CustomerReport = true;
                    currentPermissions.SaleReport = true;
                    currentPermissions.ProductReport = true;
                    currentPermissions.InvoiceReport = true;
                    currentPermissions.ReturnsReport = true;
                    currentPermissions.DailySummary = true;
                }
            }
        }
        catch (Exception ex)
        {
            errorMessage = "Error loading permissions: " + ex.Message;
        }

        await InvokeAsync(StateHasChanged);
    }

    private async Task SavePermissions()
    {
        isSaving = true;
        successMessage = null;
        errorMessage = null;
        await InvokeAsync(StateHasChanged);

        try
        {
            using var context = DbFactory.CreateDbContext();
            var role = await context.roles.FirstOrDefaultAsync(r => r.RoleTitle == selectedRole);
            if (role == null)
            {
                // Special case: if it's "Admin" and it's missing from roles table, create it
                if (selectedRole == "Admin")
                {
                    role = new Role { RoleTitle = "Admin" };
                    context.roles.Add(role);
                    await context.SaveChangesAsync();
                }
                else
                {
                    errorMessage = "Role not found in the roles table.";
                    return;
                }
            }

            var perms = await context.roles_permissions.FirstOrDefaultAsync(p => p.RoleId == role.Id);
            bool isNew = false;
            if (perms == null)
            {
                perms = new RolePermission { RoleId = role.Id };
                isNew = true;
            }

            // Explicitly copy values from currentPermissions (which is bound to UI)
            perms.Dashboard = currentPermissions.Dashboard;
            perms.Customers = currentPermissions.Customers;
            perms.Products = currentPermissions.Products;
            perms.Sales = currentPermissions.Sales;
            perms.Invoices = currentPermissions.Invoices;
            perms.Settings = currentPermissions.Settings;
            perms.Inventory = currentPermissions.Inventory;

            perms.CustomerReport = currentPermissions.CustomerReport;
            perms.SaleReport = currentPermissions.SaleReport;
            perms.ProductReport = currentPermissions.ProductReport;
            perms.InvoiceReport = currentPermissions.InvoiceReport;
            perms.ReturnsReport = currentPermissions.ReturnsReport;
            perms.DailySummary = currentPermissions.DailySummary;

            if (isNew)
            {
                context.roles_permissions.Add(perms);
            }
            else
            {
                context.roles_permissions.Update(perms);
            }

            await context.SaveChangesAsync();
            successMessage = $"Permissions for '{selectedRole}' saved successfully!";
        }
        catch (Exception ex)
        {
            errorMessage = "Error saving: " + ex.InnerException?.Message ?? ex.Message;
        }
        finally
        {
            isSaving = false;
            await InvokeAsync(StateHasChanged);
            await Task.Delay(3000);
            successMessage = null;
            await InvokeAsync(StateHasChanged);
        }
    }

    private void ToggleAllSystem(ChangeEventArgs e)
    {
        var val = (bool)(e.Value ?? false);
        currentPermissions.Dashboard = val;
        currentPermissions.Customers = val;
        currentPermissions.Products = val;
        currentPermissions.Sales = val;
        currentPermissions.Invoices = val;
        currentPermissions.Settings = val;
        currentPermissions.Inventory = val;
    }

    private void ToggleAllReports(ChangeEventArgs e)
    {
        var val = (bool)(e.Value ?? false);
        currentPermissions.CustomerReport = val;
        currentPermissions.SaleReport = val;
        currentPermissions.ProductReport = val;
        currentPermissions.InvoiceReport = val;
        currentPermissions.ReturnsReport = val;
        currentPermissions.DailySummary = val;
    }

    // Role Management Methods
    private void OpenAddRoleModal()
    {
        // Pre-populate with currently selected role from the main dropdown
        editingRole = rolesList.FirstOrDefault(r => r.RoleTitle == selectedRole);
        roleManagementInput = selectedRole; // Always pre-fill with selected role
        isDeleteConfirmMode = false;
        showAddRoleModal = true;
    }

    private void OpenRenameModal()
    {
        if (selectedRole == "Admin") return;
        editingRole = rolesList.FirstOrDefault(r => r.RoleTitle == selectedRole);
        roleManagementInput = selectedRole;
        showAddRoleModal = true;
    }

    private async Task OnRoleChangedInternal(ChangeEventArgs e)
    {
        selectedRole = e.Value?.ToString() ?? "";
        await OnRoleChanged(e);
    }

    private void CloseAddRoleModal()
    {
        showAddRoleModal = false;
        roleManagementInput = "";
        editingRole = null;
        isDeleteConfirmMode = false;
    }

    private void CancelDelete()
    {
        isDeleteConfirmMode = false;
        StateHasChanged();
    }

    // Removed OnManageRoleSelected as we use a single field now

    private async Task SaveNewRole()
    {
        if (string.IsNullOrWhiteSpace(roleManagementInput))
        {
            errorMessage = "Please enter a role name first.";
            return;
        }

        isSubmitting = true;
        errorMessage = null; 
        try
        {
            using var context = DbFactory.CreateDbContext();
            
            // Check if role already exists
            if (await context.roles.AnyAsync(r => r.RoleTitle.ToLower() == roleManagementInput.ToLower()))
            {
                errorMessage = $"'{roleManagementInput}' already exists!";
                isSubmitting = false;
                return;
            }

            var newRole = new Role { RoleTitle = roleManagementInput.Trim() };
            context.roles.Add(newRole);
            await context.SaveChangesAsync();

            await LoadRoles();
            CloseAddRoleModal();
            successMessage = $"Role '{roleManagementInput}' created successfully!";
        }
        catch (Exception ex)
        {
            errorMessage = "Error creating role: " + ex.Message;
        }
        finally
        {
            isSubmitting = false;
        }
    }

    private async Task UpdateRole()
    {
        if (editingRole == null)
        {
            errorMessage = "Please select a role from the list first (or select it on the main page).";
            return;
        }

        string newName = roleManagementInput.Trim();
        if (string.IsNullOrWhiteSpace(newName))
        {
            errorMessage = "New role name cannot be empty.";
            return;
        }

        if (newName.Equals(editingRole.RoleTitle, StringComparison.OrdinalIgnoreCase))
        {
            errorMessage = "New name is the same as the current name.";
            return;
        }

        isSubmitting = true;
        errorMessage = null; 
        try
        {
            using var context = DbFactory.CreateDbContext();

            // Check if another role with same name exists
            if (await context.roles.AnyAsync(r => r.Id != editingRole.Id && r.RoleTitle.ToLower() == newName.ToLower()))
            {
                errorMessage = $"'{newName}' already exists!";
                isSubmitting = false;
                return;
            }

            var dbRole = await context.roles.FindAsync(editingRole.Id);
            if (dbRole != null)
            {
                string oldTitle = dbRole.RoleTitle;
                string newTitle = newName;
                
                // Update users with old role string
                var usersWithOldRole = await context.users.Where(u => u.role == oldTitle).ToListAsync();
                foreach (var user in usersWithOldRole)
                {
                    user.role = newTitle;
                }

                dbRole.RoleTitle = newTitle;
                await context.SaveChangesAsync();
                
                // Update local state
                selectedRole = newTitle;
            }

            await LoadRoles();
            await LoadPermissions(); // Reload perms for the new name
            CloseAddRoleModal();
            successMessage = $"Role renamed to '{newName}' successfully!";
        }
        catch (Exception ex)
        {
            errorMessage = "Error updating role: " + ex.Message;
        }
        finally
        {
            isSubmitting = false;
        }
    }

    private async Task DeleteRole()
    {
        if (editingRole == null)
        {
            errorMessage = "Select a role to delete first.";
            return;
        }

        // If not already in confirm mode, show confirmation
        if (!isDeleteConfirmMode)
        {
            isDeleteConfirmMode = true;
            StateHasChanged();
            return;
        }

        // Proceed with deletion after confirmation
        isSubmitting = true;
        errorMessage = null; 
        try
        {
            using var context = DbFactory.CreateDbContext();
            var dbRole = await context.roles.FindAsync(editingRole.Id);
            if (dbRole != null)
            {
                context.roles.Remove(dbRole);
                await context.SaveChangesAsync();
            }

            await LoadRoles();
            selectedRole = rolesList.FirstOrDefault()?.RoleTitle ?? "Admin";
            await LoadPermissions();
            CloseAddRoleModal();
            successMessage = "Role deleted successfully!";
        }
        catch (Exception ex)
        {
            errorMessage = "Error deleting role: " + ex.Message;
        }
        finally
        {
            isSubmitting = false;
        }
    }
}
