@using E_Invoice_system.Models
@using E_Invoice_system.Data
@using Microsoft.EntityFrameworkCore
@inject IDbContextFactory<ApplicationDbContext> DbFactory
@inject NavigationManager NavigationManager

<div class="reports-center-container">
    <div class="page-header-minimal">
        <h1 class="page-title">Reports Center</h1>
        <p class="page-subtitle">Access detailed insights and generate downloadable reports for your business.</p>
    </div>

    <!-- Summary Cards -->
    <div class="reports-summary-grid">
        <div class="summary-card primary-red">
            <div class="card-info">
                <span class="card-value">@currencySymbol@todayRevenue.ToString("N0")</span>
                <span class="card-label">Today's Revenue</span>
            </div>
            <div class="card-icon-circle">
                <i class="ph-trend-up"></i>
            </div>
        </div>

        <div class="summary-card dark-gray">
            <div class="card-info">
                <span class="card-value">@currencySymbol@monthlyRevenue.ToString("N0")</span>
                <span class="card-label">Monthly Revenue</span>
            </div>
            <div class="card-icon-circle">
                <i class="ph-chart-line-up"></i>
            </div>
        </div>

        <div class="summary-card white">
            <div class="card-info">
                <span class="card-value">@activeSkus</span>
                <span class="card-label">Total Products</span>
            </div>
            <div class="card-icon-circle red-icon">
                <i class="ph-package"></i>
            </div>
        </div>

        <div class="summary-card white">
            <div class="card-info">
                <span class="card-value">@lowStockAlerts</span>
                <span class="card-label">Stock Alerts</span>
            </div>
            <div class="card-icon-circle red-icon">
                <i class="ph-warning"></i>
            </div>
        </div>

        <div class="summary-card white">
            <div class="card-info">
                <span class="card-value">@customerCount</span>
                <span class="card-label">Total Customers</span>
            </div>
            <div class="card-icon-circle blue-icon">
                <i class="ph-users"></i>
            </div>
        </div>
    </div>

    <h2 class="section-title">Available Reports</h2>

    <!-- Available Reports Grid -->
    <div class="available-reports-grid">
        <!-- Sales & Revenue -->
        <div class="report-main-card">
            <div class="report-card-header">
                <div class="report-icon-wrap red-bg">
                    <i class="ph-shopping-cart"></i>
                </div>
            </div>
            <div class="report-card-body">
                <h3 class="report-name">Sales & Revenue</h3>
                <p class="report-desc">Analyze transaction patterns, revenue trends, and discount impacts.</p>
                <div class="report-meta">
                    <i class="ph-check-circle"></i>
                    <span>Date-wise Breakdown</span>
                </div>
            </div>
            <div class="report-card-footer">
                <button class="view-hub-btn" @onclick='() => OnViewHub.InvokeAsync("sales")'>
                    View Sales Hub <i class="ph-arrow-right"></i>
                </button>
            </div>
        </div>

        <!-- Stock & Inventory -->
        <div class="report-main-card">
            <div class="report-card-header">
                <div class="report-icon-wrap red-bg">
                    <i class="ph-cube"></i>
                </div>
            </div>
            <div class="report-card-body">
                <h3 class="report-name">Stock & Inventory</h3>
                <p class="report-desc">Real-time stock levels, category distribution, and low-stock alerts.</p>
                <div class="report-meta">
                    <i class="ph-check-circle"></i>
                    <span>Inventory Insights</span>
                </div>
            </div>
            <div class="report-card-footer">
                <button class="view-hub-btn" @onclick='() => OnViewHub.InvokeAsync("inventory")'>
                    View Inventory Hub <i class="ph-arrow-right"></i>
                </button>
            </div>
        </div>

        <!-- Customer Reports -->
        <div class="report-main-card">
            <div class="report-card-header">
                <div class="report-icon-wrap red-bg">
                    <i class="ph-user-list"></i>
                </div>
            </div>
            <div class="report-card-body">
                <h3 class="report-name">Customer Insights</h3>
                <p class="report-desc">Detailed list of customers, contact info, and purchase history overview.</p>
                <div class="report-meta">
                    <i class="ph-check-circle"></i>
                    <span>Customer List</span>
                </div>
            </div>
            <div class="report-card-footer">
                <button class="view-hub-btn" @onclick='() => OnViewHub.InvokeAsync("customers")'>
                    View Customer Hub <i class="ph-arrow-right"></i>
                </button>
            </div>
        </div>

        <!-- Product Reports -->
        <div class="report-main-card">
            <div class="report-card-header">
                <div class="report-icon-wrap red-bg">
                    <i class="ph-tag"></i>
                </div>
            </div>
            <div class="report-card-body">
                <h3 class="report-name">Product Analytics</h3>
                <p class="report-desc">Performance of different products, services, and categories.</p>
                <div class="report-meta">
                    <i class="ph-check-circle"></i>
                    <span>Catalog Details</span>
                </div>
            </div>
            <div class="report-card-footer">
                <button class="view-hub-btn" @onclick='() => OnViewHub.InvokeAsync("products")'>
                    View Product Hub <i class="ph-arrow-right"></i>
                </button>
            </div>
        </div>

        <!-- Employee Reports -->
        <div class="report-main-card">
            <div class="report-card-header">
                <div class="report-icon-wrap red-bg">
                    <i class="ph-users-three"></i>
                </div>
            </div>
            <div class="report-card-body">
                <h3 class="report-name">Employee Reports</h3>
                <p class="report-desc">Staff performance, roles, and basic payroll insights.</p>
                <div class="report-meta">
                    <i class="ph-check-circle"></i>
                    <span>Staff Directory</span>
                </div>
            </div>
            <div class="report-card-footer">
                <button class="view-hub-btn" @onclick='() => OnViewHub.InvokeAsync("employees")'>
                    View Employee Hub <i class="ph-arrow-right"></i>
                </button>
            </div>
        </div>
    </div>
</div>

<style>
    .reports-center-container {
        padding: 1rem;
        animation: fadeIn 0.4s ease-out;
    }

    .page-header-minimal {
        margin-bottom: 2rem;
    }

    .page-title {
        font-size: 1.75rem;
        font-weight: 800;
        color: #1e293b;
        margin: 0;
    }

    .page-subtitle {
        color: #64748b;
        font-size: 0.95rem;
        margin-top: 0.25rem;
    }

    .reports-summary-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
        gap: 1rem;
        margin-bottom: 2.5rem;
    }

    .summary-card {
        padding: 1.25rem;
        border-radius: 12px;
        display: flex;
        justify-content: space-between;
        align-items: center;
        box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.05);
        transition: transform 0.2s;
    }

    .summary-card:hover {
        transform: translateY(-4px);
    }

    .summary-card.primary-red { background: #BC1823; color: white; }
    .summary-card.dark-gray { background: #1C2120; color: white; }
    .summary-card.white { background: white; color: #1e293b; border: 1px solid #e2e8f0; }

    .card-info { display: flex; flex-direction: column; }
    .card-value { font-size: 1.4rem; font-weight: 800; }
    .card-label { font-size: 0.8rem; opacity: 0.9; font-weight: 500; }

    .card-icon-circle {
        width: 38px;
        height: 38px;
        background: rgba(255,255,255,0.2);
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 1.1rem;
    }

    .blue-icon { background: #eff6ff; color: #3b82f6; }
    .red-icon { background: #fef2f2; color: #BC1823; }

    .section-title {
        font-size: 1.25rem;
        font-weight: 800;
        color: #1e293b;
        margin-bottom: 1.5rem;
    }

    .available-reports-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
        gap: 1.25rem;
    }

    .report-main-card {
        background: white;
        border-radius: 16px;
        border: 1px solid #e2e8f0;
        padding: 1.5rem;
        display: flex;
        flex-direction: column;
        transition: all 0.3s ease;
    }

    .report-main-card:hover {
        box-shadow: 0 10px 15px -3px rgba(0,0,0,0.1);
        border-color: #BC1823;
    }

    .report-icon-wrap {
        width: 44px;
        height: 44px;
        border-radius: 10px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 1.25rem;
        margin-bottom: 1rem;
    }

    .red-bg { background: #fef2f2; color: #BC1823; }

    .report-name { font-size: 1.1rem; font-weight: 800; color: #1e293b; margin: 0 0 0.5rem 0; }
    .report-desc { color: #64748b; font-size: 0.85rem; line-height: 1.5; margin-bottom: 1rem; flex: 1; }

    .report-meta {
        display: flex;
        align-items: center;
        gap: 0.5rem;
        color: #94a3b8;
        font-size: 0.75rem;
        font-weight: 600;
        margin-bottom: 1.5rem;
    }

    .view-hub-btn {
        width: 100%;
        padding: 0.75rem;
        background: #BC1823;
        color: white;
        border: none;
        border-radius: 10px;
        font-weight: 700;
        font-size: 0.9rem;
        cursor: pointer;
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 0.5rem;
        transition: all 0.2s;
    }

    .view-hub-btn:hover { background: #9c141d; transform: translateY(-1px); }

    @@keyframes fadeIn {
        from { opacity: 0; transform: translateY(10px); }
        to { opacity: 1; transform: translateY(0); }
    }
</style>

@code {
    [Parameter] public EventCallback<string> OnViewHub { get; set; }

    private decimal todayRevenue = 0;
    private decimal monthlyRevenue = 0;
    private int activeSkus = 0;
    private int lowStockAlerts = 0;
    private int customerCount = 0;
    private string currencySymbol = "$";

    protected override async Task OnInitializedAsync()
    {
        await LoadData();
    }

    private async Task LoadData()
    {
        try
        {
            using var context = DbFactory.CreateDbContext();
            
            // Currency
            var currency = await context.currencies.FirstOrDefaultAsync(c => c.is_active);
            if (currency != null) currencySymbol = currency.symbol ?? "$";

            // Revenue
            var todayStr = DateTime.Now.ToString("yyyy-MM-dd");
            var monthPrefix = DateTime.Now.ToString("yyyy-MM");

            var allSales = await context.sales.AsNoTracking().ToListAsync();
            todayRevenue = allSales.Where(s => s.date == todayStr && !s.is_returned).Sum(s => s.total_price);
            monthlyRevenue = allSales.Where(s => s.date.StartsWith(monthPrefix) && !s.is_returned).Sum(s => s.total_price);

            // SKUs
            activeSkus = await context.products_services.CountAsync(p => p.status == "Active");

            // Customers
            customerCount = await context.customers.CountAsync();

            // Low Stock
            var lowStockItems = await context.stock_details.CountAsync(s => s.quantity <= 5);
            lowStockAlerts = lowStockItems;
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error loading report data: {ex.Message}");
        }
    }
}
