@namespace E_Invoice_system.Components.Product
@using Microsoft.EntityFrameworkCore
@using System.IO
@inject IDbContextFactory<ApplicationDbContext> DbFactory
@inject NavigationManager NavigationManager
@inject IWebHostEnvironment Environment

<div class="form-wrapper form-layout-left-wide">
    <div class="form-section">
        <div class="form-section-header">
            <h3 class="form-section-title">
                <i class="ph-package form-icon-primary"></i>
                Product / Service Information
            </h3>
        </div>

        @if (!string.IsNullOrEmpty(errorMessage))
        {
            <div class="alert alert-danger" style="margin-bottom: 1.5rem; padding: 1rem; border-radius: 8px; background: #fee2e2; color: #ef4444; border: 1px solid #fecaca;">
                <i class="ph-warning"></i> @errorMessage
            </div>
        }

        <!-- Basic Info -->
        <div class="form-group">
            <label class="form-label">Name / Title</label>
            <input class="form-control" @bind="product.prod_name_service" placeholder="Enter name" required />
        </div>

        <div class="form-group">
            <label class="form-label">Price</label>
            <input type="number" step="0.01" class="form-control" @bind="product.price" />
        </div>
        <div class="form-group">
            <label class="form-label">Discount</label>
            <input type="number" step="0.01" class="form-control" @bind="product.discount" />
        </div>
        <div class="form-group">
            <label class="form-label">Tax (%)</label>
            <input type="number" step="0.01" class="form-control" @bind="product.tax" placeholder="0.00" />
        </div>

        <div class="form-group">
            <label class="form-label">Quantity / Unit (e.g. 10 kg / 0 Service)</label>
            <input class="form-control" @bind="product.qty_unit_type" placeholder="10 / 0" />
        </div>
        <div class="form-group">
            <label class="form-label">Barcode (Auto-generated if blank)</label>
            <input class="form-control" @bind="product.barcode" placeholder="Enter or scan barcode" />
        </div>

        <div class="form-group">
            <label class="form-label">Expiry Date</label>
            <input type="date" class="form-control" @bind="product.expiry_date" />
        </div>
        <div class="form-group">
            <label class="form-label">Status</label>
            <select class="form-control" @bind="product.status">
                <option value="Available">Available</option>
                <option value="Out of Stock">Out of Stock</option>
                <option value="Discontinued">Discontinued</option>
            </select>
        </div>

        <div class="form-group">
            <label class="form-label">Description</label>
            <textarea class="form-control" rows="3" @bind="product.description" placeholder="Optional description"></textarea>
        </div>

        <!-- Image Upload -->
        <div class="form-group">
            <label class="form-label">Product Image</label>
            <div style="display:flex; gap:1.5rem; align-items:flex-start; background:#f8fafc; padding:1.5rem; border-radius:12px; border:1px dashed #cbd5e1;">
                <div style="width:120px; height:120px; border-radius:8px; background:#e2e8f0; display:flex; align-items:center; justify-content:center; overflow:hidden;">
                    @if (!string.IsNullOrEmpty(GetImageUrl()))
                    {
                        <img src="@GetImageUrl()" style="width:100%; height:100%; object-fit:cover;" />
                    }
                    else
                    {
                        <i class="ph-image" style="font-size:2rem; color:#94a3b8;"></i>
                    }
                </div>
                <div style="flex:1;">
                    <InputFile OnChange="HandleFileSelected" class="form-control" accept="image/*" />
                    <p style="font-size:.75rem; color:#64748b; margin-top:.5rem;">PNG, JPG or JPEG. Max 5MB recommended.</p>
                </div>
            </div>
        </div>
    </div>

    <div class="form-actions-sticky">
        <button type="button" @onclick="Cancel" class="btn-secondary" style="display:inline-flex; align-items:center; justify-content:center; text-decoration:none;">Cancel</button>
        <button type="button" class="btn-primary" @onclick="SaveProduct" disabled="@isSubmitting">
            <span>
                @if (isSubmitting)
                {
                    <i class="ph-spinner ph-spin"></i> @("Saving...")
                }
                else
                {
                    <i class="ph-check"></i> @(ProductId == 0 ? "Save Product" : "Update Product")
                }
            </span>
        </button>
    </div>
</div>

@code {
    [Parameter] public int ProductId { get; set; }
    
    private ProductService product = new ProductService { 
        status = "Available", 
        price = 0,
        discount = 0
    };
    private IBrowserFile? selectedFile;
    private string? imgUrl;
    private bool isSubmitting = false;
    private string? errorMessage;

    protected override async Task OnInitializedAsync()
    {
        if (ProductId != 0)
        {
            using var context = DbFactory.CreateDbContext();
            var existing = await context.products_services.FindAsync(ProductId);
            if (existing != null) product = existing;
        }
    }

    private async Task HandleFileSelected(InputFileChangeEventArgs e)
    {
        try 
        {
            selectedFile = e.File;
            errorMessage = null;

            if (selectedFile.Size > 5120000)
            {
                errorMessage = "Selected image is too large (max 5MB). Please choose a smaller file.";
                selectedFile = null;
                imgUrl = null;
                return;
            }

            // Show preview using a memory stream for reliability
            using var stream = selectedFile.OpenReadStream(5120000);
            using var ms = new MemoryStream();
            await stream.CopyToAsync(ms);
            imgUrl = $"data:{selectedFile.ContentType};base64,{Convert.ToBase64String(ms.ToArray())}";
            
            StateHasChanged();
        }
        catch (Exception ex)
        {
            errorMessage = "Problem loading image preview: " + ex.Message;
            selectedFile = null;
            imgUrl = null;
        }
    }

    private async Task SaveProduct()
    {
        if (isSubmitting) return;
        
        errorMessage = null;
        if (string.IsNullOrWhiteSpace(product.prod_name_service)) { errorMessage = "Name is required."; return; }
        if (product.discount > product.price) { errorMessage = "Discount cannot exceed price."; return; }

        isSubmitting = true;
        StateHasChanged();

        try
        {
            // Handle Image Upload
            if (selectedFile != null)
            {
                try 
                {
                    string storagePath = @"D:\netcore\E-Invoice_system\bin\Debug\images";
                    if (!Directory.Exists(storagePath)) Directory.CreateDirectory(storagePath);

                    string fileName = Guid.NewGuid().ToString() + Path.GetExtension(selectedFile.Name);
                    string path = Path.Combine(storagePath, fileName);

                    // Delete old image if it exists and is different
                    if (!string.IsNullOrEmpty(product.image) && product.image != path)
                    {
                        if (File.Exists(product.image)) try { File.Delete(product.image); } catch {}
                    }

                    await using var stream = selectedFile.OpenReadStream(5120000);
                    await using var fs = new FileStream(path, FileMode.Create);
                    await stream.CopyToAsync(fs);
                    product.image = path; 
                }
                catch (Exception imgEx)
                {
                    errorMessage = "Failed to save image locally: " + imgEx.Message;
                    isSubmitting = false;
                    return;
                }
            }

            // Auto-generate barcode
            if (string.IsNullOrWhiteSpace(product.barcode)) product.barcode = await GenerateUniqueBarcode();

            // Sync status with quantity
            if (!string.IsNullOrEmpty(product.qty_unit_type))
            {
                var val = product.qty_unit_type.Trim();
                if (val == "0" || val.StartsWith("0 ")) product.status = "Out of Stock";
                else if (product.status == "Out of Stock") product.status = "Available";
            }

            // ROBUST DB UPDATE LOGIC
            using var context = DbFactory.CreateDbContext();
            if (ProductId == 0 || product.id == 0) 
            {
                product.date = DateTime.Now;
                context.products_services.Add(product);
            }
            else 
            {
                context.products_services.Update(product);
            }

            await context.SaveChangesAsync();
            
            // Standard Blazor Navigation
            NavigationManager.NavigateTo("/Product/Index", true);
        }
        catch (Exception ex)
        {
            string fullMsg = ex.Message;
            if (ex.InnerException != null) fullMsg += " | " + ex.InnerException.Message;
            
            errorMessage = "Save Error: " + fullMsg;
            isSubmitting = false;
            StateHasChanged();
        }
    }

    private async Task<string> GenerateUniqueBarcode()
    {
        using var context = DbFactory.CreateDbContext();
        var barcodes = await context.products_services
            .AsNoTracking()
            .Where(p => p.barcode != null && p.barcode.StartsWith("P"))
            .Select(p => p.barcode)
            .ToListAsync();

        long maxId = 0;
        foreach (var code in barcodes)
        {
            if (code!.Length > 1 && long.TryParse(code.Substring(1), out long currentId))
            {
                if (currentId > maxId) maxId = currentId;
            }
        }
        return $"P{(maxId + 1):D10}";
    }

    private string GetImageUrl()
    {
        if (!string.IsNullOrEmpty(imgUrl)) return imgUrl;
        if (!string.IsNullOrEmpty(product.image))
        {
            try { return "/product-images/" + Path.GetFileName(product.image); }
            catch { return "/product-images/" + product.image; }
        }
        return "";
    }

    private void Cancel() => NavigationManager.NavigateTo("/Product/Index", true);
}
