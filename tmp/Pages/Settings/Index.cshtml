@page "/settings"
@model E_Invoice_system.Pages.Settings.IndexModel
@{
    ViewData["Title"] = "Settings";
}

<div class="dashboard-panel">
    <div class="page-header">
        <h1 class="page-title-large">
            System Settings
        </h1>
        <p class="page-subtitle">Manage users, currencies, and system configurations.</p>
    </div>

    <div id="settings-container">
        <component type="typeof(E_Invoice_system.Components.Settings.SettingsHub)" render-mode="ServerPrerendered" />
    </div>
</div>

@section Scripts {
    <link rel="stylesheet" href="~/css/settings.css" asp-append-version="true" />
}
