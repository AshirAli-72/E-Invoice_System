@using System.Text.Json
@model E_Invoice_system.Models.invoices

@{
    Layout = null;
    var subtotal = Model.price;
    var discount = Model.discount;
    var totalAmount = Model.total_price;

    var isMultiItem = false;
    List<Dictionary<string, object>> items = new List<Dictionary<string, object>>();

    try
    {
        if (!string.IsNullOrEmpty(Model.prod_name_service) &&
            Model.prod_name_service.Trim().StartsWith("["))
        {
            var jsonElements = JsonSerializer.Deserialize<List<Dictionary<string, JsonElement>>>(Model.prod_name_service);
            if (jsonElements != null && jsonElements.Count > 0)
            {
                isMultiItem = true;
                foreach (var item in jsonElements)
                {
                    var newItem = new Dictionary<string, object>();
                    foreach (var kvp in item)
                    {
                        if (kvp.Value.ValueKind == JsonValueKind.Number)
                            newItem[kvp.Key] = kvp.Value.GetDecimal();
                        else if (kvp.Value.ValueKind == JsonValueKind.String)
                            newItem[kvp.Key] = kvp.Value.GetString() ?? "";
                        else
                            newItem[kvp.Key] = kvp.Value.ToString();
                    }
                    items.Add(newItem);
                }
                if (subtotal == 0 && items.Any())
                    subtotal = items.Sum(i => (decimal)i["price"] * (decimal)i["qty"]);
            }
        }
    }
    catch { isMultiItem = false; }
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Invoice Printing - @Model.invoice_no</title>
    <link href="https://fonts.googleapis.com/css2?family=Montserrat:wght@400;700;800;900&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://unpkg.com/phosphor-icons@1.4.2/css/phosphor-icons.css" />
    <style>
        @@import url('/css/invoice.css');

        /* ─── SCREEN STYLES ─── */
        * {
            box-sizing: border-box;
            margin: 0;
            padding: 0;
        }

        html, body {
            margin: 0;
            padding: 0;
            background: #f0f2f5;
            font-family: 'Montserrat', sans-serif;
        }

        /* Print button bar */
        .no-print {
            display: flex;
            gap: 1rem;
            padding: 16px 24px;
            justify-content: flex-end;
            background: #f0f2f5;
        }

        /* Outer wrapper - centers the invoice on screen */
        #invoiceViewWrapper {
            display: flex;
            justify-content: center;
            align-items: flex-start;
            padding: 0 0 40px 0;
            background: #f0f2f5;
        }

        /* The A4 invoice container on screen */
        #printableInvoice {
            width: 210mm;
            min-height: 297mm;
            height: 297mm;
            background: white;
            position: relative;
            display: flex;
            flex-direction: column;
            overflow: hidden;
            box-shadow: 0 10px 40px rgba(0,0,0,0.18);
            /* Scale down so it fits the screen without scrolling */
            transform: scale(0.82);
            transform-origin: top center;
            margin-bottom: -200px; /* compensate for scale shrink */
        }

        /* ─── TOP PATTERN ─── */
        .top-pattern {
            position: absolute;
            top: 0;
            left: 0;
            width: 100%;
            height: 90px;
            overflow: hidden;
            z-index: 0;
        }

        .shape-red-top {
            position: absolute;
            top: 0;
            left: 0;
            width: 100%;
            height: 90px;
            background: #BC1823;
            clip-path: polygon(0 0, 100% 0, 100% 60%, 0 100%);
        }

        .shape-black-top-1 {
            position: absolute;
            top: 0;
            right: 0;
            width: 35%;
            height: 90px;
            background: #111827;
            clip-path: polygon(30% 0, 100% 0, 100% 100%, 0 100%);
        }

        .shape-black-top-2 {
            position: absolute;
            top: 0;
            right: 0;
            width: 18%;
            height: 90px;
            background: #1f2937;
            clip-path: polygon(50% 0, 100% 0, 100% 100%, 0 100%);
        }

        /* ─── HEADER CONTENT ─── */
        .header-content {
            position: relative;
            z-index: 1;
            display: flex;
            justify-content: space-between;
            align-items: center;
            padding: 18px 30px 14px 30px;
            margin-bottom: 0;
        }

        .logo-box {
            width: 70px;
            height: 70px;
            background: white;
            border-radius: 10px;
            display: flex;
            align-items: center;
            justify-content: center;
            overflow: hidden;
            box-shadow: 0 2px 8px rgba(0,0,0,0.15);
        }

            .logo-box img {
                width: 100%;
                height: 100%;
                object-fit: contain;
            }

        .invoice-title-section {
            text-align: right;
            color: white;
        }

        .invoice-label {
            font-size: 26px;
            font-weight: 900;
            letter-spacing: 2px;
            text-transform: uppercase;
        }

        .invoice-no {
            font-size: 13px;
            font-weight: 700;
            opacity: 0.9;
            margin-top: 2px;
        }

        /* ─── DETAILS SECTION ─── */
        .details-section {
            display: flex;
            justify-content: space-between;
            padding: 14px 30px 10px 30px;
            gap: 20px;
        }

        .billing-box {
            flex: 1;
        }

            .billing-box.text-right {
                text-align: right;
            }

        .section-label {
            font-size: 10px;
            font-weight: 800;
            text-transform: uppercase;
            color: #BC1823;
            letter-spacing: 1px;
            margin-bottom: 5px;
        }

        .billing-name {
            font-size: 13px;
            font-weight: 800;
            color: #111827;
            margin-bottom: 3px;
        }

        .billing-details {
            font-size: 11px;
            color: #4b5563;
            line-height: 1.5;
        }

        /* ─── INFO BAR ─── */
        .info-bar {
            display: flex;
            gap: 16px;
            padding: 8px 30px;
            background: #f9fafb;
            border-top: 1px solid #e5e7eb;
            border-bottom: 1px solid #e5e7eb;
            margin: 0 0 0 0;
        }

        .info-item {
            display: flex;
            align-items: center;
            gap: 8px;
        }

        .info-label {
            font-size: 10px;
            font-weight: 700;
            color: #6b7280;
            text-transform: uppercase;
        }

        .info-value {
            font-size: 11px;
            font-weight: 700;
            color: #111827;
        }

        .status-badge {
            padding: 2px 10px;
            border-radius: 20px;
            color: white;
            font-size: 10px;
            font-weight: 800;
            text-transform: uppercase;
        }

        /* ─── ITEMS TABLE ─── */
        .items-section {
            padding: 10px 30px 6px 30px;
            flex: 1;
        }

            .items-section table {
                width: 100%;
                border-collapse: collapse;
            }

            .items-section thead tr {
                background: #111827;
                color: white;
            }

            .items-section thead th {
                padding: 8px 10px;
                font-size: 10px;
                font-weight: 800;
                text-transform: uppercase;
                letter-spacing: 0.5px;
            }

            .items-section tbody tr {
                border-bottom: 1px solid #f3f4f6;
            }

                .items-section tbody tr:nth-child(even) {
                    background: #f9fafb;
                }

            .items-section tbody td {
                padding: 7px 10px;
                font-size: 11px;
                color: #374151;
                vertical-align: middle;
            }

        .item-name {
            font-weight: 700;
            color: #111827;
            font-size: 11px;
        }

        .item-expiry {
            font-size: 9px;
            color: #9ca3af;
            margin-top: 2px;
        }

        .text-center {
            text-align: center;
        }

        .text-right {
            text-align: right;
        }

        /* ─── BOTTOM SECTION ─── */
        .bottom-section {
            display: flex;
            justify-content: space-between;
            align-items: flex-start;
            padding: 10px 30px 8px 30px;
            gap: 20px;
        }

        .terms-block {
            flex: 1;
        }

        .terms-title {
            font-size: 10px;
            font-weight: 800;
            text-transform: uppercase;
            color: #BC1823;
            margin-bottom: 5px;
        }

        .terms-text {
            font-size: 9px;
            color: #6b7280;
            line-height: 1.5;
        }

        .signature-box {
            margin-top: 20px;
        }

        .signature-line {
            font-size: 9px;
            font-weight: 700;
            color: #374151;
            border-top: 1.5px solid #111827;
            padding-top: 4px;
            width: 130px;
        }

        .summary-box {
            width: 200px;
        }

        .summary-row {
            display: flex;
            justify-content: space-between;
            font-size: 11px;
            padding: 3px 0;
        }

        .s-lbl {
            color: #6b7280;
            font-weight: 600;
        }

        .s-val {
            font-weight: 700;
            color: #111827;
        }

        .s-val-disc {
            color: #BC1823;
        }

        .summary-divider {
            border: 0;
            border-top: 1px solid #e5e7eb;
            margin: 6px 0;
        }

        .summary-total {
            background: #BC1823;
            color: white;
            padding: 8px 10px;
            display: flex;
            justify-content: space-between;
            font-weight: 800;
            font-size: 12px;
            border-radius: 4px;
        }

        /* ─── FOOTER (pinned inside the A4 box) ─── */
        .footer-wrapper {
            width: 100%;
            height: 72px;
            position: relative;
            flex-shrink: 0; /* never compress */
            overflow: hidden;
        }

        .bottom-pattern {
            position: absolute;
            bottom: 0;
            left: 0;
            width: 100%;
            height: 72px;
            overflow: hidden;
        }

        .shape-red-bottom {
            position: absolute;
            bottom: 0;
            left: 0;
            width: 100%;
            height: 72px;
            background: #BC1823;
            clip-path: polygon(0 40%, 100% 0, 100% 100%, 0 100%);
        }

        .shape-black-bottom-1 {
            position: absolute;
            bottom: 0;
            left: 0;
            width: 35%;
            height: 72px;
            background: #111827;
            clip-path: polygon(0 0, 70% 100%, 0 100%);
        }

        .shape-black-bottom-2 {
            position: absolute;
            bottom: 0;
            left: 0;
            width: 18%;
            height: 72px;
            background: #1f2937;
            clip-path: polygon(0 0, 50% 100%, 0 100%);
        }

        .footer-branding {
            position: absolute;
            bottom: 10px;
            width: 100%;
            text-align: center;
            font-size: 9px;
            font-weight: 800;
            color: white;
            letter-spacing: 1px;
            text-transform: uppercase;
            z-index: 2;
        }

        /* ─── PRINT STYLES ─── */
        @@media print {
            @@page {
                size: A4 portrait;
                margin: 0;
            }

            html, body {
                margin: 0 !important;
                padding: 0 !important;
                width: 210mm !important;
                height: 297mm !important;
                overflow: hidden !important;
                background: white !important;
                -webkit-print-color-adjust: exact !important;
                print-color-adjust: exact !important;
            }

            .no-print {
                display: none !important;
            }

            #invoiceViewWrapper {
                padding: 0 !important;
                margin: 0 !important;
                display: block !important;
                background: white !important;
            }

            #printableInvoice {
                width: 210mm !important;
                height: 297mm !important;
                min-height: 297mm !important;
                transform: none !important;
                margin: 0 !important;
                padding: 0 !important;
                box-shadow: none !important;
                border: none !important;
                display: flex !important;
                flex-direction: column !important;
                overflow: hidden !important;
                page-break-after: avoid !important;
                page-break-inside: avoid !important;
            }
            /* Ensure footer stays at bottom during print */
            .footer-wrapper {
                margin-top: auto !important;
            }
        }
    </style>
</head>
<body>
    <div class="no-print">
        <button onclick="window.print()"
                style="background:#BC1823;color:white;border:none;padding:0.75rem 1.5rem;border-radius:6px;cursor:pointer;font-weight:800;font-family:'Montserrat',sans-serif;font-size:14px;">
            PRINT INVOICE
        </button>
    </div>

    <div id="invoiceViewWrapper">
        <div class="invoice-container" id="printableInvoice">

            <!-- ── TOP DECORATIVE PATTERN ── -->
            <div class="top-pattern">
                <div class="shape-red-top"></div>
                <div class="shape-black-top-1"></div>
                <div class="shape-black-top-2"></div>
            </div>

            <!-- ── HEADER ── -->
            <div class="header-content">
                <div class="logo-section">
                    <div class="logo-box">
                        <img src="/images/sata-logo.png" alt="SATA Logo" />
                    </div>
                </div>
                <div class="invoice-title-section">
                    <div class="invoice-label">Invoice</div>
                    <div class="invoice-no"># @(Model.invoice_no ?? Model.id.ToString())</div>
                </div>
            </div>

            <!-- ── BILLING ── -->
            <div class="details-section">
                <div class="billing-box">
                    <div class="section-label">Invoice To:</div>
                    <div class="billing-details">
                        <div class="billing-name">@Model.customer_name</div>
                        <div>@Model.customer_address</div>
                        <div>Phone: @Model.customer_contact</div>
                    </div>
                </div>
                <div class="billing-box text-right">
                    <div class="section-label">Invoice From:</div>
                    <div class="billing-details">
                        <div class="billing-name">@Model.seller_name</div>
                        <div>@Model.seller_address</div>
                        <div>Phone: @Model.seller_contact</div>
                        <div style="font-weight:800;color:#111827;margin-top:5px;">
                            Date: @Model.date.ToString("dd MMM yyyy")
                        </div>
                    </div>
                </div>
            </div>

            <!-- ── INFO BAR ── -->
            <div class="info-bar">
                <div class="info-item">
                    <div class="info-label">Status</div>
                    <div class="info-value">
                        <span class="status-badge"
                              style="background:@(Model.status == "Paid" ? "#059669" : "#BC1823")">
                            @(Model.status ?? "PENDING")
                        </span>
                    </div>
                </div>
                <div class="info-item">
                    <div class="info-label">Payment Method</div>
                    <div class="info-value">@(Model.payment ?? "Not Specified")</div>
                </div>
            </div>

            <!-- ── ITEMS TABLE ── -->
            <div class="items-section">
                <table>
                    <thead>
                        <tr>
                            <th width="50%" class="c-desc" style="text-align:left;">Products/Services</th>
                            <th class="text-center c-price">Price</th>
                            <th class="text-center c-qty">Qty/Unit type</th>
                            <th class="text-right c-total">Total Price</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (isMultiItem)
                        {
                            foreach (var item in items)
                            {
                                <tr>
                                    <td class="c-desc">
                                        <div class="item-name">@item["name"]</div>
                                        <div class="item-expiry">Expiry: @(item.ContainsKey("expiryDate") ? item["expiryDate"] : "N/A")</div>
                                    </td>
                                    <td class="text-center c-price">$@(((decimal)item["price"]).ToString("N2"))</td>
                                    <td class="text-center c-qty">@item["qty"]</td>
                                    <td class="text-right c-total" style="font-weight:800;">$@(((decimal)item["total"]).ToString("N2"))</td>
                                </tr>
                            }
                        }
                        else
                        {
                            <tr>
                                <td class="c-desc">
                                    <div class="item-name">@Model.prod_name_service</div>
                                    <div class="item-expiry">Expiry: @(ViewBag.SingleItemExpiry ?? "N/A")</div>
                                </td>
                                <td class="text-center c-price">$@Model.price.ToString("N2")</td>
                                <td class="text-center c-qty">@Model.qty_unit_type</td>
                                <td class="text-right c-total" style="font-weight:800;">$@((Model.price - Model.discount).ToString("N2"))</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>

            <!-- ── BOTTOM SECTION (terms + totals) ── -->
            <div class="bottom-section">
                <div class="terms-block">
                    <div class="terms-title">Terms &amp; Conditions</div>
                    <div class="terms-text">
                        Please make payment within 15 days of receiving this invoice.<br />
                        Thank you for choosing SATA TECHNOLOGIES for your business needs.
                    </div>
                    <div class="signature-box">
                        <div class="signature-line">Authorized Signature</div>
                    </div>
                </div>
                <div class="summary-box">
                    <div class="summary-row">
                        <span class="s-lbl">Sub Total</span>
                        <span class="s-val">$@subtotal.ToString("N2")</span>
                    </div>
                    <div class="summary-row">
                        <span class="s-lbl">Discount</span>
                        <span class="s-val s-val-disc">$@discount.ToString("N2")</span>
                    </div>
                    <hr class="summary-divider" />
                    <div class="summary-total">
                        <span>Grand Total</span>
                        <span>$@totalAmount.ToString("N2")</span>
                    </div>
                </div>
            </div>

            <!-- ── FOOTER (always at bottom of A4) ── -->
            <div class="footer-wrapper">
                <div class="bottom-pattern">
                    <div class="shape-red-bottom"></div>
                    <div class="shape-black-bottom-1"></div>
                    <div class="shape-black-bottom-2"></div>
                </div>
                <div class="footer-branding">SATA E-Invoice System &mdash; Innovating the Future</div>
            </div>

        </div>
    </div>
</body>
</html>
