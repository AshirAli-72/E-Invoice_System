@using System.Text.Json
@model E_Invoice_system.Models.invoices

@{
    Layout = null;
    var subtotal = Model.price;
    var discount = Model.discount;
    var totalAmount = Model.total_price;

    var isMultiItem = false;
    List<Dictionary<string, object>> items = new List<Dictionary<string, object>>();

    try
    {
        if (!string.IsNullOrEmpty(Model.prod_name_service) &&
            Model.prod_name_service.Trim().StartsWith("["))
        {
            var jsonElements = JsonSerializer.Deserialize<List<Dictionary<string, JsonElement>>>(Model.prod_name_service);
            if (jsonElements != null && jsonElements.Count > 0)
            {
                isMultiItem = true;
                foreach (var item in jsonElements)
                {
                    var newItem = new Dictionary<string, object>();
                    foreach (var kvp in item)
                    {
                        if (kvp.Value.ValueKind == JsonValueKind.Number)
                            newItem[kvp.Key] = kvp.Value.GetDecimal();
                        else if (kvp.Value.ValueKind == JsonValueKind.String)
                            newItem[kvp.Key] = kvp.Value.GetString() ?? "";
                        else
                            newItem[kvp.Key] = kvp.Value.ToString();
                    }
                    items.Add(newItem);
                }
                if (subtotal == 0 && items.Any())
                    subtotal = items.Sum(i => (decimal)i["price"] * (decimal)i["qty"]);
            }
        }
    }
    catch { isMultiItem = false; }
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>THE SATA INVOICE - Receipt</title>
    <style>
        /* ===== THERMAL RECEIPT STYLES - Pic 1 Exact Match ===== */
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            background: #f0f0f0;
            display: flex;
            justify-content: center;
            align-items: flex-start;
            min-height: 100vh;
            padding: 20px;
            font-family: 'Verdana', sans-serif;
            font-weight: 900;
        }

        /* Print button (hidden on print) */
        .print-btn {
            position: fixed;
            top: 20px;
            right: 20px;
            background: #000;
            color: #fff;
            border: none;
            padding: 12px 28px;
            font-family: 'Verdana', sans-serif;
            font-size: 14px;
            font-weight: 900;
            cursor: pointer;
            letter-spacing: 1px;
            z-index: 999;
        }

        /* ===== RECEIPT WRAPPER ===== */
        #thermalReceipt {
            width: 185mm;
            padding: 10mm;
            background: white;
            font-family: 'Verdana', sans-serif;
            color: black;
            line-height: 1.2;
        }

        /* ===== TOP BANNER: Date left, Order# right ===== */
        .receipt-top-banner {
            margin-bottom: 5px;
            display: flex;
            justify-content: space-between;
            font-size: 14pt;
            font-weight: 900;
            padding: 5px 0;
        }

        /* ===== SHOP INFO BLOCK ===== */
        .shop-info-block {
            text-align: center;
            margin-bottom: 20px;
        }

        .shop-info-block h1 {
            margin: 5px 0;
            font-size: 34pt;
            font-weight: 900;
            text-transform: uppercase;
            letter-spacing: 1px;
        }

        .shop-info-block .sub-info {
            font-size: 20pt;
            font-weight: 900;
            margin: 2px 0;
        }

        .line-divider {
            border-top: 2.5pt solid black;
            margin: 10px 0;
        }

        /* ===== META LINES: Cashier, Customer ===== */
        .meta-line {
            font-size: 17pt;
            font-weight: 900;
            margin: 4px 0;
            text-align: left;
        }

        /* ===== ITEMS TABLE ===== */
        .receipt-table-v3 {
            width: 100%;
            border-collapse: collapse;
            margin: 15px 0;
            border-top: 2.5pt solid black;
            border-bottom: 2.5pt solid black;
        }

        .receipt-table-v3 th {
            font-size: 17pt;
            font-weight: 900;
            padding: 10px 0;
            text-transform: uppercase;
        }

        .receipt-table-v3 td {
            font-size: 17pt;
            font-weight: 900;
            padding: 8px 0;
        }

        /* ===== TOTALS AREA ===== */
        .totals-area {
            width: 100%;
            font-size: 18pt;
            font-weight: 900;
            margin-top: 10px;
        }

        .totals-row {
            display: flex;
            justify-content: space-between;
            margin-bottom: 8px;
            padding-left: 20%; /* Align labels more towards the middle-right like Pic 1 */
        }

        /* ===== FOOTER ===== */
        .footer-section {
            margin-top: 20px;
            text-align: center;
            clear: both;
        }

        .footer-line {
            border-top: 2pt solid black;
            margin: 8px 0;
        }

        .footer-msg {
            font-size: 22pt;
            font-weight: 900;
            margin: 10px 0;
            text-transform: uppercase;
        }

        .footer-promo {
            font-size: 16pt;
            font-weight: 900;
            margin: 12px 0;
        }

        .footer-copy {
            font-size: 11pt;
            font-weight: 900;
            margin: 8px 0;
            text-transform: uppercase;
        }

        .text-center { text-align: center; }
        .text-right  { text-align: right; }
        .text-left   { text-align: left; }

        /* ===== PRINT STYLES ===== */
        @@media print {
            @@page {
                size: A4;
                margin: 0;
            }

            html, body {
                margin: 0 !important;
                padding: 0 !important;
                width: 100% !important;
                background: #fff !important;
                display: flex !important;
                justify-content: center !important;
                align-items: flex-start !important;
            }

            .print-btn {
                display: none !important;
            }

            #thermalReceipt {
                display: block !important;
                width: 185mm !important;
                margin: 0 auto !important;
                padding: 10mm !important;
                box-sizing: border-box !important;
                background: white !important;
                font-family: 'Verdana', sans-serif !important;
                color: black !important;
                border: none !important;
            }

            #thermalReceipt * {
                visibility: visible !important;
            }
        }
    </style>
</head>
<body>

    <button class="print-btn" onclick="window.print()">🖨 PRINT RECEIPT</button>

    <!-- ===== RECEIPT ===== -->
    <div id="thermalReceipt">

        <!-- Top Banner -->
        <div class="receipt-top-banner">
            <span id="receiptDate">@Model.date.ToString("M/d/yyyy h:mm:ss tt").ToUpper()</span>
            <span id="receiptOrderNo">ORDER: @(Model.invoice_no ?? Model.id.ToString())</span>
        </div>

        <!-- Shop Info -->
        <div class="shop-info-block">
            <h1 id="receiptShopTitle">@Model.seller_name</h1>
            <div class="sub-info">@Model.seller_address</div>
            <div class="sub-info">@Model.seller_contact</div>
        </div>

        <div class="line-divider"></div>

        <!-- Meta -->
        <div class="meta-line">Cashier: nill</div>
        <div class="meta-line">Customer: <span id="receiptCustomerName">@(string.IsNullOrEmpty(Model.customer_name) ? "Walk-In" : Model.customer_name)</span></div>

        <!-- Items Table -->
        <table class="receipt-table-v3">
            <thead>
                <tr>
                    <th class="text-left"  style="width: 45%;">PRODUCT</th>
                    <th class="text-center" style="width: 15%;">QTY</th>
                    <th class="text-center" style="width: 20%;">PRICE</th>
                    <th class="text-right"  style="width: 20%;">AMOUNT</th>
                </tr>
            </thead>
            <tbody id="receiptItemsBody">
                @if (isMultiItem)
                {
                    foreach (var item in items)
                    {
                        <tr>
                            <td class="text-left">@item["name"]</td>
                            <td class="text-center">@item["qty"]</td>
                            <td class="text-center">@(((decimal)item["price"]).ToString("0"))</td>
                            <td class="text-right">@(((decimal)item["total"]).ToString("0"))</td>
                        </tr>
                    }
                }
                else
                {
                    <tr>
                        <td class="text-left">@Model.prod_name_service</td>
                        <td class="text-center">@Model.qty_unit_type</td>
                        <td class="text-center">@Model.price.ToString("0")</td>
                        <td class="text-right">@((Model.price - Model.discount).ToString("0"))</td>
                    </tr>
                }
            </tbody>
        </table>

        <!-- Totals -->
        <div class="totals-area">
            <div class="totals-row">
                <span>TOTAL</span>
                <span id="receiptTotalVal">$@totalAmount.ToString("0")</span>
            </div>
            <div class="totals-row">
                <span>AMOUNT DUE</span>
                <span id="receiptDueVal">$@(totalAmount.ToString("0"))</span>
            </div>
            <div class="totals-row">
                <span>CASH</span>
                <span id="receiptTenderedVal">$@totalAmount.ToString("0")</span>
            </div>
            <div class="totals-row">
                <span>PAY TYPE</span>
                <span id="receiptPayType">@(Model.payment ?? "Cash")</span>
            </div>
        </div>

        <div class="line-divider" style="margin-top: 5px;"></div>

        <!-- Footer -->
        <div class="footer-section">
            <div class="footer-msg">THANK YOU!</div>
            <div class="footer-line"></div>
            <div class="footer-promo">*** Refer a Friend To Smoke Drop &amp; Get 5% off. ***</div>
            <div class="footer-line"></div>
            <div class="footer-copy">Copyrights 2023, Powered by The SATA POS</div>
            <div class="footer-line"></div>
        </div>

    </div><!-- end #thermalReceipt -->

</body>
</html>

