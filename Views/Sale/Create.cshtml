@model E_Invoice_system.Models.Sale
@{
    Layout = "_SaleLayout";
    var customerList = ViewBag.Customers as List<E_Invoice_system.Models.customers>;
    var products = ViewBag.Products as List<E_Invoice_system.Models.ProductService>;
}

<!-- Select2 CSS -->
<link href="https://cdn.jsdelivr.net/npm/select2@4.1.0-rc.0/dist/css/select2.min.css" rel="stylesheet" />

<style>
    .return-warning-banner {
        display: none;
    }

    /* ── Customer search ── */
    .customer-search-container {
        position: relative;
        flex: 1;
        display: flex;
        flex-direction: column;
    }

    .customer-search-input-wrapper {
        position: relative;
        background: #f8fafc;
        border: 1px solid #e2e8f0;
        border-radius: 12px;
        height: 44px;
        display: flex;
        align-items: center;
        padding: 0 12px;
        gap: 8px;
        transition: all .2s;
    }

        .customer-search-input-wrapper:focus-within {
            border-color: var(--primary);
            background: #fff;
            box-shadow: 0 0 0 4px var(--primary-glow);
        }

        .customer-search-input-wrapper i {
            color: var(--text-muted);
            font-size: 1.25rem;
        }

    .customer-search-input {
        background: transparent;
        border: none;
        width: 100%;
        height: 100%;
        font-weight: 600;
        font-size: .95rem;
        color: var(--text-main);
        outline: none;
    }

    .customer-dropdown-results {
        position: absolute;
        top: 100%;
        left: 0;
        right: 0;
        background: white;
        border: 1px solid var(--border);
        border-radius: 12px;
        box-shadow: 0 10px 25px rgba(0,0,0,.1);
        margin-top: 4px;
        max-height: 300px;
        overflow-y: auto;
        z-index: 1000;
        display: none;
        scrollbar-width: none;
        -ms-overflow-style: none;
    }

        .customer-dropdown-results::-webkit-scrollbar {
            display: none;
        }

        .customer-dropdown-results.show {
            display: block;
        }

    .customer-result-item {
        padding: 12px 16px;
        cursor: pointer;
        transition: all .2s;
        border-bottom: 1px solid #f8fafc;
    }

        .customer-result-item:last-child {
            border-bottom: none;
        }

        .customer-result-item:hover,
        .customer-result-item.highlighted {
            background-color: var(--primary-glow);
            color: var(--primary);
        }

        .customer-result-item .cust-name {
            font-weight: 600;
            display: block;
        }

        .customer-result-item .cust-details {
            font-size: .8rem;
            color: var(--text-muted);
        }

    /* ══════════════════════════════════════════════
           RECEIPT  — pixel-matched to screenshot
           Font : Courier New  |  Width: 190mm on print
        ══════════════════════════════════════════════ */
    #thermalReceipt {
        display: none;
        width: 190mm;
        padding: 6mm 8mm;
        font-family: 'Courier New', Courier, monospace;
        color: #000;
        background: #fff;
        box-sizing: border-box;
    }

    /* Shop header */
    .rcpt-shop-header {
        text-align: center;
        line-height: 1.35;
        margin-bottom: 4px;
    }

    .rcpt-shop-name {
        display: block;
        font-size: 20pt;
        font-weight: 900;
        letter-spacing: 1px;
        text-transform: uppercase;
    }

    .rcpt-shop-sub {
        display: block;
        font-size: 10pt;
        font-weight: 700;
        margin: 1px 0;
    }

    /* Separator */
    .rcpt-hr {
        border: none;
        border-top: 1.5pt solid #000;
        margin: 4px 0;
    }

    /* Meta lines */
    .rcpt-meta {
        font-size: 11pt;
        font-weight: 800;
        margin: 3px 0;
        line-height: 1.4;
    }

    /* Items table */
    .rcpt-table {
        width: 100%;
        border-collapse: collapse;
        margin: 4px 0;
    }

        .rcpt-table thead th {
            border-top: 2pt solid #000;
            border-bottom: 2pt solid #000;
            padding: 4px 2px;
            font-size: 10pt;
            font-weight: 900;
            text-transform: uppercase;
        }

        .rcpt-table tbody td {
            font-size: 10.5pt;
            padding: 4px 2px;
            vertical-align: top;
        }

    .rcpt-col-prod {
        width: 50%;
        text-align: left;
    }

    .rcpt-col-qty {
        width: 12%;
        text-align: center;
    }

    .rcpt-col-price {
        width: 18%;
        text-align: right;
    }

    .rcpt-col-amt {
        width: 20%;
        text-align: right;
    }

    /* Totals */
    .rcpt-totals-row {
        display: flex;
        justify-content: space-between;
        font-size: 11pt;
        font-weight: 800;
        padding: 3px 2px;
        line-height: 1.3;
    }

    /* Footer */
    .rcpt-footer {
        text-align: center;
        margin-top: 4px;
    }

    .rcpt-footer-thankyou {
        font-size: 14pt;
        font-weight: 900;
        letter-spacing: 2px;
        text-transform: uppercase;
        margin: 4px 0;
    }

    .rcpt-footer-promo {
        font-size: 9pt;
        font-weight: 700;
        margin: 3px 0;
    }

    .rcpt-footer-copy {
        font-size: 8pt;
        font-weight: 600;
        margin: 2px 0;
    }

    /* Bottom row: order info + barcode */
    .rcpt-bottom {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-top: 8px;
    }

        .rcpt-bottom .order-info {
            font-size: 10pt;
            font-weight: 800;
            line-height: 1.7;
        }

    /* ── Toggle Switch ── */
    .toggle-switch {
        position: relative;
        display: inline-block;
        width: 48px;
        height: 26px;
        flex-shrink: 0;
    }
    .toggle-switch input { opacity: 0; width: 0; height: 0; }
    .toggle-slider {
        position: absolute;
        cursor: pointer;
        top: 0; left: 0; right: 0; bottom: 0;
        background: #cbd5e1;
        border-radius: 26px;
        transition: .3s;
    }
    .toggle-slider:before {
        position: absolute;
        content: "";
        height: 20px; width: 20px;
        left: 3px; bottom: 3px;
        background: white;
        border-radius: 50%;
        transition: .3s;
        box-shadow: 0 1px 3px rgba(0,0,0,.2);
    }
    .toggle-switch input:checked + .toggle-slider { background: var(--primary, #6366f1); }
    .toggle-switch input:checked + .toggle-slider:before { transform: translateX(22px); }

    /* ── PRINT ── */
    @@media print {
        @@page {
            size: A4;
            margin: 8mm;
        }

        html, body {
            margin: 0 !important;
            padding: 0 !important;
            background: #fff !important;
        }

        .pos-container-v2, .modal-overlay,
        header, footer, nav,
        .quick-actions-v2, .btn-pay-v2, button {
            display: none !important;
        }

        #thermalReceipt {
            display: block !important;
            width: 190mm !important;
            margin: 0 auto !important;
            padding: 6mm 8mm 8mm 8mm !important;
            box-sizing: border-box !important;
            background: white !important;
            color: black !important;
            border: none !important;
        }

            #thermalReceipt * {
                visibility: visible !important;
            }
        .barcode-container {
            display: flex;
            justify-content: center;
            margin-top: 12px;
        }

        #rcptBarcodeSvg {
            background: #fff;
            shape-rendering: crispEdges;
            image-rendering: pixelated;
        }
    }
</style>

<!-- ═══════════════════════════════════════════
     POS LAYOUT
═══════════════════════════════════════════ -->
<div class="pos-container-v2">
    <div class="product-canvas">
        <div class="canvas-header">
            <div class="canvas-header-top">
                <h3 class="canvas-title">Sales Transaction</h3>
                <div class="search-bar-v2">
                    <i class="ph-magnifying-glass search-icon"></i>
                    <input type="text" id="prodSearch" class="search-input"
                           placeholder="Scan or enter barcode..." oninput="filterProducts()">
                </div>
                <!-- Invoice Search for Returns -->
                <div class="search-bar-v2" style="max-width:200px; border-color:var(--primary);">
                    <i class="ph-receipt search-icon" style="color:var(--primary);"></i>
                    <input type="text" id="billNoSearch" class="search-input"
                           placeholder="Return Bill No..." onkeydown="handleBillSearch(event)">
                </div>
                <div class="mode-toggle-v2 compact">
                    <div class="toggle-pill">
                        <input type="radio" id="searchName" name="searchMode" value="name" onchange="handleSearchModeChange()">
                        <label for="searchName">Name</label>
                        <input type="radio" id="searchBarcode" name="searchMode" value="barcode" checked onchange="handleSearchModeChange()">
                        <label for="searchBarcode">Barcode</label>
                    </div>
                </div>
                <div class="quick-actions-v2">
                    <button type="button" class="btn-action-round" onclick="reloadPage()" title="Refresh"><i class="ph-arrows-clockwise"></i></button>
                    <button type="button" class="btn-action-round" onclick="toggleFullScreen()" title="Full Screen"><i class="ph-corners-out"></i></button>
                    <a href="/Home/Index" class="btn-action-round back" title="Back to Dashboard"><i class="ph-arrow-left"></i></a>
                </div>
            </div>
            <div class="category-tabs-v2">
                <div class="tab-item active" onclick="filterByCategory('all', this)">All</div>
                <div class="tab-item" onclick="filterByCategory('Foods', this)">Products</div>
                <div class="tab-item" onclick="filterByCategory('Beverages', this)">Services</div>
            </div>
        </div>

        <div class="product-grid-v2" id="productGrid">
            @if (products != null)
            {
                foreach (var p in products)
                {
                    decimal stockValue = 0;
                    string unitLabel = "";
                    bool isService = false;
                    if (!string.IsNullOrEmpty(p.qty_unit_type))
                    {
                        var match = System.Text.RegularExpressions.Regex.Match(p.qty_unit_type.Trim(), @"^([0-9.-]+)\s*(.*)$");
                        if (match.Success)
                        {
                            decimal.TryParse(match.Groups[1].Value, out stockValue);
                            unitLabel = match.Groups[2].Value.Trim();
                            if (!string.IsNullOrEmpty(unitLabel)) { isService = true; stockValue = 999999; }
                        }
                        else { isService = true; stockValue = 999999; }
                    }
                    else { isService = true; stockValue = 999999; }

                    <div class="product-card-v2"
                         data-id="@p.id" data-name="@p.prod_name_service"
                         data-search-name="@p.prod_name_service.ToLower()"
                         data-barcode="@(p.barcode ?? "")" data-price="@p.price"
                         data-discount="@p.discount"
                         data-expiry="@(p.expiry_date?.ToString("yyyy-MM-dd") ?? "")"
                         data-stock="@stockValue" data-type="@(isService ? "service" : "product")"
                         data-image="@(p.image ?? "")" onclick="addToSaleFromCard(this)">
                        <div class="card-image">
                            @if (!string.IsNullOrEmpty(p.image))
                            {
                                <img src="/product-images/@p.image" alt="Product" />
                            }
                            else
                            {
                                <div class="image-placeholder">
                                    <i class="@(isService ? "ph-wrench" : "ph-cube-transparent")"
                                       style="font-size:3rem;color:#cbd5e1;"></i>
                                </div>
                            }
                        </div>
                        <div class="card-info">
                            <h4 class="card-name">@p.prod_name_service</h4>
                            <div class="card-price-row">
                                <span class="price-tag">$@p.price.ToString("N2")</span>
                                @if (p.discount > 0)
                                {
                                    <span class="discount-pill">$@p.discount.ToString("N2")</span>
                                }
                            </div>
                        </div>
                    </div>
                }
            }
        </div>
    </div>

    <!-- ═══ CHECKOUT PANEL ═══ -->
    <div class="checkout-center">
        <form asp-action="Create" method="post" id="saleForm" class="checkout-form">
            @Html.AntiForgeryToken()
            <input type="hidden" name="payment_method" id="hiddenPaymentMethod" value="Cash" />
            <input type="hidden" name="status" id="hiddenStatus" value="Paid" />
            <input type="hidden" name="billNo" id="hiddenBillNo" value="" />

            <div class="checkout-header">
                <div class="return-warning-banner"><i class="ph-warning"></i> RETURN MODE ACTIVE</div>
                <div class="checkout-header-main">
                    <div>
                        <h3 class="order-detail-title">Order Detail</h3>
                        <div id="itemCountDisplay" class="item-count-badge">0 items selected</div>
                    </div>
                    <div class="checkout-header-actions">
                        <div class="mode-toggle-v2 compact">
                            <div class="toggle-pill">
                                <input type="radio" id="modeSale" name="transMode" value="sale" checked onchange="handleModeChange()">
                                <label for="modeSale">Sale</label>
                                <input type="radio" id="modeReturn" name="transMode" value="return" onchange="handleModeChange()">
                                <label for="modeReturn">Return</label>
                            </div>
                        </div>
                        <button type="button" class="btn-clear-v2" onclick="clearSaleItems()" title="Clear Order">
                            <i class="ph-trash"></i>
                        </button>
                    </div>
                </div>
            </div>

            <div class="customer-selector-v2">
                <div class="customer-search-container">
                    <div class="customer-search-input-wrapper">
                        <i class="ph-user-circle"></i>
                        <input type="text" id="customerSearchInput" class="customer-search-input"
                               placeholder="Search Customer..." autocomplete="off" />
                        <input type="hidden" name="customer_name" id="customerSelect" value="Walk-In" />
                    </div>
                    <div id="customerResults" class="customer-dropdown-results shadow-luxury"></div>
                </div>
                <button type="button" onclick="triggerCustomerModalV2(event)"
                        title="Add New Customer" class="btn-add-customer">
                    <i class="ph-plus"></i><span>Add Customer</span>
                </button>
            </div>

            <div class="checkout-items-v2" id="saleItemsBody"></div>
            <div id="emptyStateV2" class="empty-state-v2">
                <div class="empty-glow"></div>
                <i class="ph-shopping-cart-simple"></i>
                <p>Bag is empty</p>
            </div>

            <div class="checkout-footer-v2">
                <div class="price-summary-v2">
                    <div class="summary-line"><span>Subtotal</span><span id="subtotalDisplay">$0.00</span></div>
                    <div class="summary-line" style="color:var(--success);"><span>Discount</span><span id="discountDisplay">$0.00</span></div>
                    <div id="stockAlert" class="alert-v2" style="display:none;">
                        <i class="ph-warning"></i> <span id="stockAlertMsg"></span>
                    </div>
                    <div class="grand-total-row">
                        <div class="total-label">Grand Total</div>
                        <div class="total-value" id="grandTotal">$0.00</div>
                    </div>
                </div>
                <div id="hiddenInputsContainer"></div>
                <button type="button" class="btn-pay-v2" onclick="openPaymentModal()">
                    <i class="ph-credit-card"></i> Payment
                </button>
            </div>
        </form>
    </div>
</div>

<!-- ═══ PAYMENT MODAL ═══ -->
<div class="modal-overlay" id="paymentModal">
    <div class="payment-card">
        <div class="payment-left">
            <h1 class="payment-title">Checkout</h1>
            <p class="payment-subtitle">Complete your transaction by selecting a payment method.</p>
            <div class="method-tabs">
                <div class="method-tab active" id="btnCash" onclick="setWebPaymentMethod('Cash')">    <i class="ph-money"></i>       <span>Cash</span></div>
                <div class="method-tab" id="btnCard" onclick="setWebPaymentMethod('Card')">    <i class="ph-credit-card"></i> <span>Card</span></div>
                <div class="method-tab" id="btnTransfer" onclick="setWebPaymentMethod('Transfer')"><i class="ph-bank"></i>        <span>Bank</span></div>
                <div class="method-tab" id="btnCredit" onclick="setWebPaymentMethod('Credit')"> <i class="ph-user-focus"></i>  <span>Credit</span></div>
            </div>
            <div class="web-input-group">
                <label>Amount Tendered</label>
                <input type="number" id="webTendered" class="web-input"
                       placeholder="0.00" oninput="calculateWebChange()" step="0.01">
                <div class="quick-pills">
                    <div class="quick-pill" onclick="addWebAmount(10)">+ $10</div>
                    <div class="quick-pill" onclick="addWebAmount(20)">+ $20</div>
                    <div class="quick-pill" onclick="addWebAmount(50)">+ $50</div>
                    <div class="quick-pill" onclick="addWebAmount(100)">+ $100</div>
                    <div class="quick-pill" onclick="addWebAmount(500)">+ $500</div>
                    <div class="quick-pill" onclick="addWebAmount(1000)">+ $1000</div>
                    <div class="quick-pill" onclick="addWebAmount(5000)">+ $5000</div>
                    <div class="quick-pill" onclick="matchWebAmount()">Match Total</div>
                </div>
            </div>
            <div class="web-input-group">
                <label>Reference / Note</label>
                <input type="text" name="notes" class="web-input" placeholder="Transaction notes (optional)">
            </div>
        </div>
        <div class="payment-right">
            <div class="summary-box-web">
                <div class="summary-web-line">
                    <span style="color:var(--text-muted);font-weight:600;">Total Amount Due</span>
                    <span id="webModalTotal" style="font-weight:700;">$0.00</span>
                </div>
                <div class="summary-web-line" style="margin-top:8px;">
                    <span style="color:var(--text-muted);font-weight:600;">Total Tendered</span>
                    <span id="webModalTendered" style="font-weight:700;">$0.00</span>
                </div>
                <div class="summary-web-line grand"><span>Change Due</span><span id="webModalChange">$0.00</span></div>
                <!-- Print Receipt Toggle -->
                <div style="display:flex;align-items:center;justify-content:space-between;margin-top:18px;padding:12px 16px;background:var(--surface);border-radius:10px;border:1px solid var(--border);">
                    <label for="printReceiptToggle" style="font-weight:600;color:var(--text-main);cursor:pointer;display:flex;align-items:center;gap:8px;">
                        <i class="ph-printer" style="font-size:1.2rem;color:var(--primary);"></i> Print Receipt
                    </label>
                    <label class="toggle-switch">
                        <input type="checkbox" id="printReceiptToggle" checked>
                        <span class="toggle-slider"></span>
                    </label>
                </div>
            </div>
            <div style="margin-top:auto;">
                <p style="font-size:.75rem;color:var(--text-muted);text-align:center;margin-bottom:24px;line-height:1.5;">
                    By completing this order, you agree to generate an official invoice and update stock levels.
                </p>
                <div style="display:flex;gap:16px;">
                    <button type="button" class="btn-confirm-web"
                            style="flex:1;background:#ef4444;color:#fff;border:none;font-size:1rem;font-weight:700;"
                            onclick="closePaymentModal()">
                        Cancel
                    </button>
                    <button type="button" class="btn-confirm-web"
                            style="flex:1;background:#22c55e;color:#fff;border:none;font-size:1rem;font-weight:700;"
                            onclick="askToPrintReceipt()">
                        Complete Order <i class="ph-check-circle"></i>
                    </button>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- ═══ CUSTOM ITEM MODAL ═══ -->
<div class="modal-overlay" id="customItemModal">
    <div class="payment-card" style="max-width:500px;width:90%;align-items:stretch;flex-direction:column;">
        <div style="padding:32px;">
            <h2 style="margin:0 0 24px 0;color:var(--text-main);font-size:1.5rem;">Add Custom Item</h2>
            <div class="web-input-group">
                <label>Item Name / Description</label>
                <input type="text" id="customName" class="web-input" placeholder="e.g. Delivery Charge">
            </div>
            <div class="web-input-group">
                <label>Price</label>
                <input type="number" id="customPrice" class="web-input" placeholder="0.00" step="0.01">
            </div>
            <div style="display:flex;gap:16px;margin-top:32px;">
                <button type="button" class="btn-confirm-web"
                        style="flex:1;background:#ef4444;color:#fff;border:none;font-size:1rem;font-weight:700;"
                        onclick="closeCustomItemModal()">
                    Cancel
                </button>
                <button type="button" class="btn-confirm-web"
                        style="flex:1;background:#22c55e;color:#fff;border:none;font-size:1rem;font-weight:700;"
                        onclick="addCustomItem()">
                    Add to Order
                </button>
            </div>
        </div>
    </div>
</div>

<!-- ═══ ADD CUSTOMER MODAL ═══ -->
<div class="modal-overlay" id="customerModal">
    <div class="payment-card"
         style="max-width:900px;width:95%;align-items:stretch;flex-direction:column;overflow-y:auto;max-height:90vh;padding:40px;">
        <div class="dashboard-panel">
            <div class="page-header">
                <h1 class="page-title-large">Add New Customer</h1>
                <button type="button" class="btn-secondary" onclick="closeCustomerModal()">
                    <i class="ph-arrow-left"></i> Back
                </button>
            </div>
            <div class="form-wrapper form-layout-left-wide">
                <div class="form-section">
                    <div class="form-section-header">
                        <h3 class="form-section-title">
                            <i class="ph-users form-icon-primary"></i> Customer Information
                        </h3>
                    </div>
                    <div class="form-group">
                        <label class="form-label">Full Name</label>
                        <input type="text" id="newCustName" class="form-control" placeholder="Enter customer's full name" required />
                    </div>
                    <div class="form-group">
                        <label class="form-label">Contact Number</label>
                        <input type="text" id="newCustContact" class="form-control" placeholder="Enter contact number" />
                    </div>
                    <div class="form-group">
                        <label class="form-label">Email Address</label>
                        <input type="email" id="newCustEmail" class="form-control" placeholder="Enter email address" />
                    </div>
                    <div class="form-group">
                        <label class="form-label">Address</label>
                        <textarea id="newCustAddress" class="form-control" rows="3" placeholder="Enter physical address"></textarea>
                    </div>
                    <div class="form-group">
                        <label class="form-label">Status</label>
                        <select id="newCustStatus" class="form-control">
                            <option value="Active">Active</option>
                            <option value="Inactive">Inactive</option>
                        </select>
                    </div>
                </div>
                <div class="form-actions-sticky" style="display:flex;gap:16px;margin-top:32px;">
                    <button type="button" class="btn-confirm-web"
                            style="flex:1;background:#ef4444;color:#fff;border:none;font-size:1rem;font-weight:700;"
                            onclick="closeCustomerModal()">
                        Cancel
                    </button>
                    <button type="button" class="btn-confirm-web"
                            style="flex:1;background:#22c55e;color:#fff;border:none;font-size:1rem;font-weight:700;"
                            onclick="saveCustomerAjax()">
                        <i class="ph-check"></i> Save Customer
                    </button>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Print Confirm Modal removed — using toggle in payment form instead -->


<!-- ═══════════════════════════════════════════
     RECEIPT HTML  (hidden — shown only on print)
═══════════════════════════════════════════ -->
<div id="thermalReceipt">

    <!-- Shop Header -->
    <div class="rcpt-shop-header">
        <span class="rcpt-shop-name">THE SATA Invoice</span>
        <span class="rcpt-shop-sub">@ViewBag.SellerAddress</span>
        <span class="rcpt-shop-sub">@ViewBag.SellerContact</span>
    </div>

    <hr class="rcpt-hr" />

    <!-- Cashier / Customer -->
    <div class="rcpt-meta">Cashier: @(User.Identity?.Name ?? "nill")</div>
    <div class="rcpt-meta">Customer: <span id="rcptCustomer">Walk-In</span></div>

    <!-- Items table -->
    <table class="rcpt-table">
        <thead>
            <tr>
                <th class="rcpt-col-prod">PRODUCT</th>
                <th class="rcpt-col-qty">QTY</th>
                <th class="rcpt-col-price">PRICE</th>
                <th class="rcpt-col-amt">AMOUNT</th>
            </tr>
        </thead>
        <tbody id="rcptItemsBody">
            <!-- filled by JS -->
        </tbody>
    </table>

    <!-- Totals -->
    <div class="rcpt-totals-row"><span>SUB TOTAL</span>  <span id="rcptSubTotal">$0</span></div>
    <div class="rcpt-totals-row"><span>TOTAL</span>      <span id="rcptTotal">$0</span></div>
    <div class="rcpt-totals-row"><span>AMOUNT DUE</span> <span id="rcptDue">$0</span></div>
    <div class="rcpt-totals-row"><span>CASH SALE</span>  <span id="rcptCash">$0</span></div>
    <div class="rcpt-totals-row"><span>PAY TYPE</span>   <span id="rcptPayType">Cash</span></div>

    <!-- Footer -->
    <div class="rcpt-footer">
        <hr class="rcpt-hr" />
        <div class="rcpt-footer-thankyou">THANK YOU!</div>
        <hr class="rcpt-hr" />
        <div class="rcpt-footer-promo">*** Refer a Friend To Smoke Drop &amp; Get 5% off. ***</div>
        <hr class="rcpt-hr" />
        <div class="rcpt-footer-copy">Copyrights 2026, Powered by The SATA Invoice</div>
        <hr class="rcpt-hr" />
    </div>

    <!-- Bottom: Order info (left) + Barcode (right) -->
    <div class="rcpt-bottom">

        <div class="order-info">
            <div id="rcptOrderNo">ORDER: SALE_1</div>
            <div id="rcptDate"></div>
        </div>

        <!-- Barcode Section -->
        <div class="barcode-container">

            <svg id="rcptBarcodeSvg"></svg>

        </div>

    </div>

</div>

<!-- ═══════════════════════════════════════════
     JAVASCRIPT
═══════════════════════════════════════════ -->
<script>
    /* ═══════════════════════════════════════════════════════
       STATE
    ═══════════════════════════════════════════════════════ */
    let saleItems    = [];
    let currentTotal = 0;
    let searchMode   = 'barcode';

    /* ═══════════════════════════════════════════════════════
       HELPERS
    ═══════════════════════════════════════════════════════ */
    const format = (v) =>
        (v < 0 ? '-' : '') + '$' +
        Math.abs(v).toLocaleString(undefined, { minimumFractionDigits: 2 });

    async function getNextOrderId(isReturn) {
        try {
            const mode = isReturn ? 'return' : 'sale';
            const res  = await fetch(`/Sale/GetNextBillNo?mode=${mode}`);
            const data = await res.json();
            return data.billNo;
        } catch (e) {
            return isReturn ? 'RETURN_ERR' : 'SALE_ERR';
        }
    }

    /* ═══════════════════════════════════════════════════════
       UI HELPERS
    ═══════════════════════════════════════════════════════ */
    function toggleFullScreen() {
        if (!document.fullscreenElement) document.documentElement.requestFullscreen();
        else if (document.exitFullscreen) document.exitFullscreen();
    }
    function reloadPage() {
        if (saleItems.length > 0) {
            if (confirm('Cart contains items. Reload and lose changes?')) location.reload();
        } else location.reload();
    }
    function showStockAlert(msg) {
        const el = document.getElementById('stockAlert');
        document.getElementById('stockAlertMsg').innerText = msg;
        el.style.display = 'block';
        setTimeout(() => el.style.display = 'none', 4000);
    }

    /* ═══════════════════════════════════════════════════════
       MODALS
    ═══════════════════════════════════════════════════════ */
    function openCustomItemModal() {
        document.getElementById('customName').value  = '';
        document.getElementById('customPrice').value = '';
        document.getElementById('customItemModal').classList.add('show');
        document.getElementById('customName').focus();
    }
    function closeCustomItemModal() { document.getElementById('customItemModal').classList.remove('show'); }

    function triggerCustomerModalV2(e) {
        if (e) e.preventDefault();
        ['newCustName','newCustContact','newCustEmail','newCustAddress']
            .forEach(id => document.getElementById(id).value = '');
        document.getElementById('customerModal').classList.add('show');
        document.getElementById('newCustName').focus();
    }
    function closeCustomerModal() { document.getElementById('customerModal').classList.remove('show'); }

    function openPaymentModal() {
        if (saleItems.length === 0) return alert('Cart is empty.');
        document.getElementById('webModalTotal').innerText = format(Math.abs(currentTotal));
        document.getElementById('webTendered').value = '';
        calculateWebChange();
        document.getElementById('paymentModal').classList.add('show');
    }
    function closePaymentModal() { document.getElementById('paymentModal').classList.remove('show'); }

    /* ═══════════════════════════════════════════════════════
       CUSTOM ITEM
    ═══════════════════════════════════════════════════════ */
    function addCustomItem() {
        const name  = document.getElementById('customName').value.trim();
        const price = parseFloat(document.getElementById('customPrice').value);
        if (!name)                     return alert('Please enter item name');
        if (isNaN(price) || price < 0) return alert('Please enter a valid price');
        addItemToSale(0, name, price, 0, null, null, 999999, null);
        closeCustomItemModal();
    }

    /* ═══════════════════════════════════════════════════════
       SAVE CUSTOMER AJAX
    ═══════════════════════════════════════════════════════ */
    async function saveCustomerAjax() {
        const name    = document.getElementById('newCustName').value.trim();
        const contact = document.getElementById('newCustContact').value.trim();
        const email   = document.getElementById('newCustEmail').value.trim();
        const address = document.getElementById('newCustAddress').value.trim();
        const status  = document.getElementById('newCustStatus').value;
        if (!name) return alert('Customer name is required.');
        try {
            const token    = document.querySelector('input[name="__RequestVerificationToken"]')?.value;
            const response = await fetch('/Customer/CreateAjax', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json', 'RequestVerificationToken': token },
                body: JSON.stringify({ name, contact, email, address, status })
            });
            const data = await response.json();
            if (data.success) {
                allCustomers.push({ name: data.name, contact, email });
                selectCustomer(data.name);
                closeCustomerModal();
            } else {
                alert('Error saving customer: ' + (data.message || 'Unknown error'));
            }
        } catch (err) {
            alert('An error occurred while saving the customer.');
        }
    }

    /* ═══════════════════════════════════════════════════════
       PRODUCT SEARCH / FILTER
    ═══════════════════════════════════════════════════════ */
    function handleSearchModeChange() {
        searchMode = document.querySelector('input[name="searchMode"]:checked').value;
        const input = document.getElementById('prodSearch');
        input.placeholder = searchMode === 'name'
            ? 'Search by product name...'
            : 'Scan or enter barcode...';
        input.value = '';
        filterProducts();
        input.focus();
    }

    async function filterProducts() {
        const query      = document.getElementById('prodSearch').value.trim();
        const queryLower = query.toLowerCase();
        let exactMatchCard = null;



        document.querySelectorAll('.product-card-v2').forEach(card => {
            const name    = card.getAttribute('data-search-name') || '';
            const barcode = (card.getAttribute('data-barcode') || '').toLowerCase();
            if (!query) { card.style.display = 'flex'; return; }
            if (searchMode === 'barcode') {
                card.style.display = barcode.includes(queryLower) ? 'flex' : 'none';
                if (barcode === queryLower) exactMatchCard = card;
            } else {
                card.style.display = name.includes(queryLower) ? 'flex' : 'none';
            }
        });

        if (searchMode === 'barcode' && exactMatchCard) {
            addToSaleFromCard(exactMatchCard);
            document.getElementById('prodSearch').value = '';
            document.querySelectorAll('.product-card-v2').forEach(c => c.style.display = 'flex');
        }
    }

    function filterByCategory(cat, btn) {
        document.querySelectorAll('.tab-item').forEach(el => el.classList.remove('active'));
        if (btn) btn.classList.add('active');
        document.querySelectorAll('.product-card-v2').forEach(card => {
            const type = card.getAttribute('data-type');
            if      (cat === 'all')                             card.style.display = 'flex';
            else if (cat === 'Foods'     && type === 'product') card.style.display = 'flex';
            else if (cat === 'Beverages' && type === 'service') card.style.display = 'flex';
            else                                                card.style.display = 'none';
        });
    }

    /* ═══════════════════════════════════════════════════════
       SALE ITEMS
    ═══════════════════════════════════════════════════════ */
    function addToSaleFromCard(card) {
        addItemToSale(
            card.dataset.id,    card.dataset.name,
            parseFloat(card.dataset.price),
            parseFloat(card.dataset.discount),
            card.dataset.expiry  || null,
            card.dataset.barcode || null,
            parseFloat(card.dataset.stock),
            card.dataset.image   || null
        );
    }

    async function addItemToSale(id, name, price, discount, expiry, barcode, maxStock, image) {
        const isReturn = document.querySelector('input[name="transMode"]:checked').value === 'return';
        const qtyToAdd = isReturn ? -1 : 1;
        const existing = saleItems.find(i => i.prod_name_service === name);
        if (existing) {
            if (!isReturn && (existing.qty + qtyToAdd) > maxStock)
                return showStockAlert(`Only ${maxStock} available.`);
            existing.qty += qtyToAdd;
            if (existing.qty === 0) return removeItem(saleItems.indexOf(existing));
            existing.total_price = (existing.price * existing.qty) - (existing.discount * existing.qty);
        } else {
            if (!isReturn && qtyToAdd > maxStock)
                return showStockAlert(`Insufficient stock (${maxStock}).`);
            saleItems.push({
                prod_name_service: name,
                barcode:     barcode || null,
                qty:         qtyToAdd,
                price,
                discount,
                expiry_date: expiry  || null,
                maxStock,
                image:       image   || null,
                total_price: (price * qtyToAdd) - (discount * qtyToAdd)
            });
        }
        renderSaleItems();
    }

    function renderSaleItems() {
        const body            = document.getElementById('saleItemsBody');
        const empty           = document.getElementById('emptyStateV2');
        const hiddenContainer = document.getElementById('hiddenInputsContainer');
        const countDisplay    = document.getElementById('itemCountDisplay');

        body.innerHTML            = '';
        hiddenContainer.innerHTML = '';
        countDisplay.innerText    = `${saleItems.length} item${saleItems.length !== 1 ? 's' : ''} selected`;

        if (saleItems.length === 0) {
            empty.style.display = 'flex';
            body.style.display  = 'none';
            document.getElementById('subtotalDisplay').innerText = '$0.00';
            document.getElementById('discountDisplay').innerText = '$0.00';
            document.getElementById('grandTotal').innerText      = '$0.00';
            currentTotal = 0;
            return;
        }

        empty.style.display = 'none';
        body.style.display  = 'flex';

        let totalSub = 0, totalDisc = 0, totalBase = 0;

        saleItems.forEach((item, index) => {
            const lineSub   = item.price    * item.qty;
            const lineDisc  = item.discount * item.qty;
            const lineTotal = lineSub - lineDisc;
            totalSub  += lineSub;
            totalDisc += lineDisc;
            totalBase += lineTotal;

            const div = document.createElement('div');
            div.className = 'item-v2';
            div.innerHTML = `
                <div class="item-v2-img">${item.image
                    ? `<img src="/product-images/${item.image}" />`
                    : `<i class="ph-package" style="font-size:1.5rem;color:#cbd5e1;"></i>`}</div>
                <div class="item-v2-info">
                    <div class="title">${item.prod_name_service}</div>
                    <div class="price-input-container">
                        <span>$</span>
                        <input type="number" step="0.01" class="manual-price-input" 
                               value="${item.price.toFixed(2)}"
                               onchange="updateItemPrice(${index}, this.value)">
                    </div>
                </div>
                <div class="item-v2-controls">
                    <div class="qty-stepper">
                        <button type="button" onclick="decreaseQtyBtn(${index})">-</button>
                        <input type="number" class="manual-qty-input"
                               value="${item.qty < 0 ? '-' : ''}${Math.abs(item.qty)}"
                               onchange="updateItemQty(${index}, this.value)">
                        <button type="button" onclick="increaseQty(${index})">+</button>
                    </div>
                </div>
                <div class="item-total-info">
                    <div class="price-sub">${format(lineTotal)}</div>
                </div>
                <i class="ph-trash btn-remove-item" onclick="removeItem(${index})"></i>`;
            body.appendChild(div);

            const prefix = `items[${index}]`;
            hiddenContainer.innerHTML += `
                <input type="hidden" name="${prefix}.id"                   value="${item.id || 0}" />
                <input type="hidden" name="${prefix}.prod_name_service" value="${item.prod_name_service}" />
                <input type="hidden" name="${prefix}.barcode"           value="${item.barcode || ''}" />
                <input type="hidden" name="${prefix}.qty_unit_type"     value="${item.qty}" />
                <input type="hidden" name="${prefix}.price"             value="${item.price}" />
                <input type="hidden" name="${prefix}.discount"          value="${item.discount}" />
                <input type="hidden" name="${prefix}.expiry_date"       value="${item.expiry_date || ''}" />
                <input type="hidden" name="${prefix}.total_price"       value="${lineTotal}" />`;
        });

        currentTotal = totalBase;
        document.getElementById('subtotalDisplay').innerText = format(totalSub);
        document.getElementById('discountDisplay').innerText = format(totalDisc);
        document.getElementById('grandTotal').innerText      = format(totalBase);
    }

    async function increaseQty(index) {
        const item     = saleItems[index];
        const isReturn = document.querySelector('input[name="transMode"]:checked').value === 'return';
        if (isReturn) {
            const v = await validateReturnEligibility(item.prod_name_service);
            if (Math.abs(item.qty - 1) > v.purchasedQty) return showStockAlert('Max returnable reached.');
            item.qty--;
        } else {
            if (item.qty >= item.maxStock) return showStockAlert('Max stock reached.');
            item.qty++;
        }
        item.total_price = (item.price * item.qty) - (item.discount * item.qty);
        renderSaleItems();
    }

    function decreaseQtyBtn(index) {
        const item     = saleItems[index];
        const isReturn = document.querySelector('input[name="transMode"]:checked').value === 'return';
        if (isReturn) item.qty++; else item.qty--;
        if (item.qty === 0) removeItem(index);
        else {
            item.total_price = (item.price * item.qty) - (item.discount * item.qty);
            renderSaleItems();
        }
    }

    function removeItem(index) { saleItems.splice(index, 1); renderSaleItems(); }

    function updateItemPrice(index, value) {
        let val = parseFloat(value);
        if (isNaN(val) || val < 0) val = 0;
        saleItems[index].price       = val;
        saleItems[index].total_price = (val * saleItems[index].qty) - (saleItems[index].discount * saleItems[index].qty);
        renderSaleItems();
    }

    async function updateItemQty(index, value) {
        let val        = parseInt(value, 10);
        if (isNaN(val)) val = 1;
        const item     = saleItems[index];
        const isReturn = document.querySelector('input[name="transMode"]:checked').value === 'return';
        if (isReturn) {
            val = -Math.abs(val);
            if (val === 0) { removeItem(index); return; }
            const v = await validateReturnEligibility(item.prod_name_service);
            if (Math.abs(val) > v.purchasedQty) { showStockAlert('Max returnable reached.'); val = -v.purchasedQty; }
        } else {
            val = Math.abs(val);
            if (val === 0) { removeItem(index); return; }
            if (val > item.maxStock) { showStockAlert('Max stock reached.'); val = item.maxStock; }
        }
        item.qty         = val;
        item.total_price = (item.price * item.qty) - (item.discount * item.qty);
        renderSaleItems();
    }

    function clearSaleItems() {
        if (saleItems.length > 0 && confirm('Clear current order?')) {
            saleItems = [];
            renderSaleItems();
        }
    }

    async function handleModeChange() {
        const isReturn = document.querySelector('input[name="transMode"]:checked').value === 'return';
        
        // Toggle banner
        const banner = document.querySelector('.return-warning-banner');
        if (banner) banner.style.display = isReturn ? 'flex' : 'none';

        saleItems.forEach(item => {
            const absQty     = Math.abs(item.qty);
            item.qty         = isReturn ? -absQty : absQty;
            item.total_price = (item.price * item.qty) - (item.discount * item.qty);
        });
        renderSaleItems();
    }

    async function handleCustomerChange() {
        const customerName = document.getElementById('customerSelect').value;
        const isReturn     = document.querySelector('input[name="transMode"]:checked').value === 'return';
        if (isReturn && customerName) {
            try {
                const res  = await fetch('/Sale/CheckAnyPurchaseHistory');
                const data = await res.json();
                if (!data.hasAnyHistory) {
                    showStockAlert('Customer has no active purchases.');
                    saleItems = [];
                    renderSaleItems();
                    return;
                }
            } catch (e) {}
            const filtered = [];
            for (const item of saleItems) {
                const v = await validateReturnEligibility(item.prod_name_service);
                if (v.eligible) {
                    item.qty         = -Math.min(Math.abs(item.qty), v.purchasedQty);
                    item.total_price = (item.price * item.qty) - (item.discount * item.qty);
                    filtered.push(item);
                }
            }
            saleItems = filtered;
            renderSaleItems();
        }
    }

    async function validateReturnEligibility(productName) {
        if (!productName) return { eligible: true, purchasedQty: 0 };
        try {
            const res  = await fetch(`/Sale/CheckPurchaseHistory?productName=${encodeURIComponent(productName)}`);
            const data = await res.json();
            return { eligible: data.hasPurchased, purchasedQty: data.purchasedQty || 0 };
        } catch (e) {
            return { eligible: true, purchasedQty: 999999 };
        }
    }

    /* ═══════════════════════════════════════════════════════
       INVOICE SEARCH & LOAD (RETURN BASIS)
    ═══════════════════════════════════════════════════════ */
    async function handleBillSearch(e) {
        if (e.key !== 'Enter') return;
        const billNo = e.target.value.trim();
        if (!billNo) return;

        try {
            const res = await fetch(`/Sale/GetItemsByBillNo?billNo=${encodeURIComponent(billNo)}`);
            const data = await res.json();

            if (data.success) {
                if (saleItems.length > 0 && !confirm('Clear current cart and load items for return?')) return;
                
                saleItems = data.items.map(item => ({
                    id:                item.id,
                    prod_name_service: item.prod_name_service,
                    barcode:           item.barcode,
                    qty:               -Math.abs(item.qty), // Set as return
                    price:             item.price,
                    discount:          item.discount,
                    expiry_date:       item.expiry_date,
                    maxStock:          item.qty, // Use original qty as limit for return
                    total_price:       (item.price * -item.qty) - (item.discount * -item.qty)
                }));

                // Switch to Return Mode UI
                document.getElementById('modeReturn').checked = true;
                handleModeChange();
                
                e.target.value = '';
                renderSaleItems();
            } else {
                alert(data.message || 'Invoice not found.');
            }
        } catch (err) {
            alert('Error fetching invoice details.');
        }
    }

    /* ═══════════════════════════════════════════════════════
       PAYMENT
    ═══════════════════════════════════════════════════════ */
    function setWebPaymentMethod(method) {
        document.getElementById('hiddenPaymentMethod').value = method;
        document.getElementById('hiddenStatus').value        = method === 'Credit' ? 'Pending' : 'Paid';
        document.querySelectorAll('.method-tab').forEach(t => t.classList.remove('active'));
        if (typeof event !== 'undefined' && event.currentTarget) event.currentTarget.classList.add('active');
        else if (window.event && window.event.currentTarget) window.event.currentTarget.classList.add('active');
    }

    function calculateWebChange() {
        var tendered = parseFloat(document.getElementById('webTendered').value) || 0;
        var total    = Math.abs(currentTotal);
        var change   = tendered - total;
        document.getElementById('webModalTendered').innerText = format(tendered);
        
        var changeEl = document.getElementById('webModalChange');
        // Always show the absolute value to avoid negative signs as requested
        changeEl.innerText = format(Math.abs(change));
        
        // Use colors to indicate status: Green if fully paid/overpaid, Red if underpaid
        if (change >= 0) {
            changeEl.style.color = "#22c55e"; 
        } else {
            changeEl.style.color = "#ef4444";
        }
    }

    function addWebAmount(amt) {
        const el = document.getElementById('webTendered');
        el.value = (parseFloat(el.value || 0) + amt).toFixed(2);
        calculateWebChange();
    }
    function matchWebAmount() {
        document.getElementById('webTendered').value = Math.abs(currentTotal).toFixed(2);
        calculateWebChange();
    }

    function submitSaleForm() {
        const method        = document.getElementById('hiddenPaymentMethod').value;
        const tenderedInput = document.getElementById('webTendered').value;
        const tendered      = parseFloat(tenderedInput);
        if (!tenderedInput || isNaN(tendered)) return alert('Please enter the amount tendered.');
        if (tendered <= 0)                     return alert('Amount tendered must be greater than zero.');
        if (method !== 'Credit' && tendered < Math.abs(currentTotal))
            return alert('Amount tendered is less than the grand total.');
        // Read the print toggle and go directly — no popup
        const shouldPrint = document.getElementById('printReceiptToggle').checked;
        processFinalSubmission(shouldPrint);
    }

    function askToPrintReceipt() { submitSaleForm(); }

    async function processFinalSubmission(shouldPrint) {
        const isReturn = document.querySelector('input[name="transMode"]:checked').value === 'return';
        const orderId  = await getNextOrderId(isReturn);
        document.getElementById('hiddenBillNo').value = orderId;

        // Ensure customer is set
        const hi = document.getElementById('customerSelect');
        const si = document.getElementById('customerSearchInput');
        if (!hi.value) hi.value = si.value || 'Walk-In';

        if (shouldPrint) {
            await prepareReceiptData(orderId);
            window.print();
        }
        
        document.getElementById('saleForm').submit();
    }

    async function prepareReceiptData(orderId) {
        const isReturn     = document.querySelector('input[name="transMode"]:checked').value === 'return';
        const customerName = document.getElementById('customerSearchInput').value || 'Walk-In';
        const payMethod    = document.getElementById('hiddenPaymentMethod').value  || 'Cash';
        const netAmount    = Math.abs(currentTotal);
        const tendered     = parseFloat(document.getElementById('webTendered').value) || 0;

        const fv     = (v) => '$' + (v % 1 === 0 ? Math.round(v).toString() : v.toFixed(2));
        const fmtVal = (v) => v % 1 === 0 ? Math.round(v).toString() : v.toFixed(2);

        const now     = new Date();
        const dateStr = now.toLocaleString('en-US', {
            month: 'numeric', day: 'numeric', year: 'numeric',
            hour: 'numeric', minute: '2-digit', second: '2-digit', hour12: true
        });

        document.getElementById('rcptCustomer').innerText = customerName;

        let subTotal = 0;
        saleItems.forEach(item => { subTotal += (item.price * item.qty); });

        document.getElementById('rcptSubTotal').innerText = fv(Math.abs(subTotal));
        document.getElementById('rcptTotal').innerText    = fv(netAmount);
        document.getElementById('rcptDue').innerText      = fv(netAmount);
        document.getElementById('rcptCash').innerText     = fv(tendered);
        document.getElementById('rcptPayType').innerText  = payMethod;
        document.getElementById('rcptOrderNo').innerText  = 'ORDER: ' + orderId;
        document.getElementById('rcptDate').innerText     = dateStr;

        // Use JsBarcode for reliable, industry-standard barcode generation
        // width: 2 is the "sweet spot" for 58mm/80mm thermal printers
        JsBarcode("#rcptBarcodeSvg", orderId, {
            format: "CODE128",
            width: 2,
            height: 80,
            displayValue: true,
            fontSize: 20,
            fontOptions: "bold",
            margin: 10,
            textMargin: 5,
            background: "#ffffff",
            lineColor: "#000000",
            flat: true
        });

        const itemsBody = document.getElementById('rcptItemsBody');
        itemsBody.innerHTML = '';
        saleItems.forEach(item => {
            const row = document.createElement('tr');
            row.innerHTML = `
                <td class="rcpt-col-prod">${item.prod_name_service}</td>
                <td class="rcpt-col-qty">${Math.abs(item.qty)}</td>
                <td class="rcpt-col-price">${fmtVal(item.price)}</td>
                <td class="rcpt-col-amt">${fmtVal(Math.abs(item.total_price))}</td>`;
            itemsBody.appendChild(row);
        });
    }



    /* ═══════════════════════════════════════════════════════
       CUSTOMER DROPDOWN
    ═══════════════════════════════════════════════════════ */
    const allCustomers = @Html.Raw(Json.Serialize(customerList?.Select(c => new { name = c.name, contact = c.contact, email = c.email }))) ?? [];
    let highlightedIndex = -1;

    document.addEventListener('DOMContentLoaded', () => {
        const si = document.getElementById('customerSearchInput');
        const rc = document.getElementById('customerResults');
        const hi = document.getElementById('customerSelect');
        if (!si) return;

        si.addEventListener('focus', () => filterCustomerResults(si, rc));
        si.addEventListener('input', () => filterCustomerResults(si, rc));
        si.addEventListener('keydown', (e) => {
            const items = rc.querySelectorAll('.customer-result-item');
            if (e.key === 'ArrowDown') { e.preventDefault(); highlightedIndex = Math.min(highlightedIndex + 1, items.length - 1); updateHighlight(items); }
            else if (e.key === 'ArrowUp') { e.preventDefault(); highlightedIndex = Math.max(highlightedIndex - 1, 0); updateHighlight(items); }
            else if (e.key === 'Enter') { e.preventDefault(); if (highlightedIndex >= 0 && items[highlightedIndex]) items[highlightedIndex].click(); }
            else if (e.key === 'Escape') rc.classList.remove('show');
        });
        document.addEventListener('click', (e) => { if (!si.contains(e.target) && !rc.contains(e.target)) rc.classList.remove('show'); });
    });

    function filterCustomerResults(si, rc) {
        const query = si.value.toLowerCase(); rc.innerHTML = '';
        const filtered = allCustomers.filter(c => c.name.toLowerCase().includes(query) || (c.contact && c.contact.includes(query)));
        if (filtered.length === 0) { rc.innerHTML = `<div class="customer-result-item" style="cursor:default;color:var(--text-muted);">No customers found</div>`; }
        else {
            filtered.forEach(c => {
                const div = document.createElement('div'); div.className = 'customer-result-item';
                div.innerHTML = `<span class="cust-name">${c.name}</span>${c.contact ? `<span class="cust-details">${c.contact}</span>` : ''}`;
                div.onclick = () => { si.value = c.name; hi.value = c.name; rc.classList.remove('show'); handleCustomerChange(); };
                rc.appendChild(div);
            });
        }
        rc.classList.add('show'); highlightedIndex = -1;
    }

    function updateHighlight(items) {
        items.forEach((item, idx) => {
            if (idx === highlightedIndex) { item.classList.add('highlighted'); item.scrollIntoView({ block: 'nearest' }); }
            else item.classList.remove('highlighted');
        });
    }

    function selectCustomer(name) {
        const si = document.getElementById('customerSearchInput');
        const hi = document.getElementById('customerSelect');
        if (si) si.value = name; if (hi) hi.value = name;
        handleCustomerChange();
    }
</script>

<script src="https://cdn.jsdelivr.net/npm/select2@4.1.0-rc.0/dist/js/select2.min.js"></script>
